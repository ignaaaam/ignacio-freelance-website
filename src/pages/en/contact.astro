---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import ContactIntro from '../../components/ContactIntro.astro';
import ContactSection from '../../components/Contact.astro';
import StickyCTA from '../../components/StickyGTA.astro';
import { getTranslation } from '../../i18n/utils';

const locale = 'en';
const t = (key: string) => getTranslation(locale, key);
---

<Layout
	title={t('seo.contact.title')}
	description={t('seo.contact.description')}
	lang="en"
	canonicalUrl="/en/contact"
	alternateUrls={{ es: '/contact', en: '/en/contact' }}
>
	<Header />
	<main>
		<ContactIntro />
		<ContactSection />
	</main>
	<StickyCTA />
</Layout>
