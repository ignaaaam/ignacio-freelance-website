---
import MarketingContentPage from '../../components/MarketingContentPage.astro';

const baseUrl = 'https://www.ignacioamatweb.com';
const title = 'Professional landing page development for lead generation | Ignacio Amat';
const description =
  'Landing pages for lead generation, launches and focused offers. Clear messaging, guided copy structure, forms, integrations and technical setup built around one main conversion goal.';
const canonicalUrl = '/en/professional-landing-page-development';
const keywords = [
  'landing page development',
  'professional landing page',
  'high converting landing page',
  'landing page design',
  'landing page for business',
  'landing page cost',
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Landing page development',
  provider: {
    '@type': 'ProfessionalService',
    name: 'Ignacio Amat - Web Developer',
    url: baseUrl,
  },
  areaServed: {
    '@type': 'Country',
    name: 'Spain',
  },
  description:
    'Landing page development for campaigns, launches and focused offers with one clear conversion goal, integrations and a performance-minded technical base.',
  offers: {
    '@type': 'Offer',
    priceRange: 'Starting from EUR 800',
    priceCurrency: 'EUR',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How much does a professional landing page cost?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A straightforward landing page usually starts from EUR 800. Pricing goes up when the project needs multiple variants, integrations, automation or a heavier validation layer.',
      },
    },
    {
      '@type': 'Question',
      name: 'When is a landing page a better fit than a full website?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A landing page is the better fit when you want to promote one offer, one campaign or one service with a single primary action and less navigation noise.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do you include forms, integrations and tracking?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. I can set up forms, conversion tracking, CRM or email marketing integrations and a practical technical baseline for launch.',
      },
    },
    {
      '@type': 'Question',
      name: 'How long does a landing page take?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A well-defined landing page can move quickly. If the project needs more iterations, integrations or message refinement, the typical timeline is between a few days and two weeks.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do I need fully finished copy before we start?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Not always. If the offer is clear but the wording is still rough, I can help structure the message and page flow before implementation starts.',
      },
    },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: `${baseUrl}/en/`,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Professional landing page development',
      item: `${baseUrl}${canonicalUrl}`,
    },
  ],
};

const allSchemas = [serviceSchema, faqSchema, breadcrumbSchema];

const facts = [
  { label: 'Best for', value: 'Campaigns, launches and focused offers with one primary action.' },
  { label: 'Indicative investment', value: 'Starting from EUR 800 depending on message complexity, integrations and validation needs.' },
  { label: 'Typical timeline', value: 'From a few days to roughly two weeks when scope is clear.' },
];
---
<MarketingContentPage
  title={title}
  description={description}
  lang="en"
  canonicalUrl={canonicalUrl}
  keywords={keywords}
  additionalSchemas={allSchemas}
  alternateUrls={{ es: '/crear-landing-page-profesional', en: canonicalUrl }}
  badge="Landing pages for lead generation"
  pageTitle="Landing pages built to explain the offer clearly and convert without noise"
  lead="I design and develop landing pages for campaigns, launches and service offers when the goal is to keep the message focused, remove friction and move visitors toward one clear next step."
  primaryCta={{ label: 'Request a quote', href: '#contacto' }}
  secondaryCta={{ label: 'See all services', href: '/en/services' }}
  facts={facts}
>
  <div class="prose prose-lg max-w-none">
    <h2 class="text-2xl sm:text-3xl font-bold mt-8 mb-4">What makes a landing page work</h2>
    <p class="text-base sm:text-lg mb-4">
      A landing page does not need to feel large. It needs to make the offer clear, show who it is
      for, explain why it matters and make the next step obvious. When that chain breaks, traffic arrives
      but never turns into useful conversations.
    </p>
    <p class="text-base sm:text-lg mb-6">
      My approach is not about decorating a page. It is about tightening the message, clarifying the
      visual hierarchy and reducing contact friction so visitors understand quickly whether they should act.
    </p>

    <div class="grid sm:grid-cols-2 gap-4 sm:gap-6 mb-8">
      <div class="card p-5">
        <h3 class="text-lg font-semibold mb-2">Clear offer from the start</h3>
        <p class="text-text-muted text-sm sm:text-base">
          Visitors should understand in seconds what you offer, who it is for and what kind of result to expect.
        </p>
      </div>
      <div class="card p-5">
        <h3 class="text-lg font-semibold mb-2">One primary action</h3>
        <p class="text-text-muted text-sm sm:text-base">
          The page is built around one goal: request a proposal, book a call or leave details.
        </p>
      </div>
      <div class="card p-5">
        <h3 class="text-lg font-semibold mb-2">Trust and context</h3>
        <p class="text-text-muted text-sm sm:text-base">
          FAQs, reassurance, proof layers and a visual treatment that supports the message instead of distracting from it.
        </p>
      </div>
      <div class="card p-5">
        <h3 class="text-lg font-semibold mb-2">Performance and measurement</h3>
        <p class="text-text-muted text-sm sm:text-base">
          Fast loading, a clean form flow and a technical setup that is ready to measure conversions and iterate later.
        </p>
      </div>
    </div>

    <h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">When a landing page is the right tool</h2>
    <div class="grid sm:grid-cols-2 gap-4 sm:gap-6 mb-8">
      <div class="bg-secondary p-4 sm:p-6 rounded-lg">
        <h3 class="text-base sm:text-lg font-bold mb-2">Lead capture</h3>
        <p class="text-sm sm:text-base">
          For paid traffic, organic campaigns or outbound efforts where you want attention focused on one offer or service.
        </p>
      </div>
      <div class="bg-secondary p-4 sm:p-6 rounded-lg">
        <h3 class="text-base sm:text-lg font-bold mb-2">Launches and validation</h3>
        <p class="text-sm sm:text-base">
          Useful when you want to test interest before expanding the wider site or building something heavier than needed.
        </p>
      </div>
      <div class="bg-secondary p-4 sm:p-6 rounded-lg">
        <h3 class="text-base sm:text-lg font-bold mb-2">A focused service offer</h3>
        <p class="text-sm sm:text-base">
          Especially effective when you are selling one specific service and do not want navigation to dilute the decision.
        </p>
      </div>
      <div class="bg-secondary p-4 sm:p-6 rounded-lg">
        <h3 class="text-base sm:text-lg font-bold mb-2">Campaigns with measurable intent</h3>
        <p class="text-sm sm:text-base">
          If you care about calls, forms or booked intros, a focused landing page gives more control than a broad website page.
        </p>
      </div>
    </div>

    <h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">What is usually included</h2>
    <ul class="list-disc pl-5 sm:pl-6 space-y-2 mb-8 text-sm sm:text-base">
      <li><strong>Message structure:</strong> section order, content hierarchy and guidance to make the copy clearer.</li>
      <li><strong>Responsive design:</strong> built for mobile, tablet and desktop from the beginning.</li>
      <li><strong>Forms and lead flow:</strong> validation, spam protection and a simpler contact experience.</li>
      <li><strong>Integrations:</strong> CRM, email marketing, automation or event tracking where the project needs them.</li>
      <li><strong>Technical SEO baseline:</strong> metadata, Open Graph, semantic structure and structured data where useful.</li>
      <li><strong>Clean launch:</strong> final review, deployment and a setup that stays easy to maintain.</li>
    </ul>

    <h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">Indicative investment</h2>
    <div class="space-y-4 mb-8">
      <div class="bg-secondary p-4 sm:p-6 rounded-lg">
        <h3 class="font-bold text-base sm:text-lg mb-1">Essential landing page — from EUR 800</h3>
        <p class="text-sm sm:text-base text-text-muted">
          A focused page built around one conversion goal, with responsive design, form flow and launch-ready technical setup.
        </p>
      </div>
      <div class="bg-secondary p-4 sm:p-6 rounded-lg">
        <h3 class="font-bold text-base sm:text-lg mb-1">Landing page with integrations — from EUR 1,100</h3>
        <p class="text-sm sm:text-base text-text-muted">
          For projects that need CRM connections, automation, richer forms or a more connected sales flow.
        </p>
      </div>
      <div class="bg-secondary p-4 sm:p-6 rounded-lg">
        <h3 class="font-bold text-base sm:text-lg mb-1">Landing page plus iteration phase — custom scoped</h3>
        <p class="text-sm sm:text-base text-text-muted">
          Useful when launch is only phase one and you want a second pass with new tests, variants or extensions.
        </p>
      </div>
    </div>
    <p class="text-sm text-text-muted mb-8">
      If the offer itself is still fuzzy, the right first step is to tighten scope and message before building.
    </p>

    <h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-6">Frequently asked questions</h2>
    <div class="space-y-4 mb-8">
      <div class="bg-secondary p-4 sm:p-6 rounded-lg">
        <h3 class="text-base sm:text-lg font-bold mb-2">How much does a professional landing page cost?</h3>
        <p class="text-sm sm:text-base">
          A straightforward landing page usually starts from EUR 800. Final pricing depends on the message, the number of moving parts and the integration work involved.
        </p>
      </div>
      <div class="bg-secondary p-4 sm:p-6 rounded-lg">
        <h3 class="text-base sm:text-lg font-bold mb-2">How is it different from a business website?</h3>
        <p class="text-sm sm:text-base">
          A business website spreads attention across multiple sections and services. A landing page focuses everything on one action and removes extra decision paths.
        </p>
      </div>
      <div class="bg-secondary p-4 sm:p-6 rounded-lg">
        <h3 class="text-base sm:text-lg font-bold mb-2">Can it connect to my CRM or email platform?</h3>
        <p class="text-sm sm:text-base">
          Yes. I can connect forms, automation and tracking so new enquiries do not get lost in manual handoffs.
        </p>
      </div>
      <div class="bg-secondary p-4 sm:p-6 rounded-lg">
        <h3 class="text-base sm:text-lg font-bold mb-2">Do I need all the copy finished before we start?</h3>
        <p class="text-sm sm:text-base">
          Not always. If the offer is clear but the wording is still rough, I can help shape the structure and message before implementation.
        </p>
      </div>
    </div>

    <h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">Related services</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-8">
      <a href="/en/web-design-businesses" class="block p-3 bg-secondary rounded-lg text-sm font-medium text-center hover:shadow-md transition-all">Business websites &rarr;</a>
      <a href="/en/website-redesign-improvements" class="block p-3 bg-secondary rounded-lg text-sm font-medium text-center hover:shadow-md transition-all">Redesigns and improvements &rarr;</a>
      <a href="/en/hire-full-stack-web-developer" class="block p-3 bg-secondary rounded-lg text-sm font-medium text-center hover:shadow-md transition-all">Full-stack freelance &rarr;</a>
      <a href="/en/web-application-saas-development" class="block p-3 bg-secondary rounded-lg text-sm font-medium text-center hover:shadow-md transition-all">Web apps and MVPs &rarr;</a>
      <a href="/en/how-much-does-website-cost" class="block p-3 bg-secondary rounded-lg text-sm font-medium text-center hover:shadow-md transition-all">Pricing guide &rarr;</a>
      <a href="/en/services" class="block p-3 bg-secondary rounded-lg text-sm font-medium text-center hover:shadow-md transition-all">All services &rarr;</a>
    </div>

    <div class="bg-accent/10 p-4 sm:p-6 rounded-lg mt-8 mb-4">
      <h2 class="text-xl sm:text-2xl font-bold mb-3">Need a landing page that makes better use of the traffic you already have?</h2>
      <p class="mb-3 text-sm sm:text-base">
        Tell me what you are offering, where the traffic comes from and what action you want visitors to take. That is enough to tell whether a focused landing page is the right move or whether the project needs a broader setup.
      </p>
      <p class="font-semibold text-sm sm:text-base">
        Initial quote with no commitment<br />
        Clear direction before build work starts<br />
        Direct implementation without agency layers
      </p>
    </div>
  </div>
</MarketingContentPage>
