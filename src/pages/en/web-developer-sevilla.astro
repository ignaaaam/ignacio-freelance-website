---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Contact from '../../components/Contact.astro';
import StickyCTA from '../../components/StickyGTA.astro';
import SeoCityInternalLinks from '../../components/SeoCityInternalLinks.astro';

const baseUrl = 'https://www.ignacioamatweb.com';
const title = 'Freelance Web Developer Seville 2026 | Ignacio Amat';
const description = 'Professional web design and development for companies in Sevilla and Andalusia. Landing pages, business websites and e-commerce from €800. Free quote.';
const canonicalUrl = '/en/web-developer-sevilla';
const keywords = ['web developer sevilla', 'freelance web developer sevilla', 'website development sevilla', 'business website sevilla', 'landing page sevilla'];

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${baseUrl}${canonicalUrl}#localbusiness`,
  name: 'Ignacio Amat — Freelance Web Developer Seville',
  url: `${baseUrl}${canonicalUrl}`,
  image: `${baseUrl}/images/og-image.png`,
  description: description,
  priceRange: '€€',
  telephone: '+34-000-000-000',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Seville',
    addressRegion: 'Andalusia',
    addressCountry: 'ES',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 37.3891,
    longitude: -5.9845,
  },
  areaServed: [
    { '@type': 'City', name: 'Seville' },
    { '@type': 'AdministrativeArea', name: 'Andalusia' },
    { '@type': 'Country', name: 'Spain' },
  ],
  availableLanguage: ['English', 'Spanish'],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Web development services in Seville',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Landing pages' }, price: '800', priceCurrency: 'EUR' },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Business websites' }, price: '1800', priceCurrency: 'EUR' },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Laravel applications and MVPs' }, price: '3000', priceCurrency: 'EUR' },
    ],
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '5',
    reviewCount: '5',
    bestRating: '5',
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': [
    { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': `${baseUrl}/en/` },
    { '@type': 'ListItem', 'position': 2, 'name': 'Web Developer Sevilla', 'item': `${baseUrl}${canonicalUrl}` }
  ]
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  'mainEntity': [
    {
      '@type': 'Question',
      'name': 'How much does a website cost for a company in Sevilla?',
      'acceptedAnswer': {
        '@type': 'Answer',
        'text': 'Project pricing usually starts at EUR800 for landing pages and scales based on complexity. Business websites often range from EUR1500 to EUR3500, and ecommerce projects from EUR3000.'
      }
    },
    {
      '@type': 'Question',
      'name': 'Do you work remotely with companies in Sevilla?',
      'acceptedAnswer': {
        '@type': 'Answer',
        'text': 'Yes. I collaborate remotely with companies in Sevilla, across Andalusia, and throughout Spain.'
      }
    },
    {
      '@type': 'Question',
      'name': 'What type of websites do you build?',
      'acceptedAnswer': {
        '@type': 'Answer',
        'text': 'I build landing pages, business websites, ecommerce stores, and custom web applications focused on SEO and conversion.'
      }
    }
  ]
};

const allSchemas = [localBusinessSchema, breadcrumbSchema, faqSchema];

const alternateUrls = {
  es: '/desarrollador-web-sevilla',
  en: canonicalUrl
};
---

<Layout
  title={title}
  description={description}
  lang="en"
  canonicalUrl={canonicalUrl}
  keywords={keywords}
  additionalSchemas={allSchemas}
  alternateUrls={alternateUrls}
>
  <Header />
  <main>
    <section class="py-12 sm:py-16 md:py-20 content-page">
      <div class="container px-4 sm:px-6 content-page__container">
        <div class="max-w-4xl mx-auto content-page__inner">
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 sm:mb-6">Create Website in Sevilla for your Business</h1>

          <p class="text-lg sm:text-xl text-text-muted mb-6 sm:mb-8">
            Need a professional website for your Sevilla or Andalusia business that actually generates leads and sales? 
            I build fast, SEO-ready websites and web applications focused on real business outcomes. Free quote in 24h.
          </p>

          <div class="flex flex-wrap gap-3 mb-8">
            <a href="#contacto" class="btn-primary">Request Free Quote</a>
            <a href="/en/hire-full-stack-web-developer" class="btn-secondary">See Full-Stack Service</a>
          </div>

          <div class="prose prose-lg max-w-none content-page__prose mb-8 sm:mb-12">
            <h2 class="text-2xl sm:text-3xl font-bold mt-8 mb-4">Web services for Sevilla and all of Andalusia</h2>
            <p class="text-base sm:text-lg mb-4">
              Whether you run a local company in Sevilla or operate across Andalusia,
              your website should help your business get discovered and contacted by the right clients.
            </p>

            <div class="grid sm:grid-cols-2 gap-4 sm:gap-6 mb-8">
              <div class="bg-secondary p-4 sm:p-6 rounded-lg">
                <h3 class="text-lg sm:text-xl font-bold mb-2">Lead Generation Landing Pages</h3>
                <p class="text-sm sm:text-base">High-converting pages for campaigns and specific services.</p>
              </div>
              <div class="bg-secondary p-4 sm:p-6 rounded-lg">
                <h3 class="text-lg sm:text-xl font-bold mb-2">Business Website Development</h3>
                <p class="text-sm sm:text-base">Credible websites that communicate your offer and rank better.</p>
              </div>
              <div class="bg-secondary p-4 sm:p-6 rounded-lg">
                <h3 class="text-lg sm:text-xl font-bold mb-2">Ecommerce Solutions</h3>
                <p class="text-sm sm:text-base">Online stores with secure checkout and SEO-ready architecture.</p>
              </div>
              <div class="bg-secondary p-4 sm:p-6 rounded-lg">
                <h3 class="text-lg sm:text-xl font-bold mb-2">Custom Web Apps</h3>
                <p class="text-sm sm:text-base">Internal systems and web products aligned with your operations.</p>
              </div>
            </div>

            <h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">Why this works for any city or town in Spain</h2>
            <ul class="list-disc pl-5 sm:pl-6 space-y-2 mb-6 text-sm sm:text-base">
              <li><strong>Nationwide positioning strategy:</strong> service pages and internal links by location intent.</li>
              <li><strong>Technical SEO baseline:</strong> metadata, schema, canonical tags, and hreflang alignment.</li>
              <li><strong>Conversion-focused copy:</strong> clear offer, pricing anchors, and strong CTAs.</li>
              <li><strong>Remote collaboration:</strong> same quality process regardless of your location.</li>
            </ul>

            <h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">Explore related pages</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
              <a href="/en/web-developer-spain" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
                <h3 class="font-bold mb-1">Web Developer Spain -></h3>
                <p class="text-sm text-text-muted">Nationwide service for any city or town in Spain.</p>
              </a>
              <a href="/en/web-developer-madrid" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
                <h3 class="font-bold mb-1">Web Developer Madrid -></h3>
                <p class="text-sm text-text-muted">Service page for Madrid companies.</p>
              </a>
              <a href="/en/web-developer-barcelona" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
                <h3 class="font-bold mb-1">Web Developer Barcelona -></h3>
                <p class="text-sm text-text-muted">Service page for Barcelona companies.</p>
              </a>
              <a href="/en/web-developer-valencia" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
                <h3 class="font-bold mb-1">Web Developer Valencia -></h3>
                <p class="text-sm text-text-muted">Service page for Valencia companies.</p>
              </a>
              <a href="/en/web-design-businesses" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
                <h3 class="font-bold mb-1">Web Design for Businesses -></h3>
                <p class="text-sm text-text-muted">Design and UX focused on business growth.</p>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="container px-4 sm:px-6 pb-8 max-w-4xl mx-auto">
      <SeoCityInternalLinks lang="en" currentPath={canonicalUrl} />
    </div>

    <Contact />
    <StickyCTA />
  </main>
</Layout>

<style>
  .text-text-muted { color: var(--color-text-muted); }
  .bg-secondary { background-color: var(--color-secondary); }
  .prose h2, .prose h3, .prose h4 { color: var(--color-text); }
  .prose p, .prose li { color: var(--color-text); line-height: 1.8; }
</style>
