---
import BlogPostTemplate from '../../../components/BlogPostTemplate.astro';
import {
  getBlogEntryPathSlug,
  getPublishedBlogEntries,
  getRelatedBlogEntries,
  getTranslatedBlogEntry,
  getBlogPostUrl,
} from '../../../data/blog';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getPublishedBlogEntries('en');
  return posts.map((entry) => ({
    params: { slug: getBlogEntryPathSlug(entry) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const translatedEntry = await getTranslatedBlogEntry(entry);
const relatedPosts = await getRelatedBlogEntries(entry);
const pathSlug = getBlogEntryPathSlug(entry);
const alternateUrls = translatedEntry
  ? {
      es: getBlogPostUrl('es', getBlogEntryPathSlug(translatedEntry)),
      en: getBlogPostUrl('en', pathSlug),
    }
  : { en: getBlogPostUrl('en', pathSlug) };
---

<BlogPostTemplate entry={entry} relatedPosts={relatedPosts} alternateUrls={alternateUrls} />
