---
import BlogPostTemplate from '../../../components/BlogPostTemplate.astro';
import { getPublishedBlogEntries, getRelatedBlogEntries, getTranslatedBlogEntry, getBlogPostUrl } from '../../../data/blog';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getPublishedBlogEntries('en');
  return posts.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const translatedEntry = await getTranslatedBlogEntry(entry);
const relatedPosts = await getRelatedBlogEntries(entry);
const alternateUrls = {
  es: translatedEntry ? getBlogPostUrl('es', translatedEntry.slug) : '/blog',
  en: getBlogPostUrl('en', entry.slug),
};
---

<BlogPostTemplate entry={entry} relatedPosts={relatedPosts} alternateUrls={alternateUrls} />
