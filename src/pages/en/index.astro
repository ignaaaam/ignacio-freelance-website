---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import TrustBar from '../../components/TrustBar.astro';
import Projects from '../../components/Projects.astro';
import Features from '../../components/Features.astro';
import CaseStudies from '../../components/CaseStudies.astro';
import Process from '../../components/Process.astro';
import Pricing from '../../components/Pricing.astro';
import Testimonials from '../../components/Testimonials.astro';
import FAQ from '../../components/FAQ.astro';
import Contact from '../../components/Contact.astro';
import StickyCTA from '../../components/StickyGTA.astro';
import { siteContent } from '../../data/siteContent';

const locale = 'en';
const page = siteContent[locale];
const baseUrl = 'https://www.ignacioamatweb.com';
const canonicalUrl = '/en/';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Landing pages, business websites, redesigns, Laravel and MVP development',
  provider: { '@id': `${baseUrl}#professional-service` },
  areaServed: 'Barcelona, Spain and international clients',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: page.faq.items.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<Layout
  title={page.meta.title}
  description={page.meta.description}
  lang="en"
  canonicalUrl={canonicalUrl}
  additionalSchemas={[serviceSchema, faqSchema]}
>
  <Header surface="dark" />
  <main>
    <Hero />
    <section class="container px-4 sm:px-6 py-6 max-w-4xl mx-auto" aria-label="Featured blog post">
      <p class="text-sm sm:text-base text-[var(--color-text-muted)]">
        <a
          href="/en/blog/how-much-does-it-cost-to-build-website-barcelona-2026"
          class="text-[var(--color-accent)] font-medium hover:underline"
        >
          New on the blog: real website pricing in Barcelona (2026) ->
        </a>
      </p>
    </section>
    <TrustBar />
    <Features />
    <Projects />
    <CaseStudies />
    <Process />
    <Pricing />
    <Testimonials />
    <FAQ />
    <Contact />
  </main>
  <StickyCTA />
</Layout>
