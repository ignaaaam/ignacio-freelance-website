---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Contact from '../../components/Contact.astro';
import StickyCTA from '../../components/StickyGTA.astro';
import SeoCityInternalLinks from '../../components/SeoCityInternalLinks.astro';

const baseUrl = 'https://www.ignacioamatweb.com';
const title = 'Freelance Web Developer Spain 2026 | Ignacio Amat';
const description = 'Freelance web developer for companies anywhere in Spain. Landing pages, business websites, ecommerce and apps from €800. Remote. Free quote in 24h.';
const canonicalUrl = '/en/web-developer-spain';
const keywords = [
  'web developer spain',
  'freelance web developer spain',
  'website development spain',
  'business web design spain',
  'hire web developer spain'
];

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${baseUrl}${canonicalUrl}#localbusiness`,
  name: 'Ignacio Amat — Freelance Web Developer Spain',
  url: `${baseUrl}${canonicalUrl}`,
  image: `${baseUrl}/images/og-image.png`,
  description: description,
  priceRange: '€€',
  telephone: '+34-000-000-000',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Barcelona',
    addressRegion: 'Catalonia',
    addressCountry: 'ES',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 41.3874,
    longitude: 2.1686,
  },
  areaServed: [
    { '@type': 'Country', name: 'Spain' },
    { '@type': 'City', name: 'Barcelona' },
    { '@type': 'City', name: 'Madrid' },
    { '@type': 'City', name: 'Valencia' },
  ],
  availableLanguage: ['English', 'Spanish'],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Web development services in Spain',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Landing pages' }, price: '800', priceCurrency: 'EUR' },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Business websites' }, price: '1800', priceCurrency: 'EUR' },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Laravel applications and MVPs' }, price: '3000', priceCurrency: 'EUR' },
    ],
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '5',
    reviewCount: '5',
    bestRating: '5',
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': [
    { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': `${baseUrl}/en/` },
    { '@type': 'ListItem', 'position': 2, 'name': 'Web Developer Spain', 'item': `${baseUrl}${canonicalUrl}` }
  ]
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  'mainEntity': [
    {
      '@type': 'Question',
      'name': 'Do you only work with large cities?',
      'acceptedAnswer': {
        '@type': 'Answer',
        'text': 'No. I work with companies in any city or town in Spain through a fully remote process.'
      }
    },
    {
      '@type': 'Question',
      'name': 'What services do you offer nationwide?',
      'acceptedAnswer': {
        '@type': 'Answer',
        'text': 'I build landing pages, business websites, ecommerce stores, and custom web applications with SEO and performance best practices.'
      }
    },
    {
      '@type': 'Question',
      'name': 'How much does a website project usually cost?',
      'acceptedAnswer': {
        '@type': 'Answer',
        'text': 'Projects usually start at EUR800 for landing pages. Business websites often range between EUR1500 and EUR3500 depending on scope.'
      }
    }
  ]
};

const allSchemas = [localBusinessSchema, breadcrumbSchema, faqSchema];

const alternateUrls = {
  es: '/desarrollador-web-espana',
  en: canonicalUrl
};
---

<Layout
  title={title}
  description={description}
  lang="en"
  canonicalUrl={canonicalUrl}
  keywords={keywords}
  additionalSchemas={allSchemas}
  alternateUrls={alternateUrls}
>
  <Header />
  <main>
    <section class="py-12 sm:py-16 md:py-20 content-page">
      <div class="container px-4 sm:px-6 content-page__container">
        <div class="max-w-4xl mx-auto content-page__inner">
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 sm:mb-6">
            Freelance Web Developer for Companies Across Spain
          </h1>

          <p class="text-lg sm:text-xl text-text-muted mb-6 sm:mb-8">
            If your business is in a major city or a small town, you can still get high-quality web development
            focused on SEO, speed, and conversion. I work remotely with companies across all of Spain.
          </p>

          <div class="flex flex-wrap gap-3 mb-8">
            <a href="#contacto" class="btn-primary">Request Free Quote</a>
            <a href="/en/hire-full-stack-web-developer" class="btn-secondary">See Full-Stack Service</a>
          </div>

          <div class="prose prose-lg max-w-none content-page__prose mb-8 sm:mb-12">
            <h2 class="text-2xl sm:text-3xl font-bold mt-8 mb-4">Nationwide service for any city or town</h2>
            <p class="text-base sm:text-lg mb-4">
              You do not need a local agency to get results. With a clear remote workflow, your company can launch
              a website that attracts qualified traffic and generates more inbound opportunities.
            </p>

            <h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">What I can build for your company</h2>
            <div class="grid sm:grid-cols-2 gap-4 sm:gap-6 mb-8">
              <div class="bg-secondary p-4 sm:p-6 rounded-lg">
                <h3 class="text-lg sm:text-xl font-bold mb-2">Landing Pages</h3>
                <p class="text-sm sm:text-base">Lead-focused pages for campaigns, launches, and service offers.</p>
              </div>
              <div class="bg-secondary p-4 sm:p-6 rounded-lg">
                <h3 class="text-lg sm:text-xl font-bold mb-2">Business Websites</h3>
                <p class="text-sm sm:text-base">Professional websites with clear structure and technical SEO.</p>
              </div>
              <div class="bg-secondary p-4 sm:p-6 rounded-lg">
                <h3 class="text-lg sm:text-xl font-bold mb-2">Ecommerce Stores</h3>
                <p class="text-sm sm:text-base">Online stores with secure payments and scalable architecture.</p>
              </div>
              <div class="bg-secondary p-4 sm:p-6 rounded-lg">
                <h3 class="text-lg sm:text-xl font-bold mb-2">Custom Web Apps</h3>
                <p class="text-sm sm:text-base">Internal systems, portals, and tailored SaaS workflows.</p>
              </div>
            </div>

            <h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">City pages and local intent coverage</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
              <a href="/en/web-developer-madrid" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
                <h3 class="font-bold mb-1">Web Developer Madrid -></h3>
                <p class="text-sm text-text-muted">Service page for Madrid and surrounding areas.</p>
              </a>
              <a href="/en/web-developer-barcelona" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
                <h3 class="font-bold mb-1">Web Developer Barcelona -></h3>
                <p class="text-sm text-text-muted">Service page for Barcelona companies.</p>
              </a>
              <a href="/en/web-developer-valencia" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
                <h3 class="font-bold mb-1">Web Developer Valencia -></h3>
                <p class="text-sm text-text-muted">Service page for Valencia and nearby markets.</p>
              </a>
              <a href="/en/web-developer-sevilla" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
                <h3 class="font-bold mb-1">Web Developer Sevilla -></h3>
                <p class="text-sm text-text-muted">Service page for Sevilla and Andalusia.</p>
              </a>
            </div>

            <div class="bg-accent/10 p-4 sm:p-6 rounded-lg mt-8 mb-4">
              <h2 class="text-xl sm:text-2xl font-bold mb-3">Need stronger visibility and inbound leads?</h2>
              <p class="mb-3 text-sm sm:text-base">
                I can help you launch a website that supports SEO growth and drives more qualified business inquiries.
              </p>
              <p class="font-semibold text-sm sm:text-base">
                Free quote in 24 business hours<br/>
                No commitment<br/>
                Official invoicing
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="container px-4 sm:px-6 pb-8 max-w-4xl mx-auto">
      <SeoCityInternalLinks lang="en" currentPath={canonicalUrl} />
    </div>

    <Contact />
    <StickyCTA />
  </main>
</Layout>

<style>
  .text-text-muted { color: var(--color-text-muted); }
  .bg-secondary { background-color: var(--color-secondary); }
  .prose h2, .prose h3, .prose h4 { color: var(--color-text); }
  .prose p, .prose li { color: var(--color-text); line-height: 1.8; }
</style>
