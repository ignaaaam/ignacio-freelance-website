---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Contact from '../../components/Contact.astro';
import StickyCTA from '../../components/StickyGTA.astro';
import SeoCityInternalLinks from '../../components/SeoCityInternalLinks.astro';

const baseUrl = 'https://www.ignacioamatweb.com';
const title = 'Freelance Web Developer Murcia 2026 | Ignacio Amat';
const description = 'Freelance web developer in the Region of Murcia. Business websites, landings and multilingual ecommerce from €800. Murcia, Cartagena, Lorca. Free quote.';
const canonicalUrl = '/en/web-developer-murcia';
const keywords = ['web developer murcia', 'freelance web developer murcia', 'website development murcia', 'business website murcia', 'landing page murcia', 'web design murcia', 'web developer cartagena', 'web developer lorca'];

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${baseUrl}${canonicalUrl}#localbusiness`,
  name: 'Ignacio Amat — Freelance Web Developer Murcia',
  url: `${baseUrl}${canonicalUrl}`,
  image: `${baseUrl}/images/og-image.png`,
  description: description,
  priceRange: '€€',
  telephone: '+34-000-000-000',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Murcia',
    addressRegion: 'Region of Murcia',
    addressCountry: 'ES',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 37.9922,
    longitude: -1.1307,
  },
  areaServed: [
    { '@type': 'City', name: 'Murcia' },
    { '@type': 'AdministrativeArea', name: 'Region of Murcia' },
    { '@type': 'Country', name: 'Spain' },
  ],
  availableLanguage: ['English', 'Spanish'],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Web development services in Murcia',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Landing pages' }, price: '800', priceCurrency: 'EUR' },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Business websites' }, price: '1800', priceCurrency: 'EUR' },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Laravel applications and MVPs' }, price: '3000', priceCurrency: 'EUR' },
    ],
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '5',
    reviewCount: '5',
    bestRating: '5',
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': [
    { '@type': 'ListItem', 'position': 1, 'name': 'Home', 'item': `${baseUrl}/en/` },
    { '@type': 'ListItem', 'position': 2, 'name': 'Web Developer Murcia', 'item': `${baseUrl}${canonicalUrl}` }
  ]
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  'mainEntity': [
    {
      '@type': 'Question',
      'name': 'How much does a freelance web developer cost in Murcia?',
      'acceptedAnswer': {
        '@type': 'Answer',
        'text': 'Most projects range from EUR800 to EUR6000+ depending on scope. Landing pages start around EUR800, business websites between EUR1500 and EUR3500, and ecommerce projects from EUR3000.'
      }
    },
    {
      '@type': 'Question',
      'name': 'Do you build websites for Murcia export companies?',
      'acceptedAnswer': {
        '@type': 'Answer',
        'text': 'Yes. The Region of Murcia is one of Spain\'s biggest exporters of fruit, vegetables, and canned goods. I build multilingual websites (Spanish, English, French, German) with proper hreflang implementation and international SEO so Murcia exporters can rank in Germany, France, Netherlands, and the UK.'
      }
    },
    {
      '@type': 'Question',
      'name': 'Do you cover Cartagena and Lorca as well?',
      'acceptedAnswer': {
        '@type': 'Answer',
        'text': 'Yes. I work 100% remotely with companies from the entire Region of Murcia: Murcia city, Cartagena, Lorca, Molina de Segura, Aguilas, San Javier, the Mar Menor area, and every municipality in the region.'
      }
    },
    {
      '@type': 'Question',
      'name': 'Do we need to be based in Murcia to work together?',
      'acceptedAnswer': {
        '@type': 'Answer',
        'text': 'No. I work 100% remotely with companies in Murcia and across Spain through video calls, email, and project tools.'
      }
    },
    {
      '@type': 'Question',
      'name': 'How long does a web project usually take?',
      'acceptedAnswer': {
        '@type': 'Answer',
        'text': 'Landing pages are usually delivered in 2-5 days, business websites in 2-4 weeks, and ecommerce websites in 4-8 weeks.'
      }
    }
  ]
};

const allSchemas = [localBusinessSchema, breadcrumbSchema, faqSchema];

const alternateUrls = {
  es: '/desarrollador-web-murcia',
  en: canonicalUrl
};
---

<Layout
  title={title}
  description={description}
  lang="en"
  canonicalUrl={canonicalUrl}
  keywords={keywords}
  additionalSchemas={allSchemas}
  alternateUrls={alternateUrls}
>
  <Header />
  <main>
    <section class="py-12 sm:py-16 md:py-20 content-page">
      <div class="container px-4 sm:px-6 content-page__container">
        <div class="max-w-4xl mx-auto content-page__inner">
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 sm:mb-6">Freelance Web Developer for Companies in Murcia</h1>

          <p class="text-lg sm:text-xl text-text-muted mb-6 sm:mb-8">
            Need a website that helps your Murcia or Cartagena business generate leads, export-ready inquiries, and sales?
            I build fast, multilingual, SEO-ready websites and web applications focused on real business outcomes across the Region of Murcia.
          </p>

          <div class="flex flex-wrap gap-3 mb-8">
            <a href="#contacto" class="btn-primary">Request Free Quote</a>
            <a href="/en/hire-full-stack-web-developer" class="btn-secondary">Hire Full-Stack Developer</a>
          </div>

          <div class="prose prose-lg max-w-none content-page__prose mb-8 sm:mb-12">
            <h2 class="text-2xl sm:text-3xl font-bold mt-8 mb-4">Web development services for Murcia companies</h2>
            <p class="text-base sm:text-lg mb-4">
              The Region of Murcia is often called the "orchard of Europe" and is one of Spain's most dynamic export economies.
              From agri-food cooperatives to dental clinics, law firms, Mar Menor hotels, and Cartagena logistics operators,
              Murcia businesses need websites that load fast, communicate trust, rank internationally, and convert visitors into qualified leads.
              That is exactly how I build.
            </p>
            <p class="text-base sm:text-lg mb-4">
              I work 100% remotely with companies across Murcia city (Centro, El Carmen, Vistalegre, La Flota, Santo Angel, La Alberca, Cabezo de Torres)
              and the wider region: Cartagena, Lorca, Molina de Segura, Alcantarilla, Aguilas, San Javier, and the Mar Menor / Costa Calida coast.
            </p>

            <div class="grid sm:grid-cols-2 gap-4 sm:gap-6 mb-8">
              <div class="bg-secondary p-4 sm:p-6 rounded-lg">
                <h3 class="text-lg sm:text-xl font-bold mb-2">High-converting Landing Pages</h3>
                <p class="text-sm sm:text-base">Designed for paid campaigns and lead generation from EUR800. Ideal for dental clinics, hotels, and agri-food launches.</p>
              </div>
              <div class="bg-secondary p-4 sm:p-6 rounded-lg">
                <h3 class="text-lg sm:text-xl font-bold mb-2">Business Websites</h3>
                <p class="text-sm sm:text-base">Professional multi-page sites with strong SEO foundations from EUR1500. Great for law firms, cooperatives, and exporters.</p>
              </div>
              <div class="bg-secondary p-4 sm:p-6 rounded-lg">
                <h3 class="text-lg sm:text-xl font-bold mb-2">Ecommerce Development</h3>
                <p class="text-sm sm:text-base">Online stores with Stripe, Redsys, or Bizum integrations from EUR3000. Perfect for canned food, Jumilla wines, and gourmet brands.</p>
              </div>
              <div class="bg-secondary p-4 sm:p-6 rounded-lg">
                <h3 class="text-lg sm:text-xl font-bold mb-2">Custom Web Applications</h3>
                <p class="text-sm sm:text-base">CRMs, client portals, cooperative intranets, and logistics platforms connected to the Port of Cartagena.</p>
              </div>
            </div>

            <h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">Key sectors I work with in the Region of Murcia</h2>
            <ul class="list-disc pl-5 sm:pl-6 space-y-2 mb-6 text-sm sm:text-base">
              <li><strong>Agri-food and the Murcia orchard:</strong> cooperatives, fruit and vegetable exporters, organic farms.</li>
              <li><strong>Canned food and processed food:</strong> traditional Murcia industry with strong European demand.</li>
              <li><strong>Fruit and vegetable exports:</strong> PYMES shipping to Germany, France, Netherlands, and the UK.</li>
              <li><strong>Mar Menor and Costa Calida tourism:</strong> hotels, resorts, and tourism rental websites.</li>
              <li><strong>Hospitality and restaurants:</strong> from Murcia city tapas bars to Cartagena seafood venues.</li>
              <li><strong>Dental clinics:</strong> a strong sector in Murcia with growing international patient flows.</li>
              <li><strong>Law firms and professional services:</strong> bilingual websites that convert.</li>
              <li><strong>Exporting SMEs and logistics:</strong> companies around the Port of Cartagena.</li>
            </ul>

            <h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">Multilingual websites for Murcia's export economy</h2>
            <p class="text-base sm:text-lg mb-4">
              The Region of Murcia exports billions of euros in fresh produce, canned goods, and processed food every year.
              Big cooperatives, family-owned PYMES, and farmers work with buyers from Germany, France, the Netherlands, the UK, and the Nordics.
              A Spanish-only website is not enough for that audience.
            </p>
            <p class="text-base sm:text-lg mb-4">
              I build multilingual websites in Spanish, English, French, and German with correct hreflang implementation, localized URLs,
              international sitemaps, and market-specific schema. The goal: your Murcia business shows up in German search results when a buyer
              looks for "spanische Zitronen", or in French results when they search "brocolis Espagne".
            </p>
            <p class="text-base sm:text-lg mb-4">
              The same international SEO approach helps Murcia dental clinics attract British and French medical tourism, and Mar Menor hotels
              reach Central European travelers directly through Google instead of expensive OTAs.
            </p>

            <h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">Why choose a freelance developer for Murcia?</h2>
            <ul class="list-disc pl-5 sm:pl-6 space-y-2 mb-6 text-sm sm:text-base">
              <li><strong>Direct communication:</strong> You speak with the person building your project.</li>
              <li><strong>Lower cost:</strong> Usually 30-50% lower than agencies for similar scope.</li>
              <li><strong>Modern stack:</strong> Astro, React, Next.js, Node.js, and technical SEO.</li>
              <li><strong>Multilingual ready:</strong> ES/EN/FR/DE setups for export-driven Murcia businesses.</li>
              <li><strong>Remote delivery:</strong> Efficient process without geography constraints, covering all of the Region of Murcia.</li>
            </ul>

            <h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">Pricing for a website in Murcia</h2>
            <div class="space-y-4 mb-8">
              <div class="bg-secondary p-4 sm:p-6 rounded-lg">
                <h3 class="font-bold text-base sm:text-lg mb-2">Landing Page</h3>
                <p class="text-sm sm:text-base text-text-muted">From <strong>EUR800 to EUR1500</strong>. Ready in 2-5 days.</p>
              </div>
              <div class="bg-secondary p-4 sm:p-6 rounded-lg">
                <h3 class="font-bold text-base sm:text-lg mb-2">Business Website</h3>
                <p class="text-sm sm:text-base text-text-muted">Between <strong>EUR1500 and EUR3500</strong>. Delivered in 2-4 weeks, optionally multilingual.</p>
              </div>
              <div class="bg-secondary p-4 sm:p-6 rounded-lg">
                <h3 class="font-bold text-base sm:text-lg mb-2">Online Store</h3>
                <p class="text-sm sm:text-base text-text-muted">Between <strong>EUR3000 and EUR6000+</strong>. Full catalog, payment gateway, and international shipping. 4-8 weeks.</p>
              </div>
            </div>

            <h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">Related services in Spain</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
              <a href="/en/web-developer-spain" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
                <h3 class="font-bold mb-1">Web Developer Spain -></h3>
                <p class="text-sm text-text-muted">Nationwide service for any city or town in Spain.</p>
              </a>
              <a href="/en/web-developer-barcelona" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
                <h3 class="font-bold mb-1">Web Developer Barcelona -></h3>
                <p class="text-sm text-text-muted">Service page for Barcelona companies.</p>
              </a>
              <a href="/en/web-developer-madrid" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
                <h3 class="font-bold mb-1">Web Developer Madrid -></h3>
                <p class="text-sm text-text-muted">Service page for Madrid companies.</p>
              </a>
              <a href="/en/hire-full-stack-web-developer" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
                <h3 class="font-bold mb-1">Hire Full-Stack Developer -></h3>
                <p class="text-sm text-text-muted">For complex projects and custom web applications.</p>
              </a>
              <a href="/en/web-design-businesses" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
                <h3 class="font-bold mb-1">Web Design for Businesses -></h3>
                <p class="text-sm text-text-muted">Conversion-focused design and UX for business sites.</p>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="container px-4 sm:px-6 pb-8 max-w-4xl mx-auto">
      <SeoCityInternalLinks lang="en" currentPath={canonicalUrl} />
    </div>

    <Contact />
    <StickyCTA />
  </main>
</Layout>

<style>
  .text-text-muted { color: var(--color-text-muted); }
  .bg-secondary { background-color: var(--color-secondary); }
  .prose h2, .prose h3, .prose h4 { color: var(--color-text); }
  .prose p, .prose li { color: var(--color-text); line-height: 1.8; }
</style>
