---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Features from '../../components/Features.astro';
import Projects from '../../components/Projects.astro';
import Pricing from '../../components/Pricing.astro';
import Contact from '../../components/Contact.astro';
import StickyCTA from '../../components/StickyGTA.astro';
import { siteContent } from '../../data/siteContent';

const page = siteContent.en;
const canonicalUrl = '/en/services';
---

<Layout
  title="Freelance web development services | Ignacio Amat"
  description="Service hub for landing pages, business websites, Laravel, redesigns, maintenance and MVP development."
  lang="en"
  canonicalUrl={canonicalUrl}
  alternateUrls={{ es: '/servicios', en: canonicalUrl }}
>
  <Header />
  <main>
    <section class="section">
      <div class="container">
        <div class="section-heading">
          <p class="section-eyebrow">{page.servicesPage.eyebrow}</p>
          <h1>{page.servicesPage.title}</h1>
          <p class="section-copy">{page.servicesPage.description}</p>
        </div>
        <div class="service-page__actions">
          <a href="#contacto" class="btn-primary" data-cta="services-primary">{page.servicesPage.ctaPrimary}</a>
          <a href="#proyectos" class="btn-secondary" data-cta="services-secondary">{page.servicesPage.ctaSecondary}</a>
        </div>
        <div class="service-page__links">
          <a href="/en/web-developer-barcelona">Web developer Barcelona</a>
          <a href="/en/how-much-does-website-cost">Pricing guide</a>
          <a href="/en/frequently-asked-questions">Frequently asked questions</a>
        </div>
      </div>
    </section>
    <Features />
    <Projects />
    <Pricing />
    <Contact />
  </main>
  <StickyCTA />
</Layout>

<style>
  .service-page__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.4rem;
  }

  .service-page__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1rem;
  }

  .service-page__links a {
    color: var(--color-text-muted);
    font-weight: 700;
  }

  .service-page__links a:hover {
    color: var(--theme-highlight);
  }

  @media (max-width: 720px) {
    .service-page__actions {
      flex-direction: column;
    }
  }
</style>
