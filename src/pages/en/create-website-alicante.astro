---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Contact from '../../components/Contact.astro';
import StickyCTA from '../../components/StickyGTA.astro';

const baseUrl = 'https://www.ignacioamatweb.com';
const title = 'Create Website Alicante 2026 | Ignacio Amat';
const description =
  'Web design and development in Alicante and the Costa Blanca. Bilingual ES/EN sites for international clients. Landings and ecommerce from €800.';
const canonicalUrl = '/en/create-website-alicante';
const keywords = [
  'create website Alicante',
  'Costa Blanca web design',
  'Alicante web developer',
  'bilingual website Alicante',
  'freelance web Alicante',
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Create Website for Businesses in Alicante',
  provider: {
    '@type': 'LocalBusiness',
    name: 'Ignacio Amat',
    url: baseUrl,
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Alicante',
      addressRegion: 'Valencian Community',
      addressCountry: 'ES',
    },
    geo: {
      '@type': 'GeoCoordinates',
      latitude: 38.3452,
      longitude: -0.481,
    },
  },
  areaServed: { '@type': 'City', name: 'Alicante' },
  description:
    'Websites for Alicante and Costa Blanca businesses targeting local and international customers—including real estate and services.',
  offers: {
    '@type': 'Offer',
    priceRange: '€800 - €6,000+',
    description: 'Landing pages through multilingual corporate sites',
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${baseUrl}/en/` },
    { '@type': 'ListItem', position: 2, name: 'Create Website Alicante', item: `${baseUrl}${canonicalUrl}` },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How much does a website cost in Alicante?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Landing pages from €800, corporate sites typically €1,500–€3,500, ecommerce from €3,000. Bilingual setups add scope depending on content volume and URL strategy.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do you build bilingual Spanish/English websites?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes—common for Costa Blanca real estate, hospitality and services targeting UK and EU buyers.',
      },
    },
    {
      '@type': 'Question',
      name: 'How fast can you launch a landing page?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'With content ready, many landing pages ship within days to a couple of weeks depending on design approvals and integrations.',
      },
    },
  ],
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Ignacio Amat — Create Website Alicante',
  url: `${baseUrl}${canonicalUrl}`,
  image: `${baseUrl}/images/og-image.png`,
  priceRange: '€€',
  currenciesAccepted: 'EUR',
  serviceArea: { '@type': 'City', name: 'Alicante' },
  areaServed: { '@type': 'City', name: 'Alicante' },
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Alicante',
    addressRegion: 'Valencian Community',
    addressCountry: 'ES',
  },
  availableLanguage: ['English', 'Spanish'],
  sameAs: [
    'https://www.linkedin.com/in/ignacio-amat-urbina-789244223/',
    'https://github.com/ignaaaam',
  ],
};

const allSchemas = [serviceSchema, breadcrumbSchema, faqSchema, localBusinessSchema];

const alternateUrls = {
  es: '/crear-pagina-web-alicante',
  en: canonicalUrl,
};
---

<Layout
  title={title}
  description={description}
  lang="en"
  canonicalUrl={canonicalUrl}
  keywords={keywords}
  additionalSchemas={allSchemas}
  alternateUrls={alternateUrls}
>
  <Header />
  <main>
    <section class="py-12 sm:py-16 md:py-20 content-page">
      <div class="container px-4 sm:px-6 content-page__container">
        <div class="max-w-4xl mx-auto content-page__inner">
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 sm:mb-6">Create a Website for Your Business in Alicante</h1>

          <p class="text-lg sm:text-xl text-text-muted mb-6 sm:mb-8">
            Alicante’s market is international. I build fast, bilingual, SEO-ready sites that help you win both local and
            foreign demand—especially in real estate, services and hospitality.
          </p>

          <div class="prose prose-lg max-w-none content-page__prose mb-8 sm:mb-12">
            <h2 class="text-2xl sm:text-3xl font-bold mt-8 sm:mt-12 mb-4 sm:mb-6">What I focus on</h2>
            <ul class="list-disc pl-5 sm:pl-6 space-y-2 mb-6 text-sm sm:text-base">
              <li>Performance and Core Web Vitals</li>
              <li>Clean information architecture for multi-language sites</li>
              <li>Conversion-oriented landing pages for ads</li>
            </ul>

            <div class="bg-secondary p-4 sm:p-6 rounded-lg mt-6 sm:mt-8 mb-6 sm:mb-8">
              <h3 class="text-xl sm:text-2xl font-bold mb-3 sm:mb-4">Request a quote</h3>
              <p class="text-sm sm:text-base mb-0">Tell me your market (local/international) and must-have pages.</p>
            </div>

            <h3 class="text-xl sm:text-2xl font-bold mt-6 sm:mt-8 mb-3 sm:mb-4">Related pages</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
              <a href="/en/web-developer-alicante" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
                <h4 class="font-bold mb-2">Web Developer Alicante →</h4>
                <p class="text-sm text-text-muted">Freelance development on the Costa Blanca.</p>
              </a>
              <a href="/en/create-website-valencia" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
                <h4 class="font-bold mb-2">Create Website Valencia →</h4>
                <p class="text-sm text-text-muted">Broader Valencian Community coverage.</p>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Contact />
    <StickyCTA />
  </main>
</Layout>

<style>
  .text-text-muted {
    color: var(--color-text-muted);
  }
  .bg-secondary {
    background-color: var(--color-secondary);
  }
  .prose h2,
  .prose h3 {
    color: var(--color-text);
  }
  .prose p,
  .prose li {
    color: var(--color-text);
    line-height: 1.8;
  }
</style>
