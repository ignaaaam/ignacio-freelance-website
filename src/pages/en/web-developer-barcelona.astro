---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Contact from '../../components/Contact.astro';
import StickyCTA from '../../components/StickyGTA.astro';

const baseUrl = 'https://www.ignacioamatweb.com';
const title = "Web developer in Barcelona for business websites and landing pages | Ignacio Amat";
const description = "Freelance web developer for Barcelona-based companies. Landing pages, business websites, redesigns, Laravel and technical improvements focused on clarity, conversion and performance.";
const canonicalUrl = "/en/web-developer-barcelona";
const keywords = ["web developer Barcelona", "freelance web Barcelona", "landing page Barcelona", "business website Barcelona", "website redesign Barcelona", "create website Barcelona"];

const serviceSchema = {
	"@context": "https://schema.org",
	"@type": "ProfessionalService",
	"name": "Ignacio Amat - Web development for companies in Barcelona",
	"url": `${baseUrl}${canonicalUrl}`,
	"description": description,
	"provider": {
		"@type": "Person",
		"name": "Ignacio Amat",
		"url": baseUrl
	},
	"areaServed": {
		"@type": "City",
		"name": "Barcelona"
	},
	"availableLanguage": ["English", "Spanish"]
};

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{
			"@type": "ListItem",
			"position": 1,
			"name": "Home",
			"item": `${baseUrl}/en`
		},
		{
			"@type": "ListItem",
			"position": 2,
			"name": "Web Developer Barcelona",
			"item": `${baseUrl}${canonicalUrl}`
		}
	]
};

const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": [
		{
			"@type": "Question",
			"name": "How much does a landing page or business website usually cost?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "A focused landing page usually starts from EUR 800. A business website often sits between EUR 1,800 and 4,000. If the project needs integrations or business logic, the quote depends on scope rather than a fixed package."
			}
		},
		{
			"@type": "Question",
			"name": "How long does a project usually take?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "A well-defined landing page can move in a matter of days. A business website often takes 2 to 6 weeks. If the work involves a redesign, integrations or a product phase, the sensible approach is to break it into stages."
			}
		},
		{
			"@type": "Question",
			"name": "Do you only work with companies in Barcelona?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "No. I work remotely with Barcelona-based companies as well as teams in other cities and countries. Barcelona is simply one of the places where this type of service is in high demand."
			}
		},
		{
			"@type": "Question",
			"name": "What kind of projects are the best fit?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Landing pages, business websites, conversion-focused redesigns, Laravel work and early product or MVP phases are usually the strongest fit."
			}
		}
	]
};

const allSchemas = [serviceSchema, breadcrumbSchema, faqSchema];

// Manual alternate URLs for service pages
const alternateUrls = {
	es: "/desarrollador-web-barcelona",
	en: canonicalUrl
};
---
<Layout 
	title={title} 
	description={description} 
	lang="en"
	canonicalUrl={canonicalUrl}
	keywords={keywords}
	additionalSchemas={allSchemas}
	alternateUrls={alternateUrls}
>
	<Header />
	<main>
		<section class="py-12 sm:py-16 md:py-20 content-page">
			<div class="container px-4 sm:px-6 content-page__container">
				<div class="max-w-4xl mx-auto content-page__inner">
					<h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 sm:mb-6">Freelance Web Developer in Barcelona</h1>
					
					<p class="text-lg sm:text-xl text-text-muted mb-6 sm:mb-8">
						I work with Barcelona-based companies that need a clearer business website, a landing page
						for lead generation or improvements to a website that is no longer doing a good job of
						explaining the offer.
					</p>

					<div class="prose prose-lg max-w-none content-page__prose mb-8 sm:mb-12">
						<h2 class="text-2xl sm:text-3xl font-bold mt-8 sm:mt-12 mb-4 sm:mb-6">When this page is useful</h2>
						
						<p class="text-base sm:text-lg mb-4">
							Not every business needs the same thing. Sometimes the right move is a focused landing page.
							In other cases the priority is a more credible business website, a redesign that clarifies the message
							or technical improvements that stop getting in the way of contact.
						</p>
						<p class="text-base sm:text-lg mb-6">
							If your company is in Barcelona and you want a direct collaborator with commercial judgement
							and a solid technical base, this kind of setup is usually a good fit.
						</p>

						<h2 class="text-2xl sm:text-3xl font-bold mt-8 sm:mt-12 mb-4 sm:mb-6">Services that usually fit best</h2>
						<div class="grid sm:grid-cols-2 gap-4 sm:gap-6 mb-6 sm:mb-8">
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3">Landing pages</h3>
								<p class="text-sm sm:text-base">For campaigns, lead capture or focused offers where one primary action matters most.</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3">Business websites</h3>
								<p class="text-sm sm:text-base">For companies that need to explain services better, build trust faster and improve first impressions.</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3">Redesigns and improvements</h3>
								<p class="text-sm sm:text-base">When the current site exists already but feels outdated, weak or poor at generating contact.</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3">Laravel and custom work</h3>
								<p class="text-sm sm:text-base">For dashboards, internal workflows, integrations or product work with real business rules.</p>
							</div>
						</div>

						<h2 class="text-2xl sm:text-3xl font-bold mt-8 sm:mt-12 mb-4 sm:mb-6">Problems that often show up before hiring</h2>
						<ul class="list-disc pl-5 sm:pl-6 space-y-2 sm:space-y-3 mb-4 sm:mb-6 text-sm sm:text-base">
							<li><strong>The offer is not clear quickly enough:</strong> visitors arrive but do not understand what the company actually sells.</li>
							<li><strong>The site feels weaker than the real service quality:</strong> first impressions do not match the business.</li>
							<li><strong>Contact friction is too high:</strong> the structure, CTA or form flow do not guide people toward action.</li>
							<li><strong>The technical base is too weak:</strong> performance, technical SEO, structure or maintainability start holding the site back.</li>
						</ul>

						<h2 class="text-2xl sm:text-3xl font-bold mt-8 sm:mt-12 mb-4 sm:mb-6">Why work with a freelancer and avoid extra layers</h2>
						<ul class="list-disc pl-5 sm:pl-6 space-y-2 sm:space-y-3 mb-4 sm:mb-6 text-sm sm:text-base">
							<li><strong>Direct contact:</strong> you talk to the same person who scopes and builds the project.</li>
							<li><strong>Clearer scope:</strong> it becomes easier to see what makes sense now and what should wait.</li>
							<li><strong>Commercial fit:</strong> the site is treated as a business tool, not just as a visual exercise.</li>
							<li><strong>Remote collaboration without heavy process:</strong> I can work with Barcelona-based teams without unnecessary overhead.</li>
						</ul>

						<h2 class="text-2xl sm:text-3xl font-bold mt-8 sm:mt-12 mb-4 sm:mb-6">Indicative pricing and timing</h2>
						<p class="mb-4 text-sm sm:text-base">
							A focused landing page usually starts from EUR 800. A business website often falls between
							EUR 1,800 and 4,000. If the project needs integrations, dashboards or business logic,
							the quote is normally phased around scope.
						</p>
						<p class="mb-6 text-sm sm:text-base">
							In terms of timing, a well-defined landing page can move in a matter of days. A business
							website often takes 2 to 6 weeks. If the priority is an MVP or a substantial improvement,
							the sensible approach is normally to work in stages.
						</p>
						<div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-6">
							<a href="/en/web-developer-spain" class="block p-3 bg-secondary rounded-lg text-sm font-medium text-center hover:shadow-md transition-all">Web Developer Spain -></a>
							<a href="/en/web-developer-madrid" class="block p-3 bg-secondary rounded-lg text-sm font-medium text-center hover:shadow-md transition-all">Web Developer Madrid -></a>
							<a href="/en/web-developer-valencia" class="block p-3 bg-secondary rounded-lg text-sm font-medium text-center hover:shadow-md transition-all">Web Developer Valencia -></a>
							<a href="/en/web-developer-sevilla" class="block p-3 bg-secondary rounded-lg text-sm font-medium text-center hover:shadow-md transition-all">Web Developer Sevilla -></a>
							<a href="/en/hire-full-stack-web-developer" class="block p-3 bg-secondary rounded-lg text-sm font-medium text-center hover:shadow-md transition-all">Hire Full-Stack Developer -></a>
							<a href="/en/web-design-businesses" class="block p-3 bg-secondary rounded-lg text-sm font-medium text-center hover:shadow-md transition-all">Web Design for Businesses -></a>
							<a href="/en/create-website-barcelona" class="block p-3 bg-secondary rounded-lg text-sm font-medium text-center hover:shadow-md transition-all">Website Pricing Guide -></a>
						</div>

						<div class="bg-secondary p-4 sm:p-6 rounded-lg mt-6 sm:mt-8 mb-6 sm:mb-8">
							<h3 class="text-xl sm:text-2xl font-bold mb-3 sm:mb-4">If you need a web developer in Barcelona, the important part is whether the project is a fit</h3>
							<p class="mb-3 sm:mb-4 text-sm sm:text-base">
								Tell me what you want to improve, what kind of client you want to attract and whether you already have something live. That is usually enough to tell whether you need a landing page, a business website, a redesign or a phased scope.
							</p>
							<p class="font-semibold text-sm sm:text-base">
								✅ Useful first reply within 24 business hours<br/>
								✅ Initial scope with no commitment<br/>
								✅ Official invoicing<br/>
								✅ Direct implementation without agency layers
							</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<Contact />
		<StickyCTA />
	</main>
</Layout>

<style>
	.text-text-muted {
		color: var(--color-text-muted);
	}
	
	.bg-secondary {
		background-color: var(--color-secondary);
	}
	
	.prose h2, .prose h3, .prose h4 {
		color: var(--color-text);
	}
	
	.prose p, .prose li {
		color: var(--color-text);
		line-height: 1.8;
	}
</style>

