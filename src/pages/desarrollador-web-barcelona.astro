---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Contact from '../components/Contact.astro';
import StickyCTA from '../components/StickyGTA.astro';

const baseUrl = 'https://www.ignacioamatweb.com';
const title = "Desarrollador web en Barcelona para webs de negocio y landing pages | Ignacio Amat";
const description = "Desarrollador web freelance para empresas de Barcelona. Landing pages, webs de negocio, redisenos, Laravel y mejoras tecnicas con foco en claridad, conversion y rendimiento.";
const canonicalUrl = "/desarrollador-web-barcelona";
const keywords = ["desarrollador web Barcelona", "freelance web Barcelona", "landing page Barcelona", "web empresa Barcelona", "rediseño web Barcelona", "crear pagina web Barcelona"];

const serviceSchema = {
	"@context": "https://schema.org",
	"@type": "ProfessionalService",
	"name": "Ignacio Amat - Desarrollo web para empresas en Barcelona",
	"url": `${baseUrl}${canonicalUrl}`,
	"description": description,
	"provider": {
		"@type": "Person",
		"name": "Ignacio Amat",
		"url": baseUrl
	},
	"areaServed": {
		"@type": "City",
		"name": "Barcelona"
	},
	"availableLanguage": ["Spanish", "English"]
};

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{
			"@type": "ListItem",
			"position": 1,
			"name": "Inicio",
			"item": baseUrl
		},
		{
			"@type": "ListItem",
			"position": 2,
			"name": "Desarrollador Web Barcelona",
			"item": `${baseUrl}${canonicalUrl}`
		}
	]
};

const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": [
		{
			"@type": "Question",
			"name": "¿Cuanto cuesta normalmente una web de negocio o una landing page en Barcelona?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Una landing page bien enfocada suele partir de 800 EUR. Una web de negocio suele moverse entre 1.800 y 4.000 EUR. Si hay integraciones, logica de negocio o una fase de producto, el presupuesto se define por alcance."
			}
		},
		{
			"@type": "Question",
			"name": "¿Cuanto suele tardar un proyecto?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Una landing page bien definida puede moverse en pocos dias. Una web de negocio suele estar entre 2 y 6 semanas. Si hay rediseño, integraciones o una app web, lo razonable es plantearlo por fases."
			}
		},
		{
			"@type": "Question",
			"name": "¿Trabajas solo con empresas de Barcelona?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "No. Trabajo en remoto con empresas de Barcelona y con equipos de otras ciudades o paises. Barcelona es una de las zonas donde hay mas demanda para webs de negocio, landings y mejoras de conversion."
			}
		},
		{
			"@type": "Question",
			"name": "¿Que tipo de proyectos encajan mejor contigo?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Encajan especialmente bien las landing pages, webs de empresa, redisenos orientados a conversion, proyectos con Laravel y primeras fases de producto o MVP."
			}
		}
	]
};
const allSchemas = [serviceSchema, breadcrumbSchema, faqSchema];

// Manual alternate URLs for service pages
const alternateUrls = {
	es: canonicalUrl,
	en: "/en/web-developer-barcelona"
};
---
<Layout 
	title={title} 
	description={description} 
	lang="es"
	canonicalUrl={canonicalUrl}
	keywords={keywords}
	additionalSchemas={allSchemas}
	alternateUrls={alternateUrls}
>
	<Header />
	<main>
		<section class="py-12 sm:py-16 md:py-20 content-page">
			<div class="container px-4 sm:px-6 content-page__container">
				<div class="max-w-4xl mx-auto content-page__inner">
					<h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 sm:mb-6">Desarrollador Web Freelance en Barcelona</h1>
					
					<p class="text-lg sm:text-xl text-text-muted mb-6 sm:mb-8">
						Trabajo con empresas de Barcelona que necesitan una web mas clara para vender servicios,
						una landing page para captar demanda o mejoras en una web que hoy no transmite bien
						lo que ofrece.
					</p>

					<div class="prose prose-lg max-w-none content-page__prose mb-8 sm:mb-12">
						<h2 class="text-2xl sm:text-3xl font-bold mt-8 sm:mt-12 mb-4 sm:mb-6">Cuando esta pagina te puede ayudar</h2>
						
						<p class="text-base sm:text-lg mb-4">
							No todo negocio necesita lo mismo. A veces hace falta una landing enfocada en captar
							contactos. Otras veces la prioridad es una web de empresa mas creible, un rediseño
							que ordene mejor el mensaje o una mejora tecnica que deje de frenar el contacto.
						</p>
						<p class="text-base sm:text-lg mb-6">
							Si tu empresa esta en Barcelona y buscas un proveedor directo, con criterio comercial
							y base tecnica solida, este tipo de colaboracion suele encajar especialmente bien.
						</p>

						<h2 class="text-2xl sm:text-3xl font-bold mt-8 sm:mt-12 mb-4 sm:mb-6">Servicios que suelen encajar mejor</h2>
						<div class="grid sm:grid-cols-2 gap-4 sm:gap-6 mb-6 sm:mb-8">
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3">Landing pages</h3>
								<p class="text-sm sm:text-base">Para campanas, captacion o servicios concretos donde conviene una sola accion principal.</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3">Webs de negocio</h3>
								<p class="text-sm sm:text-base">Para explicar mejor la oferta, reforzar confianza y facilitar la evaluacion inicial.</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3">Redisenos y mejoras</h3>
								<p class="text-sm sm:text-base">Cuando la web actual ya existe, pero no convence, no convierte o se ha quedado atras.</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3">Laravel y desarrollo a medida</h3>
								<p class="text-sm sm:text-base">Para paneles, procesos internos, integraciones o producto con logica real de negocio.</p>
							</div>
						</div>

						<h2 class="text-2xl sm:text-3xl font-bold mt-8 sm:mt-12 mb-4 sm:mb-6">Problemas que suelen aparecer antes de contratar</h2>
						<ul class="list-disc pl-5 sm:pl-6 space-y-2 sm:space-y-3 mb-4 sm:mb-6 text-sm sm:text-base">
							<li><strong>La oferta no se entiende rapido:</strong> el visitante llega, pero no tiene claro que vendes ni por que deberia escribirte.</li>
							<li><strong>La web parece mas floja que el servicio real:</strong> la primera impresion no acompana al nivel del negocio.</li>
							<li><strong>El contacto tiene demasiada friccion:</strong> formulario, CTA o estructura no guian bien hacia la accion.</li>
							<li><strong>La base tecnica esta floja:</strong> rendimiento, SEO tecnico, estructura o mantenimiento terminan frenando resultados.</li>
						</ul>

						<h2 class="text-2xl sm:text-3xl font-bold mt-8 sm:mt-12 mb-4 sm:mb-6">Por que trabajar con un freelance y no perderte en capas</h2>
						<ul class="list-disc pl-5 sm:pl-6 space-y-2 sm:space-y-3 mb-4 sm:mb-6 text-sm sm:text-base">
							<li><strong>Contacto directo:</strong> hablas con la misma persona que define y construye el proyecto.</li>
							<li><strong>Alcance mas claro:</strong> antes de empezar queda mas visible que sentido tiene hacer ahora y que puede esperar.</li>
							<li><strong>Mejor encaje comercial:</strong> la web no se plantea solo como diseno, sino como herramienta para explicar mejor y captar mejor.</li>
							<li><strong>Trabajo remoto sin complicaciones:</strong> puedo colaborar con empresas de Barcelona sin depender de procesos pesados.</li>
						</ul>

						<h2 class="text-2xl sm:text-3xl font-bold mt-8 sm:mt-12 mb-4 sm:mb-6">Precios y plazos orientativos</h2>
						<p class="mb-4 text-sm sm:text-base">
							Una landing page enfocada suele partir de 800 EUR. Una web de negocio suele moverse
							entre 1.800 y 4.000 EUR. Si el proyecto necesita integraciones, paneles o logica de
							negocio, el presupuesto se plantea por alcance y fases.
						</p>
						<p class="mb-6 text-sm sm:text-base">
							En tiempos, una landing bien definida puede moverse en pocos dias. Una web de empresa
							suele ir de 2 a 6 semanas. Si la prioridad es un MVP o una mejora sobre algo existente,
							lo mas sensato suele ser trabajar por fases.
						</p>

						<h2 class="text-2xl sm:text-3xl font-bold mt-8 sm:mt-12 mb-4 sm:mb-6">Preguntas frecuentes sobre desarrollo web en Barcelona</h2>
						<div class="space-y-4 mb-6 sm:mb-8">
							<div class="bg-secondary p-4 rounded-lg">
								<h3 class="font-bold text-base sm:text-lg mb-2">¿Cuanto cuesta normalmente una web de negocio o una landing page?</h3>
								<p class="text-sm sm:text-base text-text-muted">
									Una landing page bien enfocada suele partir de 800 EUR. Una web de negocio suele moverse
									entre 1.800 y 4.000 EUR. Si hay integraciones o logica de negocio, el alcance manda mas que la tarifa fija.
								</p>
							</div>
							<div class="bg-secondary p-4 rounded-lg">
								<h3 class="font-bold text-base sm:text-lg mb-2">¿Cuanto puede tardar mi proyecto?</h3>
								<p class="text-sm sm:text-base text-text-muted">
									Una landing bien definida puede salir en pocos dias. Una web de empresa suele ir de
									2 a 6 semanas. Si hay rediseño, integraciones o producto, lo razonable es dividir por fases.
								</p>
							</div>
							<div class="bg-secondary p-4 rounded-lg">
								<h3 class="font-bold text-base sm:text-lg mb-2">¿Trabajas solo con empresas de Barcelona?</h3>
								<p class="text-sm sm:text-base text-text-muted">
									No. Trabajo en remoto con empresas de Barcelona y con equipos de otras ciudades o paises.
									Barcelona es simplemente una de las zonas donde mas encaja este tipo de servicio.
								</p>
							</div>
							<div class="bg-secondary p-4 rounded-lg">
								<h3 class="font-bold text-base sm:text-lg mb-2">¿Que tipo de proyectos encajan mejor contigo?</h3>
								<p class="text-sm sm:text-base text-text-muted">
									Landing pages, webs de empresa, redisenos orientados a conversion, proyectos con
									Laravel y primeras fases de producto o MVP.
								</p>
							</div>
						</div>

						<div class="bg-accent/10 p-4 sm:p-6 rounded-lg mt-6 sm:mt-8 mb-6 sm:mb-8">
							<h3 class="text-xl sm:text-2xl font-bold mb-3 sm:mb-4">Si buscas un desarrollador web en Barcelona, lo importante es ver si el proyecto encaja</h3>
							<p class="mb-3 sm:mb-4 text-sm sm:text-base">
								Cuentame que quieres mejorar, que tipo de cliente quieres atraer y si partes de algo ya existente.
								Con eso te puedo decir rapido si conviene una landing, una web de negocio, un rediseño o un alcance por fases.
							</p>
							<p class="font-semibold text-sm sm:text-base">
								✅ Primera respuesta util en 24h laborables<br/>
								✅ Alcance inicial sin compromiso<br/>
								✅ Facturación oficial<br/>
								✅ Trabajo directo y sin intermediarios
							</p>
						</div>

						<h3 class="text-xl sm:text-2xl font-bold mt-6 sm:mt-8 mb-3 sm:mb-4">Paginas relacionadas:</h3>
						<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
							<a href="/pagina-web-restaurantes-barcelona" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
								<h4 class="font-bold mb-2">🍽️ Web para Restaurantes →</h4>
								<p class="text-sm text-text-muted">Menú digital y reservas online para hostelería.</p>
							</a>
							<a href="/pagina-web-clinicas-dentistas-barcelona" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
								<h4 class="font-bold mb-2">🏥 Web para Clínicas →</h4>
								<p class="text-sm text-text-muted">Sistema de citas online para sector sanitario.</p>
							</a>
							<a href="/pagina-web-abogados-despachos-barcelona" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
								<h4 class="font-bold mb-2">⚖️ Web para Abogados →</h4>
								<p class="text-sm text-text-muted">Webs profesionales para despachos jurídicos.</p>
							</a>
							<a href="/pagina-web-startups-barcelona" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
								<h4 class="font-bold mb-2">🚀 Web para Startups →</h4>
								<p class="text-sm text-text-muted">Landing pages y MVPs para emprendedores.</p>
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<Contact />
		<StickyCTA />
	</main>
</Layout>

<style>
	.text-text-muted {
		color: var(--color-text-muted);
	}
	
	.bg-secondary {
		background-color: var(--color-secondary);
	}
	
	.prose h2, .prose h3, .prose h4 {
		color: var(--color-text);
	}
	
	.prose p, .prose li {
		color: var(--color-text);
		line-height: 1.8;
	}
</style>

