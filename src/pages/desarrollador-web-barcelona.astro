---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Contact from '../components/Contact.astro';
import StickyCTA from '../components/StickyGTA.astro';

const baseUrl = 'https://ignacioamatweb.com';
const title = "Desarrollador Web Barcelona | Landing y Proyectos Complejos | Ignacio Amat";
const description = "Desarrollador web freelance en Barcelona. Landing pages, webs corporativas y proyectos complejos. Desde 800€. Presupuesto gratuito. SEO y garantía.";
const canonicalUrl = "/desarrollador-web-barcelona";
const keywords = ["desarrollador web Barcelona", "landing page Barcelona", "proyectos web complejos", "freelance web Barcelona", "crear página web", "tienda online Barcelona", "web corporativa Barcelona"];

// Structured Data
const personSchema = {
	"@context": "https://schema.org",
	"@type": "Person",
	"name": "Ignacio Amat",
	"jobTitle": "Desarrollador Web Freelance",
	"url": baseUrl,
	"address": {
		"@type": "PostalAddress",
		"addressLocality": "Barcelona",
		"addressRegion": "Cataluña",
		"addressCountry": "ES"
	},
	"knowsAbout": [
		"Desarrollo Web",
		"Diseño Web",
		"SEO",
		"E-commerce",
		"Frontend Development"
	]
};

const serviceSchema = {
	"@context": "https://schema.org",
	"@type": "Service",
	"serviceType": "Desarrollo Web",
	"provider": {
		"@type": "Person",
		"name": "Ignacio Amat"
	},
	"areaServed": {
		"@type": "City",
		"name": "Barcelona"
	}
};

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{
			"@type": "ListItem",
			"position": 1,
			"name": "Inicio",
			"item": baseUrl
		},
		{
			"@type": "ListItem",
			"position": 2,
			"name": "Desarrollador Web Barcelona",
			"item": `${baseUrl}${canonicalUrl}`
		}
	]
};

const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": [
		{
			"@type": "Question",
			"name": "¿Cuánto cobra un desarrollador web freelance en Barcelona?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Un desarrollador web freelance en Barcelona cobra entre 800€ y 6.000€+ por proyecto, dependiendo de la complejidad. Landing pages desde 800€, webs corporativas 1.500-3.500€, y tiendas online desde 3.000€. Por hora, las tarifas van de 40€ a 80€/hora según experiencia."
			}
		},
		{
			"@type": "Question",
			"name": "¿Cuánto tiempo tarda un desarrollador web en crear una página?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "El tiempo depende del tipo de web: una landing page puede estar lista en 2-5 días, una web corporativa en 2-4 semanas, y una tienda online completa en 4-8 semanas. Tener el contenido preparado acelera el proceso."
			}
		},
		{
			"@type": "Question",
			"name": "¿Es mejor contratar un freelance o una agencia en Barcelona?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Para proyectos de hasta 5.000€, un freelance ofrece mejor relación calidad-precio: 30-50% más económico, comunicación directa y mayor flexibilidad. Las agencias son mejores para proyectos muy grandes (+10.000€) que requieren múltiples especialistas simultáneamente."
			}
		},
		{
			"@type": "Question",
			"name": "¿Qué tecnologías utiliza un desarrollador web moderno?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Un desarrollador web moderno utiliza HTML5, CSS3, JavaScript y frameworks como React, Astro o Next.js para el frontend. Para el backend: Node.js, APIs REST. Para e-commerce: integraciones con Stripe, PayPal. Todo optimizado para SEO y rendimiento."
			}
		}
	]
};

const localBusinessSchema = {
	"@context": "https://schema.org",
	"@type": "ProfessionalService",
	"name": "Ignacio Amat — Desarrollador Web Barcelona",
	"url": `${baseUrl}${canonicalUrl}`,
	"image": `${baseUrl}/og-image.png`,
	"priceRange": "€€",
	"currenciesAccepted": "EUR",
	"serviceArea": { "@type": "City", "name": "Barcelona" },
	"areaServed": { "@type": "City", "name": "Barcelona" },
	"address": { "@type": "PostalAddress", "addressLocality": "Barcelona", "addressRegion": "Cataluña", "addressCountry": "ES" },
	"availableLanguage": ["Spanish", "English"],
	"sameAs": ["https://www.linkedin.com/in/ignacio-amat-urbina-789244223/", "https://github.com/ignaaaam"]
};

const allSchemas = [personSchema, serviceSchema, breadcrumbSchema, faqSchema, localBusinessSchema];

// Manual alternate URLs for service pages
const alternateUrls = {
	es: canonicalUrl,
	en: "/en/web-developer-barcelona"
};
---
<Layout 
	title={title} 
	description={description} 
	lang="es"
	canonicalUrl={canonicalUrl}
	keywords={keywords}
	additionalSchemas={allSchemas}
	alternateUrls={alternateUrls}
>
	<Header />
	<main>
		<section class="py-12 sm:py-16 md:py-20 content-page">
			<div class="container px-4 sm:px-6 content-page__container">
				<div class="max-w-4xl mx-auto content-page__inner">
					<h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 sm:mb-6">Desarrollador Web Freelance en Barcelona</h1>
					
					<p class="text-lg sm:text-xl text-text-muted mb-6 sm:mb-8">
						Soy desarrollador web freelance en Barcelona especializado en crear soluciones digitales 
						que impulsan negocios. Si buscas un desarrollador web profesional para tu proyecto, 
						estás en el lugar correcto.
					</p>

					<div class="prose prose-lg max-w-none content-page__prose mb-8 sm:mb-12">
						<h2 class="text-2xl sm:text-3xl font-bold mt-8 sm:mt-12 mb-4 sm:mb-6">¿Qué hace un desarrollador web freelance?</h2>
						
						<p class="text-base sm:text-lg mb-4">
							Como desarrollador web freelance en Barcelona, me encargo de crear, diseñar y optimizar 
							páginas web para empresas. Desde landing pages hasta e-commerce completos, desarrollo 
							soluciones web que se adaptan a las necesidades específicas de cada negocio.
						</p>

						<h3 class="text-xl sm:text-2xl font-bold mt-6 sm:mt-8 mb-3 sm:mb-4">Tecnologías y herramientas que utilizo:</h3>
						<ul class="list-disc pl-5 sm:pl-6 space-y-2 sm:space-y-3 mb-4 sm:mb-6 text-sm sm:text-base">
							<li><strong>Frontend:</strong> HTML5, CSS3, JavaScript, React, Astro, Tailwind CSS</li>
							<li><strong>Backend:</strong> Node.js, APIs REST, bases de datos</li>
							<li><strong>E-commerce:</strong> Integración con pasarelas de pago, gestión de inventario</li>
							<li><strong>SEO:</strong> Optimización on-page, schema markup, velocidad de carga</li>
							<li><strong>Responsive Design:</strong> Diseño adaptable a todos los dispositivos</li>
							<li><strong>Performance:</strong> Optimización de velocidad y Core Web Vitals</li>
						</ul>

						<h3 class="text-xl sm:text-2xl font-bold mt-6 sm:mt-8 mb-3 sm:mb-4">Servicios de desarrollo web que ofrezco:</h3>
						<div class="grid sm:grid-cols-2 gap-4 sm:gap-6 mb-6 sm:mb-8">
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h4 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3">Desarrollo Frontend</h4>
								<p class="text-sm sm:text-base">Interfaces modernas y atractivas que mejoran la experiencia del usuario</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h4 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3">Desarrollo Backend</h4>
								<p class="text-sm sm:text-base">APIs, bases de datos y lógica de negocio robusta y escalable</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h4 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3">E-commerce</h4>
								<p class="text-sm sm:text-base">Tiendas online completas con pasarelas de pago integradas</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h4 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3">Optimización SEO</h4>
								<p class="text-sm sm:text-base">Tu web aparecerá en los primeros resultados de Google</p>
							</div>
						</div>

						<h3 class="text-xl sm:text-2xl font-bold mt-6 sm:mt-8 mb-3 sm:mb-4">¿Por qué trabajar con un desarrollador web freelance en Barcelona?</h3>
						<ul class="list-disc pl-5 sm:pl-6 space-y-2 sm:space-y-3 mb-4 sm:mb-6 text-sm sm:text-base">
							<li><strong>Atención personalizada:</strong> Trabajo directo contigo, sin intermediarios</li>
							<li><strong>Precios competitivos:</strong> Sin costes de agencia, mejor relación calidad-precio</li>
							<li><strong>Flexibilidad:</strong> Me adapto a tus horarios y necesidades</li>
							<li><strong>Conocimiento local:</strong> Entiendo el mercado y las necesidades de empresas en Barcelona</li>
							<li><strong>Comunicación directa:</strong> Resolución rápida de dudas y cambios</li>
						</ul>

						<h3 class="text-xl sm:text-2xl font-bold mt-6 sm:mt-8 mb-3 sm:mb-4">Experiencia trabajando con empresas de Barcelona:</h3>
						<p class="mb-4 text-sm sm:text-base">
							He trabajado con empresas de diversos sectores en Barcelona: desde restaurantes en el 
							Barrio Gótico hasta startups tecnológicas en 22@, pasando por tiendas en Passeig de Gràcia 
							y consultorías en el Eixample. Cada proyecto es único y me adapto a las necesidades específicas 
							de cada negocio.
						</p>

						<h3 class="text-xl sm:text-2xl font-bold mt-6 sm:mt-8 mb-3 sm:mb-4">Preguntas frecuentes sobre desarrollo web en Barcelona</h3>
						<div class="space-y-4 mb-6 sm:mb-8">
							<div class="bg-secondary p-4 rounded-lg">
								<h4 class="font-bold text-base sm:text-lg mb-2">¿Cuánto cobra un desarrollador web freelance en Barcelona?</h4>
								<p class="text-sm sm:text-base text-text-muted">
									Entre 800€ y 6.000€+ por proyecto según complejidad. Landing pages desde 800€, webs corporativas 
									1.500-3.500€, tiendas online desde 3.000€. Por hora: 40-80€/hora según experiencia.
								</p>
							</div>
							<div class="bg-secondary p-4 rounded-lg">
								<h4 class="font-bold text-base sm:text-lg mb-2">¿Cuánto tiempo tarda en estar lista mi web?</h4>
								<p class="text-sm sm:text-base text-text-muted">
									Landing page: 2-5 días. Web corporativa: 2-4 semanas. Tienda online: 4-8 semanas. 
									Tener el contenido preparado acelera significativamente el proceso.
								</p>
							</div>
							<div class="bg-secondary p-4 rounded-lg">
								<h4 class="font-bold text-base sm:text-lg mb-2">¿Es mejor freelance o agencia?</h4>
								<p class="text-sm sm:text-base text-text-muted">
									Para proyectos de hasta 5.000€, un freelance ofrece 30-50% mejor precio, comunicación directa 
									y mayor flexibilidad. Las agencias son mejores para proyectos muy grandes (+10.000€).
								</p>
							</div>
							<div class="bg-secondary p-4 rounded-lg">
								<h4 class="font-bold text-base sm:text-lg mb-2">¿Qué tecnologías utilizas?</h4>
								<p class="text-sm sm:text-base text-text-muted">
									HTML5, CSS3, JavaScript, React, Astro, Next.js, Node.js, Tailwind CSS. 
									Para e-commerce: Stripe, PayPal, Redsys. Todo optimizado para SEO y rendimiento.
								</p>
							</div>
						</div>

						<div class="bg-accent/10 p-4 sm:p-6 rounded-lg mt-6 sm:mt-8 mb-6 sm:mb-8">
							<h3 class="text-xl sm:text-2xl font-bold mb-3 sm:mb-4">¿Necesitas un desarrollador web para tu proyecto?</h3>
							<p class="mb-3 sm:mb-4 text-sm sm:text-base">
								Si buscas un desarrollador web freelance en Barcelona para crear tu página web, 
								tienda online o aplicación web, contáctame. Te ayudo a hacer realidad tu proyecto digital.
							</p>
							<p class="font-semibold text-sm sm:text-base">
								✅ Presupuesto gratuito y sin compromiso<br/>
								✅ Respuesta rápida (24-48h)<br/>
								✅ Facturación oficial<br/>
								✅ Garantía de satisfacción
							</p>
						</div>

						<h3 class="text-xl sm:text-2xl font-bold mt-6 sm:mt-8 mb-3 sm:mb-4">Páginas especializadas por sector:</h3>
						<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
							<a href="/pagina-web-restaurantes-barcelona" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
								<h4 class="font-bold mb-2">🍽️ Web para Restaurantes →</h4>
								<p class="text-sm text-text-muted">Menú digital y reservas online para hostelería.</p>
							</a>
							<a href="/pagina-web-clinicas-dentistas-barcelona" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
								<h4 class="font-bold mb-2">🏥 Web para Clínicas →</h4>
								<p class="text-sm text-text-muted">Sistema de citas online para sector sanitario.</p>
							</a>
							<a href="/pagina-web-abogados-despachos-barcelona" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
								<h4 class="font-bold mb-2">⚖️ Web para Abogados →</h4>
								<p class="text-sm text-text-muted">Webs profesionales para despachos jurídicos.</p>
							</a>
							<a href="/pagina-web-startups-barcelona" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
								<h4 class="font-bold mb-2">🚀 Web para Startups →</h4>
								<p class="text-sm text-text-muted">Landing pages y MVPs para emprendedores.</p>
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<Contact />
		<StickyCTA />
	</main>
</Layout>

<style>
	.text-text-muted {
		color: var(--color-text-muted);
	}
	
	.bg-secondary {
		background-color: var(--color-secondary);
	}
	
	.prose h2, .prose h3, .prose h4 {
		color: var(--color-text);
	}
	
	.prose p, .prose li {
		color: var(--color-text);
		line-height: 1.8;
	}
</style>

