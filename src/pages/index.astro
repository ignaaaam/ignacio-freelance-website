---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import Projects from '../components/Projects.astro';
import Features from '../components/Features.astro';
import CaseStudies from '../components/CaseStudies.astro';
import Process from '../components/Process.astro';
import Pricing from '../components/Pricing.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import Contact from '../components/Contact.astro';
import StickyCTA from '../components/StickyGTA.astro';
import { siteContent } from '../data/siteContent';

const locale = 'es';
const page = siteContent[locale];
const baseUrl = 'https://www.ignacioamatweb.com';
const canonicalUrl = '/';

const professionalServiceSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': `${baseUrl}${canonicalUrl}#professional-service`,
  name: 'Ignacio Amat',
  url: `${baseUrl}${canonicalUrl}`,
  description: page.meta.description,
  areaServed: 'Espana e internacional',
  availableLanguage: ['es', 'en'],
  sameAs: [
    'https://www.linkedin.com/in/ignacio-amat-urbina-789244223/',
    'https://github.com/ignaaaam',
    'https://x.com/ignathedev',
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Landing pages, webs de empresa, redisenos, Laravel y MVPs',
  provider: {
    '@type': 'Person',
    name: 'Ignacio Amat',
    url: baseUrl,
  },
  areaServed: 'Espana y clientes internacionales',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: page.faq.items.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<Layout
  title={page.meta.title}
  description={page.meta.description}
  lang="es"
  canonicalUrl={canonicalUrl}
  additionalSchemas={[professionalServiceSchema, serviceSchema, faqSchema]}
>
  <Header />
  <main>
    <Hero />
    <TrustBar />
    <Projects />
    <Features />
    <CaseStudies />
    <Process />
    <Pricing />
    <Testimonials />
    <FAQ />
    <Contact />
  </main>
  <StickyCTA />
</Layout>
