---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Contact from '../components/Contact.astro';
import StickyCTA from '../components/StickyGTA.astro';

const baseUrl = 'https://www.ignacioamatweb.com';
const title = "Crear Página Web Alicante 2026 | Ignacio Amat";
const description = "Diseño y desarrollo de páginas web en Alicante. Especialista en webs para empresas, autónomos y sector inmobiliario. SEO local y resultados. Presupuesto en 24h.";
const canonicalUrl = "/crear-pagina-web-alicante";
const keywords = ["crear página web Alicante", "diseño web Alicante", "desarrollo web Alicante", "presupuesto web Alicante", "crear web Alicante", "freelance web Alicante", "diseño web inmobiliaria Alicante"];

// Structured Data
const serviceSchema = {
	"@context": "https://schema.org",
	"@type": "Service",
	"serviceType": "Crear Página Web para Empresas en Alicante",
	"provider": {
		"@type": "LocalBusiness",
		"name": "Ignacio Amat",
		"url": baseUrl,
		"address": {
			"@type": "PostalAddress",
			"addressLocality": "Alicante",
			"addressRegion": "Comunidad Valenciana",
			"addressCountry": "ES"
		}
	},
	"areaServed": {
		"@type": "City",
		"name": "Alicante"
	},
	"description": "Servicio profesional de diseño y desarrollo web en Alicante. Especializado en crear sitios web que atraen clientes nacionales e internacionales.",
	"offers": {
		"@type": "Offer",
		"priceRange": "€800 - €6,000+",
		"description": "Presupuesto adaptado a proyectos en Alicante"
	}
};

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{
			"@type": "ListItem",
			"position": 1,
			"name": "Inicio",
			"item": baseUrl
		},
		{
			"@type": "ListItem",
			"position": 2,
			"name": "Crear Página Web Alicante",
			"item": `${baseUrl}${canonicalUrl}`
		}
	]
};

const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": [
		{
			"@type": "Question",
			"name": "¿Cuánto cuesta crear una web para mi empresa en Alicante?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "En Alicante, mis servicios parten de 800€ para landing pages. Webs corporativas entre 1.500€ y 3.500€. E-commerce desde 3.000€. Presupuesto personalizado y detallado en 24 horas."
			}
		},
		{
			"@type": "Question",
			"name": "¿Haces webs bilingües para clientes extranjeros en Alicante?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Sí, soy especialista en webs multiidioma (español/inglés), algo fundamental para el mercado inmobiliario y de servicios en Alicante y la Costa Blanca."
			}
		}
	]
};

const localBusinessSchema = {
	"@context": "https://schema.org",
	"@type": "ProfessionalService",
	"name": "Ignacio Amat — Crear Página Web Alicante",
	"url": `https://www.ignacioamatweb.com${canonicalUrl}`,
	"image": "https://www.ignacioamatweb.com/og-image.png",
	"priceRange": "€€",
	"currenciesAccepted": "EUR",
	"serviceArea": { "@type": "City", "name": "Alicante" },
	"areaServed": { "@type": "City", "name": "Alicante" },
	"address": { "@type": "PostalAddress", "addressLocality": "Alicante", "addressRegion": "Comunidad Valenciana", "addressCountry": "ES" },
	"availableLanguage": ["Spanish", "English"],
	"sameAs": ["https://www.linkedin.com/in/ignacio-amat-urbina-789244223/", "https://github.com/ignaaaam"]
};

const allSchemas = [serviceSchema, breadcrumbSchema, faqSchema, localBusinessSchema];

const alternateUrls = {
	es: canonicalUrl,
	en: "/en/create-website-alicante"
};
---
<Layout 
	title={title} 
	description={description} 
	lang="es"
	canonicalUrl={canonicalUrl}
	keywords={keywords}
	additionalSchemas={allSchemas}
	alternateUrls={alternateUrls}
>
	<Header />
	<main>
		<section class="py-12 sm:py-16 md:py-20 content-page">
			<div class="container px-4 sm:px-6 content-page__container">
				<div class="max-w-4xl mx-auto content-page__inner">
					<h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 sm:mb-6">Crear Página Web para tu Empresa en Alicante</h1>
					
					<p class="text-lg sm:text-xl text-text-muted mb-6 sm:mb-8">
						¿Buscas un diseño web en Alicante que atraiga tanto a clientes locales como internacionales? 
						Ayudo a empresas de la Costa Blanca a crear páginas web profesionales, multiidioma y optimizadas para el SEO.
					</p>

					<div class="prose prose-lg max-w-none content-page__prose mb-8 sm:mb-12">
						<h2 class="text-2xl sm:text-3xl font-bold mt-8 sm:mt-12 mb-4 sm:mb-6">Diseño web en Alicante con enfoque global</h2>
						
						<p class="text-base sm:text-lg mb-4">
							Alicante es un mercado dinámico con una fuerte presencia de clientes extranjeros. 
							Para tener éxito, tu web no solo debe ser atractiva, sino que debe cargar rápido y estar bien estructurada 
							para posicionar en Google en varios idiomas.
						</p>

						<h3 class="text-xl sm:text-2xl font-bold mt-6 sm:mt-8 mb-3 sm:mb-4">Servicios clave en Alicante:</h3>
						<ul class="list-disc pl-5 sm:pl-6 space-y-2 sm:space-y-3 mb-4 sm:mb-6 text-sm sm:text-base">
							<li><strong>Webs Inmobiliarias:</strong> Catálogos modernos para captar el interés de compradores internacionales.</li>
							<li><strong>E-commerce Multiidioma:</strong> Vende tus productos en toda Europa con facilidad.</li>
							<li><strong>Landing Pages:</strong> Optimizadas para campañas de PPC en el mercado local y extranjero.</li>
							<li><strong>Mantenimiento Web:</strong> Soporte técnico para que tu web en Alicante nunca falle.</li>
						</ul>

						<h3 class="text-xl sm:text-2xl font-bold mt-6 sm:mt-8 mb-3 sm:mb-4">Calidad de agencia, trato de freelance</h3>
						<p class="mb-4 text-sm sm:text-base">
							Al trabajar directamente conmigo, eliminas los intermediarios y los costes excesivos de las agencias de Alicante. 
							Obtienes un código limpio, rápido y una web diseñada para que tu inversión retorne lo antes posible.
						</p>

						<div class="bg-secondary p-4 sm:p-6 rounded-lg mt-6 sm:mt-8 mb-6 sm:mb-8">
							<h3 class="text-xl sm:text-2xl font-bold mb-3 sm:mb-4">Potencia tu negocio en Alicante</h3>
							<p class="mb-3 sm:mb-4 text-sm sm:text-base">
								Si necesitas crear una página web en Alicante que marque la diferencia, hablemos. 
								Analizaré tus necesidades y te daré una propuesta detallada en 24 horas laborables.
							</p>
							<p class="font-semibold text-sm sm:text-base">
								✅ Presupuesto personalizado gratis<br/>
								✅ Webs bilingües de alto nivel<br/>
								✅ Optimización SEO técnica<br/>
								✅ Soporte directo y cercano
							</p>
						</div>

						<h3 class="text-xl sm:text-2xl font-bold mt-6 sm:mt-8 mb-3 sm:mb-4">Páginas que pueden interesarte:</h3>
						<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
							<a href="/desarrollador-web-espana" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
								<h4 class="font-bold mb-2">Desarrollador Web España →</h4>
								<p class="text-sm text-text-muted">Servicios de desarrollo remoto para todo el país.</p>
							</a>
							<a href="/diseno-web-empresas" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
								<h4 class="font-bold mb-2">Diseño Web Empresas →</h4>
								<p class="text-sm text-text-muted">Enfoque en UX y conversión para negocios digitales.</p>
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<Contact />
		<StickyCTA />
	</main>
</Layout>

<style>
	.text-text-muted { color: var(--color-text-muted); }
	.bg-secondary { background-color: var(--color-secondary); }
	.prose h2, .prose h3 { color: var(--color-text); }
	.prose p, .prose li { color: var(--color-text); line-height: 1.8; }
</style>
