---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Contact from '../components/Contact.astro';
import SeoCityInternalLinks from '../components/SeoCityInternalLinks.astro';

const baseUrl = 'https://www.ignacioamatweb.com';
const title = 'Desarrollador Web Freelance España 2026 | Ignacio Amat';
const description = 'Desarrollador web freelance para toda España. Landing pages, webs corporativas, ecommerce y apps desde 800€. Trabajo en remoto. Presupuesto gratis en 24h.';
const canonicalUrl = '/desarrollador-web-espana';
const keywords = [
  'desarrollador web espana',
  'desarrollador web freelance espana',
  'crear pagina web espana',
  'diseno web empresas espana',
  'programador web espana'
];

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${baseUrl}${canonicalUrl}#localbusiness`,
  name: 'Ignacio Amat — Desarrollador Web Freelance España',
  url: `${baseUrl}${canonicalUrl}`,
  image: `${baseUrl}/images/og-image.png`,
  description: description,
  priceRange: '€€',
  telephone: '+34-000-000-000',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Barcelona',
    addressRegion: 'Cataluña',
    addressCountry: 'ES',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 41.3874,
    longitude: 2.1686,
  },
  areaServed: [
    { '@type': 'Country', name: 'España' },
    { '@type': 'City', name: 'Barcelona' },
    { '@type': 'City', name: 'Madrid' },
    { '@type': 'City', name: 'Valencia' },
  ],
  availableLanguage: ['Spanish', 'English'],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Servicios de desarrollo web en España',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Landing pages' }, price: '800', priceCurrency: 'EUR' },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Webs corporativas' }, price: '1800', priceCurrency: 'EUR' },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Aplicaciones Laravel y MVPs' }, price: '3000', priceCurrency: 'EUR' },
    ],
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '5',
    reviewCount: '5',
    bestRating: '5',
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  'itemListElement': [
    { '@type': 'ListItem', 'position': 1, 'name': 'Inicio', 'item': baseUrl },
    { '@type': 'ListItem', 'position': 2, 'name': 'Desarrollador Web España', 'item': `${baseUrl}${canonicalUrl}` }
  ]
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  'mainEntity': [
    {
      '@type': 'Question',
      'name': '¿Trabajas solo en ciudades grandes o también en pueblos?',
      'acceptedAnswer': {
        '@type': 'Answer',
        'text': 'Trabajo con empresas de cualquier ciudad o pueblo de España. El servicio es 100% remoto, con el mismo nivel de calidad y seguimiento.'
      }
    },
    {
      '@type': 'Question',
      'name': '¿Qué tipo de proyectos desarrollas para empresas en España?',
      'acceptedAnswer': {
        '@type': 'Answer',
        'text': 'Landing pages, webs corporativas, tiendas online y aplicaciones web a medida. Cada proyecto se adapta a objetivos de captacion, ventas o automatizacion.'
      }
    },
    {
      '@type': 'Question',
      'name': '¿Cuanto cuesta una web profesional?',
      'acceptedAnswer': {
        '@type': 'Answer',
        'text': 'Los proyectos suelen empezar en 800EUR para landing pages y crecer segun alcance. Una web corporativa suele estar entre 1500EUR y 3500EUR.'
      }
    }
  ]
};

const allSchemas = [localBusinessSchema, breadcrumbSchema, faqSchema];

const alternateUrls = {
  es: canonicalUrl,
  en: '/en/web-developer-spain'
};
---

<Layout
  title={title}
  description={description}
  lang="es"
  canonicalUrl={canonicalUrl}
  keywords={keywords}
  additionalSchemas={allSchemas}
  alternateUrls={alternateUrls}
>
  <Header />
  <main>
    <section class="py-12 sm:py-16 md:py-20 content-page">
      <div class="container px-4 sm:px-6 content-page__container">
        <div class="max-w-4xl mx-auto content-page__inner">
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 sm:mb-6">
            Desarrollador Web Freelance para Empresas de Toda España
          </h1>

          <p class="text-lg sm:text-xl text-text-muted mb-6 sm:mb-8">
            Si tu empresa esta en una gran ciudad o en un pueblo pequeno, puedes contratar desarrollo web profesional
            con enfoque en SEO, rendimiento y conversion. Trabajo en remoto con clientes de toda España.
          </p>

          <div class="flex flex-wrap gap-3 mb-8">
            <a href="#contacto" class="btn-primary">Solicitar Presupuesto Gratuito</a>
            <a href="/contratar-desarrollador-full-stack" class="btn-secondary">Ver Servicio Full Stack</a>
          </div>

          <div class="prose prose-lg max-w-none content-page__prose mb-8 sm:mb-12">
            <h2 class="text-2xl sm:text-3xl font-bold mt-8 mb-4">Servicio nacional para cualquier ciudad o pueblo</h2>
            <p class="text-base sm:text-lg mb-4">
              No necesitas una agencia local para tener resultados. Con un proceso remoto bien definido,
              obtienes una web profesional con la misma calidad, independientemente de donde este tu negocio.
            </p>

            <h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">Que puedo desarrollar para tu empresa</h2>
            <div class="grid sm:grid-cols-2 gap-4 sm:gap-6 mb-8">
              <div class="bg-secondary p-4 sm:p-6 rounded-lg">
                <h3 class="text-lg sm:text-xl font-bold mb-2">Landing Pages</h3>
                <p class="text-sm sm:text-base">Páginas orientadas a captar leads para servicios concretos o campañas.</p>
              </div>
              <div class="bg-secondary p-4 sm:p-6 rounded-lg">
                <h3 class="text-lg sm:text-xl font-bold mb-2">Webs Corporativas</h3>
                <p class="text-sm sm:text-base">Sitios completos para empresas con servicios, blog y SEO tecnico.</p>
              </div>
              <div class="bg-secondary p-4 sm:p-6 rounded-lg">
                <h3 class="text-lg sm:text-xl font-bold mb-2">Tiendas Online</h3>
                <p class="text-sm sm:text-base">Ecommerce con pagos seguros, catalogo y gestion de pedidos.</p>
              </div>
              <div class="bg-secondary p-4 sm:p-6 rounded-lg">
                <h3 class="text-lg sm:text-xl font-bold mb-2">Aplicaciones Web</h3>
                <p class="text-sm sm:text-base">CRMs, paneles internos y herramientas web personalizadas.</p>
              </div>
            </div>

            <h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">Cobertura por zonas</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
              <a href="/desarrollador-web-madrid" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
                <h3 class="font-bold mb-1">Desarrollador Web Madrid -></h3>
                <p class="text-sm text-text-muted">Servicios para empresas de Madrid y alrededores.</p>
              </a>
              <a href="/desarrollador-web-barcelona" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
                <h3 class="font-bold mb-1">Desarrollador Web Barcelona -></h3>
                <p class="text-sm text-text-muted">Proyectos para empresas de Barcelona.</p>
              </a>
              <a href="/desarrollador-web-valencia" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
                <h3 class="font-bold mb-1">Desarrollador Web Valencia -></h3>
                <p class="text-sm text-text-muted">Servicios para Valencia y Comunidad Valenciana.</p>
              </a>
              <a href="/desarrollador-web-sevilla" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
                <h3 class="font-bold mb-1">Desarrollador Web Sevilla -></h3>
                <p class="text-sm text-text-muted">Servicios para Sevilla y Andalucia.</p>
              </a>
            </div>

            <div class="bg-accent/10 p-4 sm:p-6 rounded-lg mt-8 mb-4">
              <h2 class="text-xl sm:text-2xl font-bold mb-3">Quieres visibilidad real en Google?</h2>
              <p class="mb-3 text-sm sm:text-base">
                Te ayudo a construir una web que no solo se vea bien, sino que atraiga trafico cualificado y genere oportunidades.
              </p>
              <p class="font-semibold text-sm sm:text-base">
                Presupuesto en 24h laborables<br/>
                Sin compromiso<br/>
                Facturacion oficial
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="container px-4 sm:px-6 pb-8 max-w-4xl mx-auto">
      <SeoCityInternalLinks lang="es" currentPath={canonicalUrl} />
    </div>

    <Contact />
  </main>
</Layout>

<style>
  .text-text-muted { color: var(--color-text-muted); }
  .bg-secondary { background-color: var(--color-secondary); }
  .prose h2, .prose h3, .prose h4 { color: var(--color-text); }
  .prose p, .prose li { color: var(--color-text); line-height: 1.8; }
</style>
