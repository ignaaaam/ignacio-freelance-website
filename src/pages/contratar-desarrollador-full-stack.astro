---
import MarketingContentPage from '../components/MarketingContentPage.astro';

const baseUrl = 'https://www.ignacioamatweb.com';
const title = 'Contratar desarrollador full stack freelance | Ignacio Amat';
const description =
  'Desarrollador full stack freelance para landing pages, webs de empresa, ecommerce, mejoras y aplicaciones web. Trabajo remoto con empresas que necesitan una ejecucion directa y bien resuelta.';
const canonicalUrl = '/contratar-desarrollador-full-stack';
const keywords = [
  'contratar desarrollador web freelance',
  'desarrollador full stack freelance espana',
  'contratar desarrollador web espana',
  'freelance desarrollador web',
  'contratar programador web',
];

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Ignacio Amat',
  jobTitle: 'Desarrollador Full Stack Freelance',
  url: baseUrl,
  sameAs: [
    'https://www.linkedin.com/in/ignacio-amat-urbina-789244223/',
    'https://github.com/ignaaaam',
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Desarrollo full stack freelance',
  provider: {
    '@type': 'Person',
    name: 'Ignacio Amat',
    url: baseUrl,
  },
  areaServed: {
    '@type': 'Country',
    name: 'Espana',
  },
  offers: {
    '@type': 'Offer',
    priceRange: '800 EUR - 6.000 EUR',
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: baseUrl },
    { '@type': 'ListItem', position: 2, name: 'Contratar desarrollador full stack', item: `${baseUrl}${canonicalUrl}` },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Para que tipo de proyectos tiene sentido contratar un full stack freelance?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Suele encajar en landing pages, webs de empresa, mejoras sobre proyectos existentes, ecommerce y aplicaciones web donde interesa tener una sola persona resolviendo frontend, backend y despliegue.',
      },
    },
    {
      '@type': 'Question',
      name: 'Que ventaja tiene frente a una agencia?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'La comunicacion es directa, el alcance se aterriza mas rapido y hay menos capas entre quien decide y quien ejecuta el trabajo.',
      },
    },
    {
      '@type': 'Question',
      name: 'Trabajas en remoto?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Si. Trabajo en remoto con empresas de Espana y con clientes internacionales cuando el proyecto encaja.',
      },
    },
  ],
};

const facts = [
  { label: 'Encaja bien para', value: 'Webs de negocio, redisenos, ecommerce, apps web y mejoras sobre proyectos existentes.' },
  { label: 'Ventaja principal', value: 'Una sola persona toma responsabilidad sobre estructura, implementacion y puesta en produccion.' },
  { label: 'Forma de trabajo', value: 'Directa, remota y con mas rapidez para aterrizar alcance y decisiones.' },
];
---

<MarketingContentPage
  title={title}
  description={description}
  lang="es"
  canonicalUrl={canonicalUrl}
  keywords={keywords}
  alternateUrls={{ es: canonicalUrl, en: '/en/hire-full-stack-web-developer' }}
  additionalSchemas={[personSchema, serviceSchema, breadcrumbSchema, faqSchema]}
  badge="Full stack freelance"
  pageTitle="Contratar un full stack freelance para web, ecommerce o producto sin pasar por una estructura pesada"
  lead="Si necesitas a una sola persona que pueda aterrizar el alcance, resolver frontend y backend y dejar el proyecto bien publicado, trabajo de forma directa para reducir ruido y acelerar decisiones."
  primaryCta={{ label: 'Solicitar propuesta', href: '#contacto' }}
  secondaryCta={{ label: 'Ver servicios', href: '/servicios' }}
  facts={facts}
>
  <div class="prose prose-lg max-w-none">
    <h2 class="text-2xl sm:text-3xl font-bold mt-8 mb-4">Cuando tiene sentido contratar un full stack freelance</h2>
    <p class="text-base sm:text-lg mb-4">
      Tiene sentido cuando el proyecto necesita avanzar sin pasar por varias capas de coordinacion y cuando
      te conviene que la misma persona pueda entender el objetivo, aterrizar el alcance y ejecutar la solucion.
    </p>
    <p class="text-base sm:text-lg mb-6">
      No siempre hace falta una estructura grande. En muchos proyectos de web, rediseno o producto, una
      ejecucion mas directa da mejor ritmo, menos ruido y una relacion mas clara entre coste y valor entregado.
    </p>

    <div class="grid sm:grid-cols-2 gap-4 sm:gap-6 mb-8">
      <div class="card p-5">
        <h3 class="text-lg font-semibold mb-2">Una sola responsabilidad tecnica</h3>
        <p class="text-text-muted text-sm sm:text-base">
          El proyecto no se reparte entre perfiles que luego tienen que reinterpretar lo que necesita el negocio.
        </p>
      </div>
      <div class="card p-5">
        <h3 class="text-lg font-semibold mb-2">Mas rapidez para decidir</h3>
        <p class="text-text-muted text-sm sm:text-base">
          El feedback y los cambios no tienen que cruzar una cadena larga de interlocutores antes de llegar a quien implementa.
        </p>
      </div>
      <div class="card p-5">
        <h3 class="text-lg font-semibold mb-2">Mejor encaje en proyectos medianos</h3>
        <p class="text-text-muted text-sm sm:text-base">
          Especialmente util cuando quieres lanzar algo bien resuelto sin sobredimensionar equipo ni proceso.
        </p>
      </div>
      <div class="card p-5">
        <h3 class="text-lg font-semibold mb-2">Mas continuidad despues del lanzamiento</h3>
        <p class="text-text-muted text-sm sm:text-base">
          Si el proyecto crece, es mas facil evolucionarlo sobre una base ya entendida que empezar de cero con otro equipo.
        </p>
      </div>
    </div>

    <h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">Que tipo de proyectos suelo trabajar asi</h2>
    <div class="grid sm:grid-cols-2 gap-4 sm:gap-6 mb-8">
      <div class="bg-secondary p-4 sm:p-6 rounded-lg">
        <h3 class="text-base sm:text-lg font-bold mb-2">Landing pages y captacion</h3>
        <p class="text-sm sm:text-base">
          Para campanas, servicios o propuestas donde importa mas convertir bien que parecer una web enorme.
        </p>
      </div>
      <div class="bg-secondary p-4 sm:p-6 rounded-lg">
        <h3 class="text-base sm:text-lg font-bold mb-2">Webs de empresa y redisenos</h3>
        <p class="text-sm sm:text-base">
          Cuando la prioridad es aclarar la oferta, reforzar confianza y dejar una base mejor resuelta que la actual.
        </p>
      </div>
      <div class="bg-secondary p-4 sm:p-6 rounded-lg">
        <h3 class="text-base sm:text-lg font-bold mb-2">Ecommerce y flujos comerciales</h3>
        <p class="text-sm sm:text-base">
          Para proyectos con pagos, catalogo, formularios o integraciones donde conviene cuidar tambien la capa tecnica.
        </p>
      </div>
      <div class="bg-secondary p-4 sm:p-6 rounded-lg">
        <h3 class="text-base sm:text-lg font-bold mb-2">Apps web, paneles y MVPs</h3>
        <p class="text-sm sm:text-base">
          Cuando el proyecto ya necesita mas que una web y conviene trabajar con una primera fase util y mantenible.
        </p>
      </div>
    </div>

    <h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">Que valor aporta frente a una estructura mas grande</h2>
    <ul class="list-disc pl-5 sm:pl-6 space-y-2 mb-8 text-sm sm:text-base">
      <li><strong>Comunicacion directa:</strong> hablas con quien entiende el problema y ejecuta la solucion.</li>
      <li><strong>Menos friccion:</strong> menos traspasos internos significa menos malentendidos y menos tiempo perdido.</li>
      <li><strong>Mas criterio en el alcance:</strong> se puede decidir antes que hace falta ahora y que deberia esperar.</li>
      <li><strong>Mejor relacion entre inversion y trabajo real:</strong> especialmente en proyectos de tamano medio donde una estructura pesada no aporta tanto.</li>
    </ul>

    <h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">Rangos orientativos</h2>
    <div class="space-y-4 mb-8">
      <div class="bg-secondary p-4 sm:p-6 rounded-lg">
        <h3 class="font-bold text-base sm:text-lg mb-1">Landing page o mejora concreta — desde 800 EUR</h3>
        <p class="text-sm sm:text-base text-text-muted">
          Para proyectos enfocados, correcciones con impacto o una primera pieza comercial bien resuelta.
        </p>
      </div>
      <div class="bg-secondary p-4 sm:p-6 rounded-lg">
        <h3 class="font-bold text-base sm:text-lg mb-1">Web de empresa o rediseno — desde 1.500 EUR</h3>
        <p class="text-sm sm:text-base text-text-muted">
          Cuando la necesidad ya pasa por replantear estructura, mensaje y presencia digital con mas profundidad.
        </p>
      </div>
      <div class="bg-secondary p-4 sm:p-6 rounded-lg">
        <h3 class="font-bold text-base sm:text-lg mb-1">Aplicacion web o MVP — desde 3.000 EUR</h3>
        <p class="text-sm sm:text-base text-text-muted">
          Para producto digital, paneles o software de negocio donde ya existe una capa funcional mas importante.
        </p>
      </div>
    </div>

    <h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-6">Preguntas frecuentes</h2>
    <div class="space-y-4 mb-8">
      <div class="bg-secondary p-4 rounded-lg">
        <h3 class="font-bold text-base sm:text-lg mb-2">Para que tipo de proyectos encaja un full stack freelance?</h3>
        <p class="text-sm sm:text-base text-text-muted">
          Landing pages, webs de empresa, redisenos, ecommerce, apps web y mejoras donde interesa tener una sola persona resolviendo varias capas del proyecto.
        </p>
      </div>
      <div class="bg-secondary p-4 rounded-lg">
        <h3 class="font-bold text-base sm:text-lg mb-2">Trabajas en remoto?</h3>
        <p class="text-sm sm:text-base text-text-muted">
          Si. Trabajo en remoto con empresas de toda Espana y con clientes internacionales cuando el proyecto encaja bien.
        </p>
      </div>
      <div class="bg-secondary p-4 rounded-lg">
        <h3 class="font-bold text-base sm:text-lg mb-2">Que pasa si solo necesito una parte concreta?</h3>
        <p class="text-sm sm:text-base text-text-muted">
          Tambien trabajo mejoras puntuales, correcciones, revisiones y fases cortas cuando es la mejor forma de avanzar.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-8">
      <a href="/servicios" class="block p-3 bg-secondary rounded-lg text-sm font-medium text-center hover:shadow-md transition-all">Todos los servicios &rarr;</a>
      <a href="/crear-landing-page-profesional" class="block p-3 bg-secondary rounded-lg text-sm font-medium text-center hover:shadow-md transition-all">Landing pages &rarr;</a>
      <a href="/diseno-web-empresas" class="block p-3 bg-secondary rounded-lg text-sm font-medium text-center hover:shadow-md transition-all">Webs de empresa &rarr;</a>
      <a href="/desarrollo-aplicacion-web-saas" class="block p-3 bg-secondary rounded-lg text-sm font-medium text-center hover:shadow-md transition-all">Apps web y MVPs &rarr;</a>
      <a href="/cuanto-cuesta-pagina-web" class="block p-3 bg-secondary rounded-lg text-sm font-medium text-center hover:shadow-md transition-all">Guia de precios &rarr;</a>
      <a href="/contact" class="block p-3 bg-secondary rounded-lg text-sm font-medium text-center hover:shadow-md transition-all">Contacto &rarr;</a>
    </div>

    <div class="bg-accent/10 p-4 sm:p-6 rounded-lg mt-8 mb-4">
      <h2 class="text-xl sm:text-2xl font-bold mb-3">Quieres una propuesta clara sin pasar por capas innecesarias?</h2>
      <p class="mb-3 text-sm sm:text-base">
        Cuentame el proyecto, el punto de partida y que necesitas mover primero. Si encaja, te dire como enfocaria el alcance y la primera fase.
      </p>
      <p class="font-semibold text-sm sm:text-base">
        Propuesta mas directa<br />
        Menos friccion entre idea y ejecucion<br />
        Alcance pensado con criterio tecnico y comercial
      </p>
    </div>
  </div>
</MarketingContentPage>
