---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Contact from '../components/Contact.astro';

const baseUrl = 'https://www.ignacioamatweb.com';
const title = "Desarrollador Web en Eixample Barcelona | Creación de Páginas Web desde 800€";
const description = "¿Buscas un desarrollador web en el Eixample de Barcelona? Creo páginas web profesionales para empresas, comercios y profesionales del Eixample. Diseño moderno, SEO local y presupuesto gratuito.";
const canonicalUrl = "/desarrollador-web-eixample-barcelona";

// Structured Data
const localBusinessSchema = {
	"@context": "https://schema.org",
	"@type": "LocalBusiness",
	"name": "Ignacio Amat - Desarrollador Web Eixample",
	"url": baseUrl,
	"address": {
		"@type": "PostalAddress",
		"addressLocality": "Barcelona",
		"addressRegion": "Cataluña",
		"addressCountry": "ES",
		"streetAddress": "Eixample"
	},
	"geo": {
		"@type": "GeoCoordinates",
		"latitude": "41.3926",
		"longitude": "2.1631"
	},
	"areaServed": {
		"@type": "Place",
		"name": "Eixample, Barcelona"
	},
	"priceRange": "€€",
	"description": "Servicios de desarrollo web profesional para empresas y negocios del Eixample de Barcelona."
};

const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": [
		{
			"@type": "Question",
			"name": "¿Cuánto cuesta crear una página web para mi negocio en el Eixample?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "El precio para crear una página web en el Eixample de Barcelona varía según tus necesidades: Landing pages desde 800€, webs corporativas de 1.500€ a 3.500€, y tiendas online desde 3.000€. Ofrezco presupuesto personalizado sin compromiso."
			}
		},
		{
			"@type": "Question",
			"name": "¿Por qué elegir un desarrollador web local del Eixample?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Un desarrollador local entiende el mercado y la competencia de la zona. Puedo reunirme contigo en persona, entender mejor tu negocio y optimizar tu web para SEO local del Eixample, ayudándote a aparecer cuando busquen servicios en tu barrio."
			}
		}
	]
};

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{
			"@type": "ListItem",
			"position": 1,
			"name": "Inicio",
			"item": baseUrl
		},
		{
			"@type": "ListItem",
			"position": 2,
			"name": "Desarrollador Web Barcelona",
			"item": `${baseUrl}/desarrollador-web-barcelona`
		},
		{
			"@type": "ListItem",
			"position": 3,
			"name": "Eixample",
			"item": `${baseUrl}${canonicalUrl}`
		}
	]
};

const allSchemas = [localBusinessSchema, faqSchema, breadcrumbSchema];
---
<Layout 
	title={title} 
	description={description} 
	lang="es"
	canonicalUrl={canonicalUrl}
	additionalSchemas={allSchemas}
	keywords={["desarrollador web Eixample", "crear página web Eixample Barcelona", "diseño web Eixample", "web para empresas Eixample", "programador web Eixample Barcelona", "página web negocio Eixample"]}
>
	<Header />
	<main>
		<section class="py-12 sm:py-16 md:py-20 content-page">
			<div class="container px-4 sm:px-6 content-page__container">
				<div class="max-w-4xl mx-auto content-page__inner">
					<div class="mb-6">
						<span class="inline-block px-3 py-1 text-sm font-medium bg-accent/10 text-accent rounded-full mb-4">
							📍 Zona: Eixample, Barcelona
						</span>
					</div>
					
					<h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 sm:mb-6">
						Desarrollador Web en el Eixample de Barcelona
					</h1>
					
					<p class="text-lg sm:text-xl text-text-muted mb-6 sm:mb-8">
						¿Tienes un negocio, comercio o consulta profesional en el Eixample de Barcelona? 
						Creo páginas web profesionales optimizadas para aparecer cuando tus clientes busquen 
						servicios en tu zona. <strong>Atención personalizada y reuniones presenciales en el barrio.</strong>
					</p>

					<div class="prose prose-lg max-w-none content-page__prose mb-8 sm:mb-12">
						<h2 class="text-2xl sm:text-3xl font-bold mt-8 sm:mt-12 mb-4 sm:mb-6">
							¿Por qué elegir un desarrollador web local del Eixample?
						</h2>
						
						<p class="text-base sm:text-lg mb-4">
							El Eixample es uno de los barrios más comerciales de Barcelona, con una alta concentración de 
							negocios, consultorías, clínicas y comercios. La competencia online es feroz, y necesitas 
							una web que destaque y aparezca en Google cuando busquen servicios en tu zona.
						</p>

						<ul class="list-disc pl-5 sm:pl-6 space-y-2 sm:space-y-3 mb-4 sm:mb-6 text-sm sm:text-base">
							<li><strong>Conozco el mercado local:</strong> Entiendo la competencia y el perfil de cliente del Eixample</li>
							<li><strong>Reuniones presenciales:</strong> Podemos quedar en persona para entender mejor tu negocio</li>
							<li><strong>SEO local optimizado:</strong> Tu web aparecerá cuando busquen servicios en el Eixample</li>
							<li><strong>Comunicación directa:</strong> Sin intermediarios, trabajo directamente contigo</li>
							<li><strong>Soporte cercano:</strong> Cualquier duda o cambio, estoy a mano</li>
						</ul>

						<h2 class="text-2xl sm:text-3xl font-bold mt-8 sm:mt-12 mb-4 sm:mb-6">
							Negocios del Eixample con los que trabajo
						</h2>

						<div class="grid sm:grid-cols-2 gap-4 sm:gap-6 mb-6 sm:mb-8">
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3">👔 Consultorías y Despachos</h3>
								<p class="text-sm sm:text-base">Abogados, asesores fiscales, consultores. Webs que transmiten profesionalidad.</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3">🦷 Clínicas y Consultas</h3>
								<p class="text-sm sm:text-base">Dentistas, psicólogos, fisioterapeutas. Webs con sistema de citas online.</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3">🛍️ Comercios</h3>
								<p class="text-sm sm:text-base">Tiendas de moda, decoración, gourmet. Tiendas online y webs corporativas.</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3">🍽️ Hostelería</h3>
								<p class="text-sm sm:text-base">Restaurantes, bares, cafeterías. Menú digital y reservas online.</p>
							</div>
						</div>

						<h2 class="text-2xl sm:text-3xl font-bold mt-8 sm:mt-12 mb-4 sm:mb-6">
							SEO Local para el Eixample de Barcelona
						</h2>
						
						<p class="text-base sm:text-lg mb-4">
							Optimizo tu web para que aparezcas cuando alguien busque servicios en el Eixample. 
							Esto incluye:
						</p>

						<ul class="list-disc pl-5 sm:pl-6 space-y-2 mb-4 sm:mb-6 text-sm sm:text-base">
							<li>Configuración de Google Business Profile</li>
							<li>Schema markup de LocalBusiness para el Eixample</li>
							<li>Optimización para búsquedas como "dentista Eixample" o "abogado Eixample Barcelona"</li>
							<li>Contenido localizado mencionando calles y referencias del barrio</li>
							<li>Integración con Google Maps mostrando tu ubicación exacta</li>
						</ul>

						<div class="bg-accent/10 p-4 sm:p-6 rounded-lg mt-6 sm:mt-8 mb-6 sm:mb-8">
							<h3 class="text-xl sm:text-2xl font-bold mb-3 sm:mb-4">
								¿Tienes un negocio en el Eixample?
							</h3>
							<p class="mb-3 sm:mb-4 text-sm sm:text-base">
								Cuéntame sobre tu negocio y te preparo un presupuesto personalizado. Podemos 
								quedar a tomar un café en el barrio y hablamos de tu proyecto sin compromiso.
							</p>
							<p class="font-semibold text-sm sm:text-base">
								✅ Presupuesto gratuito en 24h<br/>
								✅ Reunión presencial si prefieres<br/>
								✅ SEO local incluido<br/>
								✅ Factura oficial
							</p>
						</div>

						<h3 class="text-xl sm:text-2xl font-bold mt-6 sm:mt-8 mb-3 sm:mb-4">Servicios relacionados:</h3>
						<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
							<a href="/desarrollador-web-barcelona" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
								<h4 class="font-bold mb-2">Desarrollador Web Barcelona →</h4>
								<p class="text-sm text-text-muted">Servicios de desarrollo web para todo Barcelona.</p>
							</a>
							<a href="/crear-pagina-web-barcelona" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
								<h4 class="font-bold mb-2">Crear Página Web Barcelona →</h4>
								<p class="text-sm text-text-muted">Creación de webs profesionales para empresas.</p>
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<Contact />
	</main>
</Layout>

<style>
	.text-text-muted {
		color: var(--color-text-muted);
	}
	
	.bg-secondary {
		background-color: var(--color-secondary);
	}
	
	.text-accent {
		color: var(--color-accent);
	}
	
	.prose h2, .prose h3 {
		color: var(--color-text);
	}
	
	.prose p, .prose li {
		color: var(--color-text);
		line-height: 1.8;
	}
</style>
