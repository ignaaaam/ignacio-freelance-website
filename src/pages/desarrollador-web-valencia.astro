---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Contact from '../components/Contact.astro';
import StickyCTA from '../components/StickyGTA.astro';

const baseUrl = 'https://ignacioamatweb.com';
const title = "Desarrollador Web Valencia | Freelance Full Stack | Ignacio Amat";
const description = "Desarrollador web freelance para empresas de Valencia. Landing pages, webs corporativas y aplicaciones web desde 800€. Trabajo en remoto. Presupuesto gratuito.";
const canonicalUrl = "/desarrollador-web-valencia";
const keywords = ["desarrollador web Valencia", "desarrollador web freelance Valencia", "crear página web Valencia", "diseño web Valencia", "landing page Valencia", "web corporativa Valencia", "freelance web Valencia", "programador web Valencia"];

const personSchema = {
	"@context": "https://schema.org",
	"@type": "Person",
	"name": "Ignacio Amat",
	"jobTitle": "Desarrollador Web Freelance",
	"url": baseUrl,
	"knowsAbout": ["Desarrollo Web", "Diseño Web", "SEO", "E-commerce", "Frontend Development"],
	"hasOfferCatalog": {
		"@type": "OfferCatalog",
		"name": "Servicios de desarrollo web para Valencia",
		"itemListElement": [
			{ "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Landing pages para empresas de Valencia" } },
			{ "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Webs corporativas para Valencia" } },
			{ "@type": "Offer", "itemOffered": { "@type": "Service", "name": "E-commerce para tiendas de Valencia" } }
		]
	}
};

const serviceSchema = {
	"@context": "https://schema.org",
	"@type": "Service",
	"serviceType": "Desarrollo Web",
	"provider": {
		"@type": "Person",
		"name": "Ignacio Amat",
		"url": baseUrl
	},
	"areaServed": {
		"@type": "City",
		"name": "Valencia"
	},
	"offers": {
		"@type": "Offer",
		"priceRange": "800€ - 6.000€+"
	}
};

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{ "@type": "ListItem", "position": 1, "name": "Inicio", "item": baseUrl },
		{ "@type": "ListItem", "position": 2, "name": "Desarrollador Web Valencia", "item": `${baseUrl}${canonicalUrl}` }
	]
};

const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": [
		{
			"@type": "Question",
			"name": "¿Cuánto cobra un desarrollador web freelance en Valencia?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Un desarrollador web freelance en Valencia cobra entre 800€ y 6.000€+ por proyecto según complejidad. Landing pages desde 800€, webs corporativas 1.500-3.500€, y tiendas online desde 3.000€. Por hora, las tarifas rondan 40-75€/hora."
			}
		},
		{
			"@type": "Question",
			"name": "¿Trabajas con empresas de Valencia de forma remota?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Sí. Trabajo 100% en remoto con empresas de Valencia y toda la Comunitat Valenciana. Nos comunicamos por videollamada, email y las herramientas que prefieras. Sin desplazamientos ni costes extra."
			}
		},
		{
			"@type": "Question",
			"name": "¿Cuánto tiempo tarda una web para una empresa de Valencia?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Una landing page puede estar lista en 2-5 días, una web corporativa en 2-4 semanas, y una tienda online en 4-8 semanas. La rapidez también depende de la disponibilidad del contenido del cliente."
			}
		},
		{
			"@type": "Question",
			"name": "¿Emites factura oficial para empresas valencianas?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Sí. Emito facturas oficiales para empresas y autónomos de Valencia. El coste del desarrollo web es desgravable como inversión empresarial."
			}
		}
	]
};

const localBusinessSchema = {
	"@context": "https://schema.org",
	"@type": "ProfessionalService",
	"name": "Ignacio Amat — Desarrollador Web Valencia",
	"url": `${baseUrl}${canonicalUrl}`,
	"image": `${baseUrl}/og-image.png`,
	"priceRange": "€€",
	"currenciesAccepted": "EUR",
	"serviceArea": { "@type": "City", "name": "Valencia" },
	"areaServed": { "@type": "City", "name": "Valencia" },
	"address": { "@type": "PostalAddress", "addressLocality": "Valencia", "addressRegion": "Comunitat Valenciana", "addressCountry": "ES" },
	"availableLanguage": ["Spanish", "English"],
	"sameAs": ["https://www.linkedin.com/in/ignacio-amat-urbina-789244223/", "https://github.com/ignaaaam"]
};

const allSchemas = [personSchema, serviceSchema, breadcrumbSchema, faqSchema, localBusinessSchema];

const alternateUrls = {
	es: canonicalUrl,
	en: "/en/web-developer-valencia"
};
---
<Layout
	title={title}
	description={description}
	lang="es"
	canonicalUrl={canonicalUrl}
	keywords={keywords}
	additionalSchemas={allSchemas}
	alternateUrls={alternateUrls}
>
	<Header />
	<main>
		<section class="py-12 sm:py-16 md:py-20 content-page">
			<div class="container px-4 sm:px-6 content-page__container">
				<div class="max-w-4xl mx-auto content-page__inner">
					<h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 sm:mb-6">Desarrollador Web Freelance para Empresas de Valencia</h1>

					<p class="text-lg sm:text-xl text-text-muted mb-6 sm:mb-8">
						¿Tu empresa valenciana necesita una presencia digital profesional? Soy Ignacio Amat, desarrollador web freelance full stack.
						Diseño y desarrollo webs rápidas, optimizadas para SEO y orientadas a convertir visitantes en clientes.
						Trabajo en remoto con empresas de Valencia, Castellón y Alicante. Presupuesto gratuito.
					</p>

					<div class="flex flex-wrap gap-3 mb-8">
						<a href="#contacto" class="btn-primary">Solicitar Presupuesto Gratuito</a>
					</div>

					<div class="prose prose-lg max-w-none content-page__prose mb-8 sm:mb-12">

						<h2 class="text-2xl sm:text-3xl font-bold mt-8 mb-4">Desarrollo web profesional para empresas de Valencia</h2>
						<p class="text-base sm:text-lg mb-4">
							Valencia es una de las ciudades con mayor crecimiento económico y tecnológico de España.
							Las empresas valencianas necesitan webs que reflejen esa modernidad: rápidas, visibles en Google y diseñadas para convertir.
							Como desarrollador web freelance, te ayudo a construir esa presencia digital sin los costes de una agencia.
						</p>
						<p class="text-base sm:text-lg mb-4">
							Trabajo con empresas de Ruzafa, Benimaclet, el Cabanyal, El Carmen, Patraix, Burjassot, Torrent, Paterna,
							y cualquier localidad de la Comunitat Valenciana — 100% en remoto, sin recargos por distancia.
						</p>

						<h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">Servicios de desarrollo web para Valencia</h2>
						<div class="grid sm:grid-cols-2 gap-4 sm:gap-6 mb-8">
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg sm:text-xl font-bold mb-2">Landing Pages de Conversión</h3>
								<p class="text-sm sm:text-base">Páginas diseñadas para captar clientes. Ideales para campañas, lanzamientos y servicios específicos. Desde 800€.</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg sm:text-xl font-bold mb-2">Web Corporativa</h3>
								<p class="text-sm sm:text-base">Presencia online completa para tu empresa valenciana. Blog, múltiples servicios y SEO avanzado. Desde 1.500€.</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg sm:text-xl font-bold mb-2">Tienda Online</h3>
								<p class="text-sm sm:text-base">Vende tus productos con pasarelas de pago seguras (Stripe, Redsys, Bizum). Desde 3.000€.</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg sm:text-xl font-bold mb-2">Aplicaciones Web a Medida</h3>
								<p class="text-sm sm:text-base">Plataformas, CRMs, portales de clientes o cualquier herramienta digital personalizada.</p>
							</div>
						</div>

						<h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">¿Por qué elegir un freelance en lugar de una agencia en Valencia?</h2>
						<ul class="list-disc pl-5 sm:pl-6 space-y-2 mb-6 text-sm sm:text-base">
							<li><strong>Hasta un 50% más económico</strong> que agencias locales sin sacrificar calidad.</li>
							<li><strong>Trato directo:</strong> Siempre hablas conmigo, el desarrollador. Sin intermediarios.</li>
							<li><strong>Tecnología moderna:</strong> React, Astro, Node.js — webs ultrarrápidas y bien posicionadas.</li>
							<li><strong>SEO desde el día 1:</strong> Tu web diseñada para aparecer en los primeros resultados de Google.</li>
							<li><strong>Factura oficial</strong> para empresas y autónomos.</li>
							<li><strong>Garantía de satisfacción:</strong> Si no estás contento, seguimos hasta que lo estés.</li>
						</ul>

						<h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">Precios para empresas de Valencia</h2>
						<div class="space-y-4 mb-8">
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="font-bold text-base sm:text-lg mb-2">Landing Page — desde 800€</h3>
								<p class="text-sm sm:text-base text-text-muted">Lista en 2-5 días. Perfecta para captar leads con Google Ads o redes sociales.</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="font-bold text-base sm:text-lg mb-2">Web Corporativa — 1.500€ a 3.500€</h3>
								<p class="text-sm sm:text-base text-text-muted">Lista en 2-4 semanas. Con blog, CMS y SEO avanzado.</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="font-bold text-base sm:text-lg mb-2">Tienda Online — 3.000€ a 6.000€+</h3>
								<p class="text-sm sm:text-base text-text-muted">Lista en 4-8 semanas. Catálogo, pasarela de pago y gestión de pedidos.</p>
							</div>
						</div>

						<div class="bg-accent/10 p-4 sm:p-6 rounded-lg mt-8 mb-8">
							<h2 class="text-xl sm:text-2xl font-bold mb-3">¿Listo para dar el paso digital en Valencia?</h2>
							<p class="mb-3 text-sm sm:text-base">
								Cuéntame tu proyecto y en menos de 24 horas te envío un presupuesto detallado, sin rodeos y sin compromiso.
							</p>
							<p class="font-semibold text-sm sm:text-base">
								✅ Presupuesto gratuito en 24h<br/>
								✅ Sin compromiso<br/>
								✅ Facturación oficial<br/>
								✅ Garantía de satisfacción
							</p>
						</div>

						<h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">Otros servicios de desarrollo web</h2>
						<div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
							<a href="/desarrollador-web-espana" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
								<h3 class="font-bold mb-1">🇪🇸 Desarrollador Web España →</h3>
								<p class="text-sm text-text-muted">Servicio nacional para cualquier ciudad o pueblo.</p>
							</a>
							<a href="/desarrollador-web-madrid" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
								<h3 class="font-bold mb-1">🏙️ Desarrollador Web Madrid →</h3>
								<p class="text-sm text-text-muted">Servicios para empresas de la capital.</p>
							</a>
							<a href="/desarrollador-web-barcelona" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
								<h3 class="font-bold mb-1">🏙️ Desarrollador Web Barcelona →</h3>
								<p class="text-sm text-text-muted">Mi perfil y servicios principales.</p>
							</a>
							<a href="/contratar-desarrollador-full-stack" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
								<h3 class="font-bold mb-1">💻 Contratar Desarrollador Full Stack →</h3>
								<p class="text-sm text-text-muted">Para proyectos complejos y apps web.</p>
							</a>
							<a href="/diseno-web-empresas" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
								<h3 class="font-bold mb-1">🎨 Diseño Web para Empresas →</h3>
								<p class="text-sm text-text-muted">Diseños orientados a conversión.</p>
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<Contact />
		<StickyCTA />
	</main>
</Layout>

<style>
	.text-text-muted {
		color: var(--color-text-muted);
	}

	.bg-secondary {
		background-color: var(--color-secondary);
	}

	.prose h2, .prose h3, .prose h4 {
		color: var(--color-text);
	}

	.prose p, .prose li {
		color: var(--color-text);
		line-height: 1.8;
	}
</style>
