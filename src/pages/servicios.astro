---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Features from '../components/Features.astro';
import Projects from '../components/Projects.astro';
import Pricing from '../components/Pricing.astro';
import Contact from '../components/Contact.astro';
import StickyCTA from '../components/StickyGTA.astro';
import { siteContent } from '../data/siteContent';

const page = siteContent.es;
const canonicalUrl = '/servicios';
---

<Layout
  title="Servicios de desarrollo web freelance | Ignacio Amat"
  description="Hub de servicios para landing pages, webs de empresa, Laravel, redisenos, mantenimiento y MVPs."
  lang="es"
  canonicalUrl={canonicalUrl}
  alternateUrls={{ es: canonicalUrl, en: '/en/services' }}
>
  <Header />
  <main>
    <section class="section">
      <div class="container">
        <div class="section-heading">
          <p class="section-eyebrow">{page.servicesPage.eyebrow}</p>
          <h1>{page.servicesPage.title}</h1>
          <p class="section-copy">{page.servicesPage.description}</p>
        </div>
        <div class="service-page__actions">
          <a href="#contacto" class="btn-primary" data-cta="services-primary">{page.servicesPage.ctaPrimary}</a>
          <a href="#proyectos" class="btn-secondary" data-cta="services-secondary">{page.servicesPage.ctaSecondary}</a>
        </div>
        <div class="service-page__links">
          <a href="/desarrollador-web-barcelona">Desarrollador web Barcelona</a>
          <a href="/cuanto-cuesta-pagina-web">Guia de precios</a>
          <a href="/preguntas-frecuentes">Preguntas frecuentes</a>
        </div>
      </div>
    </section>
    <Features />
    <Projects />
    <Pricing />
    <Contact />
  </main>
  <StickyCTA />
</Layout>

<style>
  .service-page__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.4rem;
  }

  .service-page__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1rem;
  }

  .service-page__links a {
    color: var(--color-text-muted);
    font-weight: 700;
  }

  .service-page__links a:hover {
    color: var(--theme-highlight);
  }

  @media (max-width: 720px) {
    .service-page__actions {
      flex-direction: column;
    }
  }
</style>
