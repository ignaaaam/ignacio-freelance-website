---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Contact from '../components/Contact.astro';
import StickyCTA from '../components/StickyGTA.astro';

const baseUrl = 'https://ignacioamatweb.com';
const title = "Desarrollador Web Madrid | Freelance Full Stack | Ignacio Amat";
const description = "Desarrollador web freelance en Madrid. Landing pages, webs corporativas y aplicaciones web desde 800€. Trabajo en remoto con empresas de Madrid. Presupuesto gratuito.";
const canonicalUrl = "/desarrollador-web-madrid";
const keywords = ["desarrollador web Madrid", "desarrollador web freelance Madrid", "crear página web Madrid", "diseño web Madrid", "landing page Madrid", "web corporativa Madrid", "freelance web Madrid", "programador web Madrid"];

const personSchema = {
	"@context": "https://schema.org",
	"@type": "Person",
	"name": "Ignacio Amat",
	"jobTitle": "Desarrollador Web Freelance",
	"url": baseUrl,
	"knowsAbout": ["Desarrollo Web", "Diseño Web", "SEO", "E-commerce", "Frontend Development"],
	"hasOfferCatalog": {
		"@type": "OfferCatalog",
		"name": "Servicios de desarrollo web para Madrid",
		"itemListElement": [
			{ "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Landing pages para empresas de Madrid" } },
			{ "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Webs corporativas para Madrid" } },
			{ "@type": "Offer", "itemOffered": { "@type": "Service", "name": "E-commerce para tiendas de Madrid" } }
		]
	}
};

const serviceSchema = {
	"@context": "https://schema.org",
	"@type": "Service",
	"serviceType": "Desarrollo Web",
	"provider": {
		"@type": "Person",
		"name": "Ignacio Amat",
		"url": baseUrl
	},
	"areaServed": {
		"@type": "City",
		"name": "Madrid"
	},
	"offers": {
		"@type": "Offer",
		"priceRange": "800€ - 6.000€+"
	}
};

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{ "@type": "ListItem", "position": 1, "name": "Inicio", "item": baseUrl },
		{ "@type": "ListItem", "position": 2, "name": "Desarrollador Web Madrid", "item": `${baseUrl}${canonicalUrl}` }
	]
};

const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": [
		{
			"@type": "Question",
			"name": "¿Cuánto cobra un desarrollador web freelance en Madrid?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Un desarrollador web freelance en Madrid cobra entre 800€ y 6.000€+ por proyecto según complejidad. Landing pages desde 800€, webs corporativas 1.500-3.500€, y tiendas online desde 3.000€. Por hora, las tarifas rondan 45-85€/hora según experiencia y tecnología."
			}
		},
		{
			"@type": "Question",
			"name": "¿Necesito estar en Madrid para contratar un desarrollador web?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "No. Trabajo 100% en remoto con empresas de Madrid, lo que te permite acceder a un profesional de calidad sin limitaciones geográficas. Nos comunicamos por videollamada, email y las herramientas que prefieras."
			}
		},
		{
			"@type": "Question",
			"name": "¿Cuánto tiempo tarda en estar lista una web para una empresa de Madrid?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "El plazo depende del proyecto: una landing page puede estar lista en 2-5 días, una web corporativa en 2-4 semanas, y una tienda online completa en 4-8 semanas. La rapidez también depende de tener el contenido preparado."
			}
		},
		{
			"@type": "Question",
			"name": "¿Es mejor contratar un freelance o una agencia en Madrid?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Para proyectos de hasta 5.000-8.000€, un freelance ofrece 30-50% mejor precio que una agencia madrileña, comunicación directa y mayor flexibilidad. Las agencias son más adecuadas para proyectos muy grandes (+15.000€) que requieren múltiples especialistas trabajando simultáneamente."
			}
		},
		{
			"@type": "Question",
			"name": "¿Haces factura oficial para empresas de Madrid?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Sí. Emito facturas oficiales para empresas y autónomos. Puedes desgravar el coste del desarrollo web como inversión empresarial."
			}
		}
	]
};

const localBusinessSchema = {
	"@context": "https://schema.org",
	"@type": "ProfessionalService",
	"name": "Ignacio Amat — Desarrollador Web Madrid",
	"url": `${baseUrl}${canonicalUrl}`,
	"image": `${baseUrl}/og-image.png`,
	"priceRange": "€€",
	"currenciesAccepted": "EUR",
	"serviceArea": { "@type": "City", "name": "Madrid" },
	"areaServed": { "@type": "City", "name": "Madrid" },
	"address": { "@type": "PostalAddress", "addressLocality": "Madrid", "addressRegion": "Comunidad de Madrid", "addressCountry": "ES" },
	"availableLanguage": ["Spanish", "English"],
	"sameAs": ["https://www.linkedin.com/in/ignacio-amat-urbina-789244223/", "https://github.com/ignaaaam"]
};

const allSchemas = [personSchema, serviceSchema, breadcrumbSchema, faqSchema, localBusinessSchema];

const alternateUrls = {
	es: canonicalUrl,
	en: "/en/web-developer-madrid"
};
---
<Layout
	title={title}
	description={description}
	lang="es"
	canonicalUrl={canonicalUrl}
	keywords={keywords}
	additionalSchemas={allSchemas}
	alternateUrls={alternateUrls}
>
	<Header />
	<main>
		<section class="py-12 sm:py-16 md:py-20 content-page">
			<div class="container px-4 sm:px-6 content-page__container">
				<div class="max-w-4xl mx-auto content-page__inner">
					<h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 sm:mb-6">Desarrollador Web Freelance para Empresas de Madrid</h1>

					<p class="text-lg sm:text-xl text-text-muted mb-6 sm:mb-8">
						¿Tu empresa de Madrid necesita una web profesional? Soy Ignacio Amat, desarrollador web freelance full stack.
						Trabajo en remoto con empresas de Madrid para crear páginas web que generan ventas, captación de leads y presencia online.
						Presupuesto gratuito y sin compromiso.
					</p>

					<div class="flex flex-wrap gap-3 mb-8">
						<a href="#contacto" class="btn-primary">Solicitar Presupuesto Gratuito</a>
						<a href="/desarrollador-web-barcelona" class="btn-secondary">Ver mi perfil completo</a>
					</div>

					<div class="prose prose-lg max-w-none content-page__prose mb-8 sm:mb-12">

						<h2 class="text-2xl sm:text-3xl font-bold mt-8 sm:mt-12 mb-4 sm:mb-6">Desarrollo web para empresas de Madrid</h2>
						<p class="text-base sm:text-lg mb-4">
							Las empresas de Madrid necesitan webs que funcionen: rápidas, bien posicionadas en Google y diseñadas para convertir visitantes en clientes.
							Como desarrollador web freelance, te ayudo a construir exactamente eso: una presencia digital que trabaja para tu negocio las 24 horas.
						</p>
						<p class="text-base sm:text-lg mb-4">
							Trabajo 100% en remoto, lo que me permite atender a empresas de Salamanca, Chamberí, Retiro, Las Tablas, Vallecas,
							Alcobendas, Getafe, Móstoles, Alcalá de Henares y cualquier otro punto de la Comunidad de Madrid —sin costes de desplazamiento ni recargos.
						</p>

						<h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">Servicios de desarrollo web que ofrezco a empresas de Madrid</h2>
						<div class="grid sm:grid-cols-2 gap-4 sm:gap-6 mb-8">
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg sm:text-xl font-bold mb-2">Landing Pages de Alta Conversión</h3>
								<p class="text-sm sm:text-base">Páginas diseñadas para captar leads y clientes. Ideales para campañas Google Ads, lanzamientos y servicios específicos. Desde 800€.</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg sm:text-xl font-bold mb-2">Web Corporativa Profesional</h3>
								<p class="text-sm sm:text-base">Presencia online completa para tu empresa: varios servicios, blog, formularios de contacto y SEO integrado. Desde 1.500€.</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg sm:text-xl font-bold mb-2">Tiendas Online (E-commerce)</h3>
								<p class="text-sm sm:text-base">Vende tus productos 24/7 con pasarelas de pago seguras (Stripe, Redsys, Bizum). Gestión sencilla de inventario. Desde 3.000€.</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg sm:text-xl font-bold mb-2">Aplicaciones Web a Medida</h3>
								<p class="text-sm sm:text-base">CRMs, portales de clientes, plataformas SaaS o cualquier herramienta digital que tu empresa necesite. Presupuesto personalizado.</p>
							</div>
						</div>

						<h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">¿Por qué contratar un desarrollador web freelance para tu empresa de Madrid?</h2>
						<ul class="list-disc pl-5 sm:pl-6 space-y-2 sm:space-y-3 mb-6 text-sm sm:text-base">
							<li><strong>30-50% más económico que una agencia de Madrid:</strong> Sin estructura de empresa, sin costes ocultos.</li>
							<li><strong>Comunicación directa:</strong> Hablas siempre conmigo, no con un account manager que traslada mensajes.</li>
							<li><strong>Tecnología moderna:</strong> React, Astro, Next.js, Node.js — tecnologías que garantizan velocidad y SEO.</li>
							<li><strong>SEO incluido desde el principio:</strong> Cada web que entrego está optimizada para posicionar en Google.</li>
							<li><strong>Factura oficial:</strong> Desgrávate el 100% de la inversión.</li>
							<li><strong>Garantía de satisfacción:</strong> Si no estás contento, seguimos trabajando hasta que lo estés.</li>
						</ul>

						<h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">Sectores con los que trabajo en Madrid</h2>
						<p class="mb-4">Tengo experiencia creando webs para empresas de múltiples sectores del ecosistema madrileño:</p>
						<div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-8">
							<div class="bg-secondary p-3 rounded-lg text-sm font-medium text-center">Consultorías y despachos</div>
							<div class="bg-secondary p-3 rounded-lg text-sm font-medium text-center">Startups tecnológicas</div>
							<div class="bg-secondary p-3 rounded-lg text-sm font-medium text-center">Despachos de abogados</div>
							<div class="bg-secondary p-3 rounded-lg text-sm font-medium text-center">Clínicas y salud</div>
							<div class="bg-secondary p-3 rounded-lg text-sm font-medium text-center">Restaurantes y hostelería</div>
							<div class="bg-secondary p-3 rounded-lg text-sm font-medium text-center">Inmobiliarias</div>
							<div class="bg-secondary p-3 rounded-lg text-sm font-medium text-center">E-commerce y retail</div>
							<div class="bg-secondary p-3 rounded-lg text-sm font-medium text-center">Academias y formación</div>
							<div class="bg-secondary p-3 rounded-lg text-sm font-medium text-center">Agencias de marketing</div>
						</div>

						<h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">Tecnologías que utilizo para webs de empresas madrileñas</h2>
						<ul class="list-disc pl-5 sm:pl-6 space-y-2 mb-6 text-sm sm:text-base">
							<li><strong>Frontend:</strong> HTML5, CSS3, JavaScript, React, Astro, Next.js, Tailwind CSS</li>
							<li><strong>Backend:</strong> Node.js, APIs REST, bases de datos SQL y NoSQL</li>
							<li><strong>E-commerce:</strong> Pasarelas de pago Stripe, Redsys (Servired), Bizum</li>
							<li><strong>SEO técnico:</strong> Core Web Vitals, schema markup, sitemap, hreflang</li>
							<li><strong>Rendimiento:</strong> Tiempo de carga &lt;1.5s, puntuación Lighthouse &gt;90</li>
						</ul>

						<h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">¿Cuánto cuesta una página web para una empresa de Madrid?</h2>
						<div class="space-y-4 mb-8">
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="font-bold text-base sm:text-lg mb-2">Landing Page</h3>
								<p class="text-sm sm:text-base text-text-muted">Desde <strong>800€ hasta 1.500€</strong>. Perfecta para campañas de captación, servicios concretos o lanzamientos. Lista en 2-5 días.</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="font-bold text-base sm:text-lg mb-2">Web Corporativa</h3>
								<p class="text-sm sm:text-base text-text-muted">Entre <strong>1.500€ y 3.500€</strong>. Hasta 8-10 páginas, blog, CMS y SEO avanzado. Lista en 2-4 semanas.</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="font-bold text-base sm:text-lg mb-2">Tienda Online</h3>
								<p class="text-sm sm:text-base text-text-muted">Entre <strong>3.000€ y 6.000€+</strong>. Catálogo completo, pasarela de pago y gestión de pedidos. Lista en 4-8 semanas.</p>
							</div>
						</div>

						<h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">Preguntas frecuentes sobre desarrollo web en Madrid</h2>
						<div class="space-y-4 mb-8">
							<div class="bg-secondary p-4 rounded-lg">
								<h3 class="font-bold text-base sm:text-lg mb-2">¿Cuánto cobra un desarrollador web freelance en Madrid?</h3>
								<p class="text-sm sm:text-base text-text-muted">Entre 800€ y 6.000€+ por proyecto según complejidad. Por hora, las tarifas rondan 45-85€/hora.</p>
							</div>
							<div class="bg-secondary p-4 rounded-lg">
								<h3 class="font-bold text-base sm:text-lg mb-2">¿Necesito estar en Madrid para contratarte?</h3>
								<p class="text-sm sm:text-base text-text-muted">No. Trabajo 100% en remoto. Nos comunicamos por videollamada y email, igual de eficaz que en persona.</p>
							</div>
							<div class="bg-secondary p-4 rounded-lg">
								<h3 class="font-bold text-base sm:text-lg mb-2">¿Cuánto tiempo tarda mi web?</h3>
								<p class="text-sm sm:text-base text-text-muted">Landing page: 2-5 días. Web corporativa: 2-4 semanas. Tienda online: 4-8 semanas.</p>
							</div>
							<div class="bg-secondary p-4 rounded-lg">
								<h3 class="font-bold text-base sm:text-lg mb-2">¿Emites factura oficial?</h3>
								<p class="text-sm sm:text-base text-text-muted">Sí. Factura oficial para empresas y autónomos. Desgravable al 100% como inversión empresarial.</p>
							</div>
						</div>

						<div class="bg-accent/10 p-4 sm:p-6 rounded-lg mt-8 mb-8">
							<h2 class="text-xl sm:text-2xl font-bold mb-3">¿Tu empresa de Madrid necesita una web profesional?</h2>
							<p class="mb-3 text-sm sm:text-base">
								Cuéntame tu proyecto y en 24 horas laborables te envío un presupuesto detallado y sin compromiso.
								Trabajo con empresas de Madrid, Comunidad de Madrid y toda España.
							</p>
							<p class="font-semibold text-sm sm:text-base">
								✅ Presupuesto gratuito en 24h<br/>
								✅ Sin compromiso<br/>
								✅ Facturación oficial<br/>
								✅ Garantía de satisfacción
							</p>
						</div>

						<h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">Otros servicios y ciudades</h2>
						<div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
							<a href="/desarrollador-web-espana" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
								<h3 class="font-bold mb-1">🇪🇸 Desarrollador Web España →</h3>
								<p class="text-sm text-text-muted">Servicio nacional para ciudades y pueblos de España.</p>
							</a>
							<a href="/desarrollador-web-barcelona" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
								<h3 class="font-bold mb-1">🏙️ Desarrollador Web Barcelona →</h3>
								<p class="text-sm text-text-muted">Mi perfil y servicios principales.</p>
							</a>
							<a href="/contratar-desarrollador-full-stack" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
								<h3 class="font-bold mb-1">💻 Contratar Desarrollador Full Stack →</h3>
								<p class="text-sm text-text-muted">Para proyectos complejos y aplicaciones web.</p>
							</a>
							<a href="/diseno-web-empresas" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
								<h3 class="font-bold mb-1">🎨 Diseño Web para Empresas →</h3>
								<p class="text-sm text-text-muted">Diseños profesionales orientados a conversión.</p>
							</a>
							<a href="/crear-pagina-web-barcelona" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
								<h3 class="font-bold mb-1">🚀 Crear Página Web →</h3>
								<p class="text-sm text-text-muted">Guía de precios y proceso de creación.</p>
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<Contact />
		<StickyCTA />
	</main>
</Layout>

<style>
	.text-text-muted {
		color: var(--color-text-muted);
	}

	.bg-secondary {
		background-color: var(--color-secondary);
	}

	.prose h2, .prose h3, .prose h4 {
		color: var(--color-text);
	}

	.prose p, .prose li {
		color: var(--color-text);
		line-height: 1.8;
	}
</style>
