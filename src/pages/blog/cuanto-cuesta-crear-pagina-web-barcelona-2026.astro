---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Contact from '../../components/Contact.astro';
import StickyCTA from '../../components/StickyGTA.astro';

const baseUrl = 'https://ignacioamatweb.com';
const title = '¿Cuánto Cuesta Crear una Página Web en Barcelona? [Guía 2026]';
const description = 'Descubre los precios reales para crear una página web en Barcelona en 2026. Desglose completo de landing pages, webs corporativas, ecommerce y proyectos a medida.';
const canonicalUrl = '/blog/cuanto-cuesta-crear-pagina-web-barcelona-2026';
const publishedDate = '2026-01-14';

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  image: `${baseUrl}/images/og-image.png`,
  author: {
    '@type': 'Person',
    name: 'Ignacio Amat',
    url: baseUrl,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Ignacio Amat - Desarrollo Web',
    logo: {
      '@type': 'ImageObject',
      url: `${baseUrl}/images/og-image.png`,
    },
  },
  datePublished: publishedDate,
  dateModified: '2026-03-09',
  isPartOf: {
    '@type': 'Blog',
    name: 'Blog de Ignacio Amat',
    url: `${baseUrl}/blog`,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${baseUrl}${canonicalUrl}`,
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '¿Cuánto cuesta una landing page en Barcelona?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Una landing page profesional suele costar entre 800€ y 1.500€, según diseño, copy, integraciones y nivel de optimización.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cuánto cuesta una web corporativa en Barcelona?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Una web corporativa suele situarse entre 1.500€ y 3.500€, dependiendo del número de páginas, complejidad del diseño, estructura de contenidos y requisitos técnicos.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Qué factores afectan más al precio de una web?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'El alcance, la complejidad del diseño, las integraciones, el contenido disponible, el SEO técnico, los plazos y el mantenimiento posterior son los factores que más afectan al presupuesto.',
      },
    },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Inicio',
      item: baseUrl,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Blog',
      item: `${baseUrl}/blog`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: 'Cuánto cuesta crear una página web en Barcelona',
      item: `${baseUrl}${canonicalUrl}`,
    },
  ],
};

const allSchemas = [articleSchema, faqSchema, breadcrumbSchema];
---

<Layout
  title={title}
  description={description}
  lang="es"
  canonicalUrl={canonicalUrl}
  type="article"
  publishedDate={publishedDate}
  additionalSchemas={allSchemas}
  keywords={['precio pagina web Barcelona', 'cuanto cuesta crear web', 'presupuesto web Barcelona', 'precio landing page', 'precio web corporativa', 'coste ecommerce']}
>
  <Header />
  <main>
    <article class="section">
      <div class="container article-layout">
        <header class="article-hero surface-card" data-sr>
          <nav class="article-breadcrumbs" aria-label="Breadcrumb">
            <a href="/">Inicio</a>
            <span>/</span>
            <a href="/blog">Blog</a>
            <span>/</span>
            <span>Precios web Barcelona</span>
          </nav>

          <p class="section-eyebrow">Precios</p>
          <h1>¿Cuánto Cuesta Crear una Página Web en Barcelona? [Guía 2026]</h1>
          <div class="article-meta">
            <span>Ignacio Amat</span>
            <span>14 de enero de 2026</span>
            <span>12 min lectura</span>
          </div>
          <p class="article-intro">Si estás comparando presupuestos para una web en Barcelona, el problema no suele ser “cuánto cuesta una web” en abstracto, sino qué está realmente incluido, qué nivel de calidad necesitas y qué parte del presupuesto impacta de verdad en resultados, mantenimiento y percepción de marca.</p>
        </header>

        <div class="article-shell surface-card" data-sr>
          <div class="article-content">
            <div class="toc-card">
              <h2>Contenido de esta guía</h2>
              <ol>
                <li><a href="#resumen">Resumen rápido de rangos</a></li>
                <li><a href="#landing-page">Precio de una landing page</a></li>
                <li><a href="#web-corporativa">Precio de una web corporativa</a></li>
                <li><a href="#tienda-online">Precio de una tienda online</a></li>
                <li><a href="#factores">Factores que cambian el presupuesto</a></li>
                <li><a href="#freelance-vs-agencia">Freelance vs agencia</a></li>
                <li><a href="#costes-ocultos">Costes adicionales</a></li>
                <li><a href="#como-ahorrar">Cómo ahorrar sin cargarte el proyecto</a></li>
              </ol>
            </div>

            <section id="resumen">
              <h2>Resumen rápido: rangos habituales en 2026</h2>
              <p>Estos rangos sirven para orientarte. Un presupuesto serio siempre dependerá del alcance, del contenido disponible, de la complejidad técnica y del nivel de acompañamiento que necesites.</p>
              <table>
                <thead>
                  <tr>
                    <th>Tipo de proyecto</th>
                    <th>Rango habitual freelance</th>
                    <th>Referencia agencia</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td>Landing page</td>
                    <td>800€ - 1.500€</td>
                    <td>1.500€ - 3.000€</td>
                  </tr>
                  <tr>
                    <td>Web corporativa</td>
                    <td>1.500€ - 3.500€</td>
                    <td>3.000€ - 8.000€</td>
                  </tr>
                  <tr>
                    <td>Tienda online</td>
                    <td>3.000€ - 6.000€+</td>
                    <td>5.000€ - 15.000€+</td>
                  </tr>
                  <tr>
                    <td>App web o MVP</td>
                    <td>5.000€ - 15.000€+</td>
                    <td>15.000€ - 50.000€+</td>
                  </tr>
                </tbody>
              </table>
            </section>

            <section id="landing-page">
              <h2>¿Cuánto cuesta una landing page en Barcelona?</h2>
              <p>Una landing page profesional no es simplemente “una página”. Suele incluir estructura, copy guiado, diseño responsive, formularios, medición y una jerarquía pensada para una sola conversión principal.</p>
              <div class="price-card">
                <h3>Referencia razonable: 800€ a 1.500€</h3>
                <p>Encaja cuando necesitas lanzar una campaña, presentar un servicio concreto o mejorar la captación de leads con una sola pieza enfocada.</p>
                <ul>
                  <li>Diseño y estructura orientados a conversión</li>
                  <li>Formulario o flujo de captación</li>
                  <li>Base SEO y rendimiento</li>
                  <li>Adaptación responsive real</li>
                </ul>
              </div>
            </section>

            <section id="web-corporativa">
              <h2>¿Cuánto cuesta una web corporativa en Barcelona?</h2>
              <p>Cuando una empresa necesita explicar servicios, transmitir confianza, tener una estructura clara y dejar una mejor primera impresión, el proyecto ya no es solo “montar páginas”, sino ordenar el discurso comercial y la experiencia completa.</p>
              <div class="price-card">
                <h3>Referencia razonable: 1.500€ a 3.500€</h3>
                <p>Es el rango más común para webs de empresa con varias páginas, servicios, formularios, blog o recursos y una base más seria para SEO.</p>
                <ul>
                  <li>Arquitectura de contenidos</li>
                  <li>Páginas clave de servicios o negocio</li>
                  <li>Bloques de credibilidad y captación</li>
                  <li>Mejor base para crecer después</li>
                </ul>
              </div>
            </section>

            <section id="tienda-online">
              <h2>¿Cuánto cuesta una tienda online?</h2>
              <p>El ecommerce añade una capa operativa mucho más sensible: catálogo, pagos, pedidos, panel, incidencias y mantenimiento. Por eso el presupuesto suele subir de forma clara respecto a una web corporativa.</p>
              <div class="price-card">
                <h3>Referencia razonable: 3.000€ a 6.000€+</h3>
                <p>Sube en función del número de productos, variantes, integraciones con ERP o TPV, automatizaciones y procesos internos.</p>
                <ul>
                  <li>Catálogo y carrito</li>
                  <li>Pasarela de pago</li>
                  <li>Gestión de pedidos e inventario</li>
                  <li>SEO base para ecommerce</li>
                </ul>
              </div>
            </section>

            <section id="factores">
              <h2>Qué cambia realmente el presupuesto</h2>
              <div class="factor-grid">
                <div class="factor-card">
                  <h3>Alcance real</h3>
                  <p>Número de páginas, módulos, integraciones y complejidad de flujos.</p>
                </div>
                <div class="factor-card">
                  <h3>Diseño</h3>
                  <p>No cuesta lo mismo adaptar una base simple que diseñar una experiencia más editorial y trabajada.</p>
                </div>
                <div class="factor-card">
                  <h3>Contenido</h3>
                  <p>Tener textos y materiales listos reduce mucho fricción, tiempo y cambios.</p>
                </div>
                <div class="factor-card">
                  <h3>Integraciones</h3>
                  <p>CRMs, pagos, automatizaciones, reservas o sistemas externos suelen mover bastante el presupuesto.</p>
                </div>
                <div class="factor-card">
                  <h3>SEO y rendimiento</h3>
                  <p>Cuando se trabaja bien desde el inicio, requiere criterio y tiempo, no solo “activar plugins”.</p>
                </div>
                <div class="factor-card">
                  <h3>Urgencia</h3>
                  <p>Los plazos muy ajustados suelen introducir sobrecoste y más riesgo de mala ejecución.</p>
                </div>
              </div>
            </section>

            <section id="freelance-vs-agencia">
              <h2>Freelance vs agencia: qué suele salir más a cuenta</h2>
              <div class="compare-grid">
                <div class="compare-card">
                  <h3>Freelance</h3>
                  <ul>
                    <li>Relación directa con quien ejecuta</li>
                    <li>Menos estructura y menos coste</li>
                    <li>Más agilidad en cambios razonables</li>
                    <li>Muy buena opción para proyectos medianos</li>
                  </ul>
                </div>
                <div class="compare-card">
                  <h3>Agencia</h3>
                  <ul>
                    <li>Mejor encaje en proyectos grandes o con varios perfiles</li>
                    <li>Más capacidad de coordinación corporativa</li>
                    <li>Mayor coste estructural</li>
                    <li>Más sentido cuando el alcance lo justifica</li>
                  </ul>
                </div>
              </div>
            </section>

            <section id="costes-ocultos">
              <h2>Costes adicionales que conviene prever</h2>
              <ul>
                <li><strong>Dominio:</strong> coste anual del dominio principal.</li>
                <li><strong>Hosting:</strong> depende del tráfico, stack y soporte incluido.</li>
                <li><strong>Email profesional:</strong> Google Workspace, Microsoft 365 u otras soluciones.</li>
                <li><strong>Mantenimiento:</strong> cambios, revisiones, actualizaciones y soporte posterior.</li>
                <li><strong>Servicios externos:</strong> CRMs, calendarios, pasarelas, automatizaciones o herramientas premium.</li>
              </ul>
            </section>

            <section id="como-ahorrar">
              <h2>Cómo ahorrar sin cargarte la calidad</h2>
              <ol>
                <li>Define qué necesitas ahora y qué puede esperar a una segunda fase.</li>
                <li>Llega con el contenido lo más claro posible.</li>
                <li>Evita urgencias artificiales si no son realmente necesarias.</li>
                <li>Compara alcance, no solo cifras.</li>
                <li>Prioriza una base sólida frente a la falsa economía de la plantilla barata.</li>
              </ol>
            </section>

            <div class="article-note">
              <h2>¿Quieres una cifra más realista para tu caso?</h2>
              <p>Si me cuentas el tipo de web, objetivo, contenido disponible y nivel de urgencia, puedo darte una primera orientación útil antes de pasar a presupuesto.</p>
              <div class="article-note__actions">
                <a href="/#contacto" class="btn-primary">Solicitar orientación</a>
                <a href="/servicios" class="btn-secondary">Ver servicios</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </article>

    <Contact />
    <StickyCTA />
  </main>
</Layout>

<style>
  .article-layout {
    display: grid;
    gap: 1rem;
    max-width: 920px;
  }

  .article-hero,
  .article-shell {
    padding: 1.45rem;
  }

  .article-breadcrumbs,
  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    color: var(--color-text-muted);
    font-size: 0.94rem;
  }

  .article-breadcrumbs {
    margin-bottom: 1rem;
  }

  .article-hero h1 {
    max-width: 16ch;
    margin-bottom: 1rem;
    font-size: clamp(2.5rem, 6vw, 4.8rem);
  }

  .article-intro {
    max-width: 66ch;
    margin-top: 1rem;
    color: var(--color-text-muted);
    font-size: 1.08rem;
    line-height: 1.85;
  }

  .toc-card,
  .price-card,
  .factor-card,
  .compare-card,
  .article-note {
    padding: 1rem 1.05rem;
    border: 1px solid rgba(74, 54, 41, 0.1);
    border-radius: 1rem;
    background: rgba(255, 250, 244, 0.88);
  }

  .toc-card ol,
  .price-card ul,
  .compare-card ul {
    margin-top: 0.85rem;
  }

  .factor-grid,
  .compare-grid {
    display: grid;
    gap: 0.9rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: 1rem;
  }

  .article-note {
    margin-top: 2rem;
    background: linear-gradient(180deg, rgba(184, 104, 54, 0.08), rgba(33, 68, 63, 0.05));
  }

  .article-note__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1rem;
  }

  @media (max-width: 720px) {
    .article-hero,
    .article-shell {
      padding: 1.2rem;
    }

    .article-hero h1 {
      max-width: none;
    }

    .factor-grid,
    .compare-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
