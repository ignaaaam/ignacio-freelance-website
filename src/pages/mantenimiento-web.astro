---
import MarketingContentPage from '../components/MarketingContentPage.astro';

const baseUrl = 'https://www.ignacioamatweb.com';
const title = "Mantenimiento Web para Empresas | Ignacio Amat";
const description = "Mantenimiento web para empresas que necesitan una web segura, actualizada y útil después del lanzamiento. Soporte, actualizaciones, backups y mejoras desde 150 EUR/mes.";
const canonicalUrl = "/mantenimiento-web";
const keywords = ["mantenimiento web", "mantenimiento página web", "mantenimiento web profesional", "soporte web", "mantenimiento web empresas", "plan mantenimiento web"];

const serviceSchema = {
	"@context": "https://schema.org",
	"@type": "Service",
	"serviceType": "Mantenimiento Web Profesional",
	"provider": {
		"@type": "ProfessionalService",
		"name": "Ignacio Amat - Desarrollador Web",
		"url": baseUrl
	},
	"areaServed": {
		"@type": "Country",
		"name": "España"
	},
	"description": "Servicio de mantenimiento web para empresas. Actualizaciones, copias de seguridad, monitorización, parches de seguridad y soporte técnico.",
	"offers": {
		"@type": "Offer",
		"priceRange": "Desde 150 EUR/mes",
		"priceCurrency": "EUR"
	}
};

const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": [
		{
			"@type": "Question",
			"name": "¿Qué incluye un plan de mantenimiento web profesional?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Un plan de mantenimiento web incluye actualizaciones periódicas, copias de seguridad automatizadas, monitorización, parches de seguridad y soporte técnico. Según el plan, puede añadir revisiones SEO, informes y horas de desarrollo."
			}
		},
		{
			"@type": "Question",
			"name": "¿Por qué necesita mi empresa un plan de mantenimiento web?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Sin mantenimiento regular, la web se vuelve más vulnerable, más lenta y más difícil de corregir cuando aparece un problema. El mantenimiento protege la inversión y evita que cada incidencia se convierta en una urgencia."
			}
		},
		{
			"@type": "Question",
			"name": "¿Cuánto cuesta el mantenimiento de una página web?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Los planes de mantenimiento parten de 150 EUR/mes. El precio depende del stack, del volumen de cambios y del nivel de soporte que necesite tu web."
			}
		},
		{
			"@type": "Question",
			"name": "¿Con qué frecuencia se realizan las copias de seguridad?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Todos los planes incluyen copias de seguridad automatizadas. La frecuencia y la retención se ajustan al tipo de proyecto y al nivel de soporte contratado."
			}
		},
		{
			"@type": "Question",
			"name": "¿Qué pasa si mi web sufre un problema o cae?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "La web se monitoriza y, si aparece una caída o una incidencia crítica, actúo según la prioridad. Como referencia, el tiempo de respuesta para incidencias prioritarias es de 24 horas laborables en Básico, 8 en Profesional y 4 en Premium."
			}
		},
		{
			"@type": "Question",
			"name": "¿Puedo contratar mantenimiento para cualquier tipo de web?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Sí, siempre que el stack permita trabajar con seguridad. Antes de empezar reviso la base técnica y te digo si hay limitaciones o deuda técnica relevante."
			}
		}
	]
};

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{
			"@type": "ListItem",
			"position": 1,
			"name": "Inicio",
			"item": baseUrl
		},
		{
			"@type": "ListItem",
			"position": 2,
			"name": "Mantenimiento Web",
			"item": `${baseUrl}${canonicalUrl}`
		}
	]
};

const allSchemas = [serviceSchema, faqSchema, breadcrumbSchema];

const alternateUrls = {
	es: canonicalUrl,
	en: "/en/website-maintenance"
};

const facts = [
	{ label: 'Modelo', value: 'Soporte mensual con actualizaciones, backups, monitorización y pequeñas mejoras.' },
	{ label: 'Desde', value: '150 EUR/mes según complejidad y nivel de soporte.' },
	{ label: 'Ideal para', value: 'Empresas que quieren una web fiable sin montar equipo técnico interno.' },
];
---
<MarketingContentPage
	title={title}
	description={description}
	lang="es"
	canonicalUrl={canonicalUrl}
	keywords={keywords}
	additionalSchemas={allSchemas}
	alternateUrls={alternateUrls}
	badge="Mantenimiento web"
	pageTitle="Mantenimiento web para empresas que no quieren esperar a que la web falle"
	lead="Mantengo webs de negocio actualizadas, respaldadas y vigiladas para que sigan siendo seguras, rápidas y útiles, sin convertir cada incidencia en una urgencia."
	primaryCta={{ label: 'Cuéntame tu proyecto', href: '#contacto' }}
	secondaryCta={{ label: 'Ver servicios', href: '/servicios' }}
	facts={facts}
>
					<div class="prose prose-lg max-w-none">
						<h2 class="text-2xl sm:text-3xl font-bold mt-8 mb-4">Por qué importa el mantenimiento web</h2>
						<div class="grid sm:grid-cols-3 gap-4 sm:gap-6 mb-8">
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg font-bold mb-2">Seguridad</h3>
								<p class="text-sm sm:text-base">Actualizaciones, parches y revisiones para no dejar abierta una puerta innecesaria.</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg font-bold mb-2">Rendimiento</h3>
								<p class="text-sm sm:text-base">La web se degrada con el tiempo. Reviso carga, dependencias y puntos que empiezan a frenar la experiencia.</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg font-bold mb-2">Continuidad</h3>
								<p class="text-sm sm:text-base">Backups, monitorización y respuesta cuando hay incidencias para no depender de improvisar.</p>
							</div>
						</div>

						<h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">Qué suelo incluir</h2>
						<ul class="list-disc pl-5 sm:pl-6 space-y-3 mb-8 text-sm sm:text-base">
							<li><strong>Actualizaciones:</strong> CMS, plugins, dependencias o librerías del proyecto cuando aplica.</li>
							<li><strong>Backups:</strong> copias automatizadas y revisión de que la restauración sea viable.</li>
							<li><strong>Monitorización:</strong> uptime, errores, SSL y señales básicas de rendimiento.</li>
							<li><strong>Seguridad:</strong> aplicación de parches, revisión de vulnerabilidades y endurecimiento básico.</li>
							<li><strong>Soporte:</strong> corrección de incidencias, pequeños cambios y canal directo para prioridades reales.</li>
						</ul>

						<h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">Planes orientativos</h2>
						<div class="space-y-4 mb-8">
							<div class="bg-secondary p-4 sm:p-6 rounded-lg border-l-4 border-accent">
								<h3 class="text-lg sm:text-xl font-bold mb-2">Básico — 150 EUR/mes</h3>
								<ul class="text-sm sm:text-base space-y-1 text-text-muted">
									<li>Actualizaciones y parches de seguridad</li>
									<li>Backups automatizados</li>
									<li>Monitorización 24/7</li>
									<li>Soporte por email</li>
								</ul>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg border-l-4 border-green-500">
								<h3 class="text-lg sm:text-xl font-bold mb-2">Profesional — 300 EUR/mes</h3>
								<ul class="text-sm sm:text-base space-y-1 text-text-muted">
									<li>Todo lo del plan Básico</li>
									<li>Revisión de rendimiento y SEO técnico</li>
									<li>Soporte prioritario</li>
									<li>Informe mensual y recomendaciones</li>
									<li>Pequeños cambios incluidos</li>
								</ul>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg border-l-4 border-purple-500">
								<h3 class="text-lg sm:text-xl font-bold mb-2">Premium — 500 EUR/mes</h3>
								<ul class="text-sm sm:text-base space-y-1 text-text-muted">
									<li>Todo lo del plan Profesional</li>
									<li>Horas de desarrollo incluidas</li>
									<li>Soporte más rápido</li>
									<li>Seguimiento más profundo de métricas</li>
									<li>Ideal para sites críticos o con evolución continua</li>
								</ul>
							</div>
						</div>
						<p class="text-sm text-text-muted mb-8">
							Sin permanencia mínima. Si la web necesita algo fuera de plan, lo vemos antes de tocar nada.
						</p>

						<h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-4">Cómo funciona</h2>
						<ol class="list-decimal pl-5 sm:pl-6 space-y-3 mb-6 text-sm sm:text-base">
							<li><strong>Auditoría inicial:</strong> reviso el estado actual de la web, riesgos, dependencias y prioridades.</li>
							<li><strong>Configuración:</strong> dejo montados backups, alertas y la base de trabajo.</li>
							<li><strong>Mantenimiento mensual:</strong> aplico actualizaciones, revisiones y correcciones según el plan.</li>
							<li><strong>Canal directo:</strong> si hay incidencias o cambios, hablas conmigo y no con una cola de tickets.</li>
						</ol>
						<p class="text-base sm:text-lg mb-8">
							Referencia de respuesta: 24h en Básico, 8h en Profesional y 4h en Premium para incidencias prioritarias.
						</p>

						<h2 class="text-2xl sm:text-3xl font-bold mt-10 mb-6">Preguntas frecuentes</h2>
						<div class="space-y-4 mb-8">
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg sm:text-xl font-bold mb-2">¿Qué incluye un plan de mantenimiento web profesional?</h3>
								<p class="text-sm sm:text-base">Actualizaciones, backups, monitorización, parches de seguridad y soporte. Según el plan, también puede incluir revisiones SEO, informes y horas de desarrollo.</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg sm:text-xl font-bold mb-2">¿Por qué necesita mi empresa un plan de mantenimiento web?</h3>
								<p class="text-sm sm:text-base">Porque una web sin seguimiento se vuelve más vulnerable, más lenta y más difícil de corregir cuando aparece un problema. El mantenimiento evita que todo se convierta en urgencia.</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg sm:text-xl font-bold mb-2">¿Cuánto cuesta el mantenimiento de una página web?</h3>
								<p class="text-sm sm:text-base">Los planes parten de 150 EUR/mes. El precio final depende del stack, del volumen de cambios y del nivel de soporte que necesites.</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg sm:text-xl font-bold mb-2">¿Qué pasa si mi web sufre un problema o cae?</h3>
								<p class="text-sm sm:text-base">La monitorización lo detecta, reviso la incidencia y actúo según el nivel de prioridad. Si hace falta, restauro una copia reciente para reducir el impacto.</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg sm:text-xl font-bold mb-2">¿Puedo contratar mantenimiento para cualquier tipo de web?</h3>
								<p class="text-sm sm:text-base">Sí, siempre que el stack permita trabajar con seguridad. Antes de empezar reviso el proyecto y te digo si hay limitaciones o deuda técnica relevante.</p>
							</div>
						</div>

						<div class="bg-accent/10 p-4 sm:p-6 rounded-lg mt-8 mb-4">
							<h2 class="text-xl sm:text-2xl font-bold mb-3">¿Tu web necesita mantenimiento de verdad y no solo “arreglos cuando falle”?</h2>
							<p class="mb-3 text-sm sm:text-base">
								Cuéntame qué stack usas, qué tipo de soporte necesitas y si la web es crítica para el negocio. Con eso te digo qué plan tiene sentido o si antes conviene una auditoría.
							</p>
							<p class="font-semibold text-sm sm:text-base">
								Auditoría inicial incluida<br/>
								Sin permanencia mínima<br/>
								Facturación oficial<br/>
								Comunicación directa
							</p>
						</div>
					</div>
</MarketingContentPage>
