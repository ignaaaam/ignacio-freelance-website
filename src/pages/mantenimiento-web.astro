---
import MarketingContentPage from '../components/MarketingContentPage.astro';

const baseUrl = 'https://ignacioamatweb.com';
const title = "Mantenimiento Web Profesional para Empresas | Ignacio Amat";
const description = "Servicio de mantenimiento web profesional para empresas. Actualizaciones, copias de seguridad, monitorización y soporte técnico. Planes desde 150€/mes. Presupuesto gratuito.";
const canonicalUrl = "/mantenimiento-web";
const keywords = ["mantenimiento web", "mantenimiento página web", "mantenimiento web profesional", "soporte web", "mantenimiento web empresas", "plan mantenimiento web"];

const serviceSchema = {
	"@context": "https://schema.org",
	"@type": "Service",
	"serviceType": "Mantenimiento Web Profesional",
	"provider": {
		"@type": "ProfessionalService",
		"name": "Ignacio Amat - Desarrollador Web",
		"url": baseUrl
	},
	"areaServed": {
		"@type": "Country",
		"name": "España"
	},
	"description": "Servicio de mantenimiento web profesional para empresas. Actualizaciones de software, copias de seguridad automatizadas, monitorización 24/7, parches de seguridad y soporte técnico prioritario.",
	"offers": {
		"@type": "Offer",
		"priceRange": "From €150/month",
		"priceCurrency": "EUR"
	}
};

const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": [
		{
			"@type": "Question",
			"name": "¿Qué incluye un plan de mantenimiento web profesional?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Un plan de mantenimiento web profesional incluye actualizaciones periódicas del CMS, plugins y dependencias, copias de seguridad automatizadas diarias o semanales, monitorización de disponibilidad y rendimiento, aplicación de parches de seguridad y soporte técnico. Dependiendo del plan, también puede incluir monitorización SEO, horas de desarrollo incluidas, informes mensuales y pruebas A/B."
			}
		},
		{
			"@type": "Question",
			"name": "¿Por qué necesita mi empresa un plan de mantenimiento web?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Sin mantenimiento regular, tu web se vuelve vulnerable a ataques, pierde velocidad de carga y puede caer en posiciones de Google. Las estadísticas muestran que el 43% de los ciberataques se dirigen a pequeñas y medianas empresas, y un sitio web lento puede perder hasta el 40% de sus visitantes. El mantenimiento profesional protege tu inversión y asegura que tu web siga generando resultados."
			}
		},
		{
			"@type": "Question",
			"name": "¿Cuánto cuesta el mantenimiento de una página web?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Los planes de mantenimiento web profesional empiezan desde 150€/mes para el plan Básico (actualizaciones, backups y monitorización), 300€/mes para el plan Profesional (incluye monitorización SEO, soporte prioritario e informe mensual) y 500€/mes para el plan Premium (incluye horas de desarrollo, tests A/B y analítica avanzada). El precio exacto depende de la complejidad de tu web y las necesidades específicas de tu negocio."
			}
		},
		{
			"@type": "Question",
			"name": "¿Con qué frecuencia se realizan las copias de seguridad?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "En todos los planes realizamos copias de seguridad automatizadas. El plan Básico incluye backups semanales almacenados durante 30 días. El plan Profesional incluye backups diarios con retención de 60 días. El plan Premium incluye backups diarios con retención de 90 días y una copia adicional mensual almacenada durante 12 meses. Todas las copias se guardan en servidores externos para máxima seguridad."
			}
		},
		{
			"@type": "Question",
			"name": "¿Qué pasa si mi web sufre un problema o cae?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Monitorizo tu web las 24 horas del día, 7 días a la semana. Si tu web experimenta una caída o un error crítico, recibirás una alerta inmediata y comenzaré a trabajar en la resolución. El tiempo de respuesta garantizado varía según el plan: 24 horas para el plan Básico, 8 horas para el plan Profesional y 4 horas para el plan Premium. En caso de emergencia, restauro la última copia de seguridad disponible para minimizar el tiempo de inactividad."
			}
		},
		{
			"@type": "Question",
			"name": "¿Puedo contratar mantenimiento para cualquier tipo de web?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Sí, ofrezco mantenimiento web para todo tipo de sitios: WordPress, WooCommerce, sitios en Astro, webs en React o Next.js, y cualquier otra tecnología web moderna. Tanto si tienes una web corporativa, una tienda online, una landing page o un portal con funcionalidades avanzadas, puedo encargarse del mantenimiento y soporte técnico. Contacta y evaluamos juntos el plan más adecuado para tu caso."
			}
		}
	]
};

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{
			"@type": "ListItem",
			"position": 1,
			"name": "Inicio",
			"item": baseUrl
		},
		{
			"@type": "ListItem",
			"position": 2,
			"name": "Mantenimiento Web",
			"item": `${baseUrl}${canonicalUrl}`
		}
	]
};

const allSchemas = [serviceSchema, faqSchema, breadcrumbSchema];

const alternateUrls = {
	es: canonicalUrl,
	en: "/en/website-maintenance"
};

const facts = [
	{ label: 'Modelo', value: 'Soporte mensual con actualizaciones, seguridad, monitorizacion y mejoras.' },
	{ label: 'Desde', value: '150 EUR al mes para una base tecnica bien resuelta.' },
	{ label: 'Ideal para', value: 'Empresas que no quieren dejar su web abandonada despues del lanzamiento.' },
];
---
<MarketingContentPage
	title={title}
	description={description}
	lang="es"
	canonicalUrl={canonicalUrl}
	keywords={keywords}
	additionalSchemas={allSchemas}
	alternateUrls={alternateUrls}
	badge="Servicio de mantenimiento"
	pageTitle="Mantenimiento Web Profesional para Empresas"
	lead="Una web sin mantenimiento se degrada: pierde seguridad, rendimiento y capacidad comercial. Ofrezco soporte mensual para que siga funcionando bien, se mantenga actualizada y no se convierta en un problema tecnico para tu negocio."
	primaryCta={{ label: 'Solicitar presupuesto gratuito', href: '#contacto' }}
	secondaryCta={{ label: 'Ver servicios', href: '/servicios' }}
	facts={facts}
>
					<div class="prose prose-lg max-w-none">

						<!-- WHY MAINTENANCE MATTERS -->
						<h2 class="text-2xl sm:text-3xl font-bold mt-8 sm:mt-12 mb-4 sm:mb-6">
							¿Por qué es imprescindible el mantenimiento web para tu empresa?
						</h2>

						<p class="text-base sm:text-lg mb-4">
							Una web sin mantenimiento regular es como un local comercial que nadie limpia ni actualiza.
							Los plugins desactualizados abren brechas de seguridad, el software obsoleto ralentiza la carga
							de páginas y los errores acumulados dañan tu posicionamiento en Google. El impacto en el negocio
							es directo y medible.
						</p>

						<p class="text-base sm:text-lg mb-6">
							Según datos del sector, el <strong>43% de los ciberataques se dirige a pequeñas y medianas empresas</strong>,
							y un sitio web que tarda más de 3 segundos en cargar pierde hasta el <strong>40% de sus visitantes</strong>
							antes de que lleguen a ver tu oferta. El mantenimiento web profesional no es un gasto — es la
							protección de tu inversión y la garantía de que tu web sigue generando clientes.
						</p>

						<h3 class="text-xl sm:text-2xl font-bold mt-6 sm:mt-8 mb-3 sm:mb-4">Los tres pilares del mantenimiento web:</h3>
						<div class="grid sm:grid-cols-3 gap-4 sm:gap-6 mb-6 sm:mb-8">
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h4 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3">Seguridad</h4>
								<p class="text-sm sm:text-base">Parches de seguridad aplicados de forma proactiva, monitorización de amenazas y protección contra ataques de fuerza bruta, malware e inyecciones SQL.</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h4 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3">Rendimiento</h4>
								<p class="text-sm sm:text-base">Optimización de velocidad de carga, revisión de Core Web Vitals, limpieza de base de datos y actualizaciones de dependencias para mantener la web ágil.</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h4 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3">SEO Técnico</h4>
								<p class="text-sm sm:text-base">Revisión de errores de rastreo, corrección de enlaces rotos, monitorización de posiciones clave y alertas ante caídas de tráfico orgánico.</p>
							</div>
						</div>

						<!-- WHAT'S INCLUDED -->
						<h2 class="text-2xl sm:text-3xl font-bold mt-8 sm:mt-12 mb-4 sm:mb-6">
							¿Qué incluye el servicio de mantenimiento web?
						</h2>

						<p class="text-base sm:text-lg mb-4">
							El mantenimiento de una página web abarca un conjunto de tareas técnicas recurrentes que mantienen
							el sitio en perfecto estado de funcionamiento. No se trata solo de "tocar algo de vez en cuando":
							es un proceso sistemático que cubre todos los aspectos críticos de tu presencia online.
						</p>

						<h3 class="text-xl sm:text-2xl font-bold mt-6 sm:mt-8 mb-3 sm:mb-4">Actualizaciones de software:</h3>
						<ul class="list-disc pl-5 sm:pl-6 space-y-2 sm:space-y-3 mb-4 sm:mb-6 text-sm sm:text-base">
							<li><strong>CMS y núcleo:</strong> Actualización del sistema de gestión de contenidos (WordPress, etc.) a la última versión estable</li>
							<li><strong>Plugins y extensiones:</strong> Revisión y actualización de todos los plugins instalados, comprobando la compatibilidad antes de aplicar cambios</li>
							<li><strong>Temas y plantillas:</strong> Actualización controlada de los temas activos sin romper el diseño personalizado</li>
							<li><strong>Dependencias de desarrollo:</strong> Actualización de librerías y paquetes en proyectos con código a medida (React, Astro, Node.js)</li>
						</ul>

						<h3 class="text-xl sm:text-2xl font-bold mt-6 sm:mt-8 mb-3 sm:mb-4">Copias de seguridad:</h3>
						<ul class="list-disc pl-5 sm:pl-6 space-y-2 sm:space-y-3 mb-4 sm:mb-6 text-sm sm:text-base">
							<li><strong>Backups automatizados:</strong> Copias de seguridad programadas de archivos y base de datos sin intervención manual</li>
							<li><strong>Almacenamiento externo:</strong> Guardado en servidores externos independientes del hosting principal (protección ante fallos del servidor)</li>
							<li><strong>Retención y versionado:</strong> Historial de copias para poder restaurar a cualquier punto anterior en caso de necesidad</li>
							<li><strong>Pruebas de restauración:</strong> Verificación periódica de que los backups son funcionales y restaurables</li>
						</ul>

						<h3 class="text-xl sm:text-2xl font-bold mt-6 sm:mt-8 mb-3 sm:mb-4">Monitorización continua:</h3>
						<ul class="list-disc pl-5 sm:pl-6 space-y-2 sm:space-y-3 mb-4 sm:mb-6 text-sm sm:text-base">
							<li><strong>Uptime 24/7:</strong> Alertas inmediatas si tu web cae o experimenta errores de servidor</li>
							<li><strong>Velocidad de carga:</strong> Seguimiento del tiempo de respuesta y Core Web Vitals (LCP, CLS, FID)</li>
							<li><strong>Certificado SSL:</strong> Control de la validez del certificado HTTPS y renovación automática</li>
							<li><strong>Errores 404 y redirecciones:</strong> Detección y corrección de enlaces rotos que dañan la experiencia de usuario y el SEO</li>
						</ul>

						<h3 class="text-xl sm:text-2xl font-bold mt-6 sm:mt-8 mb-3 sm:mb-4">Seguridad activa:</h3>
						<ul class="list-disc pl-5 sm:pl-6 space-y-2 sm:space-y-3 mb-4 sm:mb-6 text-sm sm:text-base">
							<li><strong>Escaneo de malware:</strong> Análisis periódico del código del sitio en busca de archivos maliciosos o código inyectado</li>
							<li><strong>Parches de seguridad:</strong> Aplicación urgente de actualizaciones críticas tan pronto como se publican</li>
							<li><strong>Revisión de permisos:</strong> Auditoría de usuarios, roles y permisos de archivos del servidor</li>
							<li><strong>Protección ante ataques:</strong> Configuración y revisión de firewalls, limitación de intentos de login y bloqueo de IPs maliciosas</li>
						</ul>

						<!-- MAINTENANCE PLANS -->
						<h2 class="text-2xl sm:text-3xl font-bold mt-8 sm:mt-12 mb-4 sm:mb-6">
							Planes de mantenimiento web
						</h2>

						<p class="text-base sm:text-lg mb-6">
							Cada negocio es diferente. Por eso ofrezco tres planes de mantenimiento web adaptados a distintas
							necesidades y presupuestos. Todos los planes incluyen soporte técnico y se facturan mensualmente
							sin permanencia mínima.
						</p>

						<div class="grid sm:grid-cols-3 gap-4 sm:gap-6 mb-8 sm:mb-10">
							<!-- Basic -->
							<div class="bg-secondary p-4 sm:p-6 rounded-lg border border-transparent hover:border-accent transition-all">
								<div class="text-xs font-semibold uppercase tracking-wide text-accent mb-2">Plan Básico</div>
								<div class="text-2xl sm:text-3xl font-bold mb-1">150€<span class="text-base font-normal text-text-muted">/mes</span></div>
								<p class="text-xs sm:text-sm text-text-muted mb-4">Ideal para webs corporativas y landing pages con tráfico estable</p>
								<ul class="space-y-2 text-sm">
									<li>✅ Actualizaciones mensuales de CMS y plugins</li>
									<li>✅ Backup semanal (retención 30 días)</li>
									<li>✅ Monitorización de uptime 24/7</li>
									<li>✅ Control de certificado SSL</li>
									<li>✅ Soporte por email (respuesta en 24h)</li>
									<li>✅ Corrección de errores básicos</li>
								</ul>
							</div>

							<!-- Professional -->
							<div class="bg-secondary p-4 sm:p-6 rounded-lg border-2 border-accent relative">
								<div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-accent text-white text-xs font-bold px-3 py-1 rounded-full">MAS POPULAR</div>
								<div class="text-xs font-semibold uppercase tracking-wide text-accent mb-2">Plan Profesional</div>
								<div class="text-2xl sm:text-3xl font-bold mb-1">300€<span class="text-base font-normal text-text-muted">/mes</span></div>
								<p class="text-xs sm:text-sm text-text-muted mb-4">Para webs que son el motor principal del negocio</p>
								<ul class="space-y-2 text-sm">
									<li>✅ Todo lo del plan Básico</li>
									<li>✅ Actualizaciones quincenales</li>
									<li>✅ Backup diario (retención 60 días)</li>
									<li>✅ Monitorización SEO (posiciones, tráfico)</li>
									<li>✅ Soporte prioritario (respuesta en 8h)</li>
									<li>✅ Informe mensual de rendimiento</li>
									<li>✅ Escaneo mensual de malware</li>
									<li>✅ Corrección de errores ilimitada</li>
								</ul>
							</div>

							<!-- Premium -->
							<div class="bg-secondary p-4 sm:p-6 rounded-lg border border-transparent hover:border-accent transition-all">
								<div class="text-xs font-semibold uppercase tracking-wide text-accent mb-2">Plan Premium</div>
								<div class="text-2xl sm:text-3xl font-bold mb-1">500€<span class="text-base font-normal text-text-muted">/mes</span></div>
								<p class="text-xs sm:text-sm text-text-muted mb-4">Solución completa para ecommerce y portales con alto tráfico</p>
								<ul class="space-y-2 text-sm">
									<li>✅ Todo lo del plan Profesional</li>
									<li>✅ Actualizaciones semanales</li>
									<li>✅ Backup diario (retención 90 días)</li>
									<li>✅ Horas de desarrollo incluidas (4h/mes)</li>
									<li>✅ Tests A/B y optimización de conversión</li>
									<li>✅ Analítica avanzada y seguimiento de KPIs</li>
									<li>✅ Soporte por email y videollamada (respuesta en 4h)</li>
									<li>✅ Auditoría SEO técnica trimestral</li>
								</ul>
							</div>
						</div>

						<p class="text-sm text-text-muted mb-8">
							* Los precios no incluyen IVA. Sin permanencia mínima. Puedes cambiar de plan o cancelar con 30 días de aviso.
							Para proyectos con necesidades específicas o volumen muy elevado, consultame para un presupuesto personalizado.
						</p>

						<!-- HOW IT WORKS -->
						<h2 class="text-2xl sm:text-3xl font-bold mt-8 sm:mt-12 mb-4 sm:mb-6">
							¿Cómo funciona el servicio de mantenimiento web?
						</h2>

						<p class="text-base sm:text-lg mb-6">
							El proceso está diseñado para ser transparente y sin fricciones. Desde el primer día sabrás exactamente
							qué se hace en tu web, cuándo y con qué resultado.
						</p>

						<h3 class="text-xl sm:text-2xl font-bold mt-6 sm:mt-8 mb-3 sm:mb-4">Proceso de onboarding:</h3>
						<ol class="list-decimal pl-5 sm:pl-6 space-y-2 sm:space-y-3 mb-6 text-sm sm:text-base">
							<li><strong>Auditoría inicial:</strong> Análisis completo del estado actual de tu web — versiones, plugins, seguridad, velocidad y SEO técnico. Identifico problemas existentes antes de empezar.</li>
							<li><strong>Primer backup completo:</strong> Antes de tocar nada, realizo una copia de seguridad completa del sitio como punto de partida seguro.</li>
							<li><strong>Configuración de herramientas:</strong> Instalo y configuro las herramientas de monitorización, alertas y backup automatizado.</li>
							<li><strong>Plan de acción:</strong> Comparto contigo un informe de la auditoría y el plan de mejoras para los primeros 30 días.</li>
							<li><strong>Inicio del mantenimiento:</strong> El servicio entra en funcionamiento. Recibirás acceso a un panel donde podrás ver el estado de tu web en tiempo real.</li>
						</ol>

						<h3 class="text-xl sm:text-2xl font-bold mt-6 sm:mt-8 mb-3 sm:mb-4">Informes mensuales (planes Profesional y Premium):</h3>
						<p class="text-base sm:text-lg mb-4">
							Cada mes recibirás un informe detallado que incluye las tareas realizadas, el estado de seguridad y
							rendimiento, la evolución del tráfico orgánico y las posiciones en Google para tus keywords principales,
							junto con las recomendaciones de mejora para el siguiente mes.
						</p>
						<p class="text-base sm:text-lg mb-6">
							El informe está redactado en lenguaje claro, sin tecnicismos, para que puedas entender exactamente
							qué pasa con tu web y tomar decisiones informadas sobre tu negocio digital.
						</p>

						<h3 class="text-xl sm:text-2xl font-bold mt-6 sm:mt-8 mb-3 sm:mb-4">SLA y tiempos de respuesta:</h3>
						<div class="grid sm:grid-cols-3 gap-4 mb-6">
							<div class="bg-secondary p-4 rounded-lg text-center">
								<div class="text-2xl font-bold text-accent">24h</div>
								<div class="text-sm font-semibold mt-1">Plan Básico</div>
								<div class="text-xs text-text-muted mt-1">Tiempo de respuesta garantizado</div>
							</div>
							<div class="bg-secondary p-4 rounded-lg text-center">
								<div class="text-2xl font-bold text-accent">8h</div>
								<div class="text-sm font-semibold mt-1">Plan Profesional</div>
								<div class="text-xs text-text-muted mt-1">Tiempo de respuesta garantizado</div>
							</div>
							<div class="bg-secondary p-4 rounded-lg text-center">
								<div class="text-2xl font-bold text-accent">4h</div>
								<div class="text-sm font-semibold mt-1">Plan Premium</div>
								<div class="text-xs text-text-muted mt-1">Tiempo de respuesta garantizado</div>
							</div>
						</div>

						<!-- WHY CHOOSE -->
						<h2 class="text-2xl sm:text-3xl font-bold mt-8 sm:mt-12 mb-4 sm:mb-6">
							¿Por qué contratar el mantenimiento web con un freelance especializado?
						</h2>

						<p class="text-base sm:text-lg mb-4">
							Contratar el mantenimiento web con una agencia grande puede significar hablar con un comercial,
							esperar días para cualquier cambio y pagar honorarios inflados por trabajo que realiza un junior.
							Con mi servicio de mantenimiento web freelance, tienes acceso directo al desarrollador que conoce
							tu web desde dentro.
						</p>

						<ul class="list-disc pl-5 sm:pl-6 space-y-2 sm:space-y-3 mb-6 text-sm sm:text-base">
							<li><strong>Conocimiento profundo de tu proyecto:</strong> Soy el mismo profesional que desarrolló o revisó tu web. No hay curva de aprendizaje ni tiempo perdido explicando la arquitectura.</li>
							<li><strong>Comunicación directa:</strong> Hablas directamente conmigo, sin intermediarios ni colas de tickets impersonales.</li>
							<li><strong>Proactividad:</strong> No espero a que los problemas exploten. Identifico y resuelvo incidencias antes de que afecten a tu negocio.</li>
							<li><strong>Transparencia total:</strong> Sabes exactamente qué se hace, cuándo y por qué. Sin letra pequeña ni cobros sorpresa.</li>
							<li><strong>Flexibilidad:</strong> Puedes adaptar el plan a tus necesidades reales. Sin contratos anuales ni permanencias obligatorias.</li>
						</ul>

						<!-- CROSS-LINKS -->
						<h3 class="text-xl sm:text-2xl font-bold mt-6 sm:mt-8 mb-3 sm:mb-4">Otros servicios relacionados:</h3>
						<div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-6">
							<a href="/diseno-web-empresas" class="block p-3 bg-secondary rounded-lg text-sm font-medium text-center hover:shadow-md transition-all">Diseño web empresas →</a>
							<a href="/desarrollador-web-espana" class="block p-3 bg-secondary rounded-lg text-sm font-medium text-center hover:shadow-md transition-all">Desarrollador web España →</a>
							<a href="/desarrollador-web-barcelona" class="block p-3 bg-secondary rounded-lg text-sm font-medium text-center hover:shadow-md transition-all">Desarrollador web Barcelona →</a>
							<a href="/contratar-desarrollador-full-stack" class="block p-3 bg-secondary rounded-lg text-sm font-medium text-center hover:shadow-md transition-all">Contratar desarrollador →</a>
							<a href="/crear-pagina-web-barcelona" class="block p-3 bg-secondary rounded-lg text-sm font-medium text-center hover:shadow-md transition-all">Crear página web →</a>
							<a href="/desarrollador-web-madrid" class="block p-3 bg-secondary rounded-lg text-sm font-medium text-center hover:shadow-md transition-all">Desarrollador web Madrid →</a>
						</div>

						<!-- CTA BOX -->
						<div class="bg-secondary p-4 sm:p-6 rounded-lg mt-6 sm:mt-8 mb-6 sm:mb-8">
							<h3 class="text-xl sm:text-2xl font-bold mb-3 sm:mb-4">¿Lista tu web para un mantenimiento profesional?</h3>
							<p class="mb-3 sm:mb-4 text-sm sm:text-base">
