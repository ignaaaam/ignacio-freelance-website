---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Contact from '../components/Contact.astro';
import StickyCTA from '../components/StickyGTA.astro';

const baseUrl = 'https://www.ignacioamatweb.com';
const title = "Web para startups en Barcelona | Landing pages, webs de negocio y MVPs | Ignacio Amat";
const description = "Desarrollo web para startups en Barcelona: landing pages, webs para presentar mejor el producto y MVPs por fases con foco en claridad, validacion y velocidad razonable.";
const canonicalUrl = "/pagina-web-startups-barcelona";

const serviceSchema = {
	"@context": "https://schema.org",
	"@type": "Service",
	"serviceType": "Desarrollo Web para Startups",
	"provider": {
		"@type": "ProfessionalService",
		"name": "Ignacio Amat - Desarrollador Web",
		"url": baseUrl
	},
	"areaServed": {
		"@type": "City",
		"name": "Barcelona"
	},
	"description": description,
	"offers": {
		"@type": "Offer",
		"priceRange": "€800 - €6,000+",
		"priceCurrency": "EUR"
	}
};

const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": [
		{
			"@type": "Question",
			"name": "¿Cuanto cuesta normalmente una landing page o una web para startup?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Una landing page enfocada suele partir de 800 EUR. Una web mas completa para presentar producto, equipo y propuesta suele moverse desde 1.800 EUR. Si hay MVP o logica de producto, conviene presupuestarlo por fases."
			}
		},
		{
			"@type": "Question",
			"name": "¿Puedes ayudarme a definir un MVP sin sobreconstruir?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Si. El enfoque suele ser definir primero la version minima util, construir solo los modulos clave y dejar la base preparada para iterar despues con datos reales."
			}
		},
		{
			"@type": "Question",
			"name": "¿Que tipo de startups encajan mejor con este servicio?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Suele encajar bien con equipos pequeños que necesitan validar una propuesta, presentar mejor el producto, captar leads o preparar una primera base util para ventas o aprendizaje."
			}
		},
		{
			"@type": "Question",
			"name": "¿Tambien trabajas con startups fuera de Barcelona?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Si. Trabajo en remoto con startups de Barcelona y con equipos de otras ciudades o paises. Barcelona es una de las ubicaciones donde este tipo de proyecto aparece con frecuencia."
			}
		}
	]
};

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{
			"@type": "ListItem",
			"position": 1,
			"name": "Inicio",
			"item": baseUrl
		},
		{
			"@type": "ListItem",
			"position": 2,
			"name": "Web para Startups Barcelona",
			"item": `${baseUrl}${canonicalUrl}`
		}
	]
};

const allSchemas = [serviceSchema, faqSchema, breadcrumbSchema];
---
<Layout 
	title={title} 
	description={description} 
	lang="es"
	canonicalUrl={canonicalUrl}
	additionalSchemas={allSchemas}
	keywords={["página web startup Barcelona", "landing page startup", "MVP desarrollo Barcelona", "web emprendedores Barcelona", "desarrollo web 22@ Barcelona", "página web SaaS", "web tech startup", "desarrollador freelance startups"]}
>
	<Header />
	<main>
		<section class="py-12 sm:py-16 md:py-20 content-page">
			<div class="container px-4 sm:px-6 content-page__container">
				<div class="max-w-4xl mx-auto content-page__inner">
					<div class="mb-6">
						<span class="inline-block px-3 py-1 text-sm font-medium bg-accent/10 text-accent rounded-full mb-4">
							Landing pages, webs de producto y MVPs por fases
						</span>
					</div>
					
					<h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 sm:mb-6">
						Web para startups en Barcelona
					</h1>
					
					<p class="text-lg sm:text-xl text-text-muted mb-6 sm:mb-8">
						Si estas validando una idea, preparando una demo para ventas o inversores, o necesitas una
						web mas creible para presentar el producto, puedo ayudarte a lanzar una base clara sin
						sobredimensionar el proyecto desde el principio.
					</p>

					<div class="bg-accent/5 border border-accent/20 rounded-lg p-4 sm:p-6 mb-8">
						<p class="text-sm sm:text-base font-medium mb-2">Este tipo de trabajo suele encajar cuando necesitas:</p>
						<div class="grid sm:grid-cols-3 gap-2 text-sm">
							<span>Una landing para validar interes real</span>
							<span>Una web de producto mas creible</span>
							<span>Una primera base para ventas o demos</span>
							<span>Un MVP con alcance razonable</span>
							<span>Integraciones y captacion sin exceso de complejidad</span>
							<span>Una estructura lista para iterar</span>
						</div>
					</div>

					<div class="prose prose-lg max-w-none content-page__prose mb-8 sm:mb-12">
						<h2 class="text-2xl sm:text-3xl font-bold mt-8 sm:mt-12 mb-4 sm:mb-6">
							Que suele necesitar una startup en esta fase
						</h2>

						<div class="grid gap-4 sm:gap-6 mb-6 sm:mb-8">
							<div class="bg-secondary p-4 sm:p-6 rounded-lg border-l-4 border-accent">
								<h3 class="text-lg sm:text-xl font-bold mb-2">Landing page para captar o validar</h3>
								<p class="text-2xl font-bold text-accent mb-2">Desde 800€</p>
								<p class="text-sm text-text-muted mb-3">
									Una pagina enfocada en explicar mejor la propuesta, reducir ruido y llevar al usuario a una accion clara.
								</p>
								<ul class="text-sm space-y-1 mb-3">
									<li>✅ Propuesta clara y CTA visible</li>
									<li>✅ Formulario o waitlist bien resuelto</li>
									<li>✅ Integraciones utiles si hacen falta</li>
									<li>✅ Seguimiento basico de conversion</li>
									<li>✅ Ideal para validar interes o captar reuniones</li>
								</ul>
								<p class="text-sm">Ideal para: validacion, demos, campanas o primeras conversaciones comerciales</p>
							</div>

							<div class="bg-secondary p-4 sm:p-6 rounded-lg border-l-4 border-green-500">
								<h3 class="text-lg sm:text-xl font-bold mb-2">Web de producto o de empresa</h3>
								<p class="text-2xl font-bold text-green-500 mb-2">1.500€ - 3.000€</p>
								<p class="text-sm text-text-muted mb-3">
									Una base mas completa para presentar mejor el producto, reforzar confianza y explicar el negocio con mas claridad.
								</p>
								<ul class="text-sm space-y-1 mb-3">
									<li>✅ Home, producto, FAQ y contacto</li>
									<li>✅ Mensaje mas claro para ventas o inversores</li>
									<li>✅ Secciones de confianza y contexto</li>
									<li>✅ Base tecnica cuidada desde el inicio</li>
									<li>✅ Preparada para crecer sin rehacerlo todo</li>
								</ul>
								<p class="text-sm">Ideal para: producto B2B, presentaciones comerciales, primeras fases de crecimiento</p>
							</div>

							<div class="bg-secondary p-4 sm:p-6 rounded-lg border-l-4 border-purple-500">
								<h3 class="text-lg sm:text-xl font-bold mb-2">MVP web por fases</h3>
								<p class="text-2xl font-bold text-purple-500 mb-2">2.500€ - 6.000€+</p>
								<p class="text-sm text-text-muted mb-3">
									Una primera version util para validar flujo, propuesta o logica principal sin construir mas de la cuenta.
								</p>
								<ul class="text-sm space-y-1 mb-3">
									<li>✅ Definicion del alcance minimo util</li>
									<li>✅ Auth, panel y modulos clave</li>
									<li>✅ Integraciones necesarias</li>
									<li>✅ Base mantenible para iterar</li>
									<li>✅ Trabajo por fases para decidir mejor</li>
								</ul>
								<p class="text-sm">Ideal para: validar con usuarios, demos, procesos internos o primera traccion</p>
							</div>
						</div>

						<h2 class="text-2xl sm:text-3xl font-bold mt-8 sm:mt-12 mb-4 sm:mb-6">
							Por que este enfoque suele funcionar bien con startups
						</h2>

						<div class="grid sm:grid-cols-2 gap-4 sm:gap-6 mb-6 sm:mb-8">
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3">Alcance por fases</h3>
								<p class="text-sm sm:text-base">En lugar de construir todo de golpe, priorizamos lo minimo util y dejamos margen para aprender.</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3">Mensaje mas claro</h3>
								<p class="text-sm sm:text-base">Si el producto o la propuesta aun esta verde, ordenar el mensaje suele aportar mas que anadir mas pantallas.</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3">Base tecnica razonable</h3>
								<p class="text-sm sm:text-base">El objetivo es lanzar bien, medir y mantener, no impresionar con complejidad innecesaria.</p>
							</div>
							<div class="bg-secondary p-4 sm:p-6 rounded-lg">
								<h3 class="text-lg sm:text-xl font-bold mb-2 sm:mb-3">Trabajo directo</h3>
								<p class="text-sm sm:text-base">Hablas con la misma persona que piensa la estructura, define el alcance y construye la solucion.</p>
							</div>
						</div>

						<h2 class="text-2xl sm:text-3xl font-bold mt-8 sm:mt-12 mb-4 sm:mb-6">
							Cuando suele tener sentido este tipo de proyecto
						</h2>
						
						<p class="text-base sm:text-lg mb-4">
							Suele encajar bien cuando la startup necesita mejorar alguno de estos puntos:
						</p>

						<ul class="list-disc pl-5 sm:pl-6 space-y-2 mb-4 sm:mb-6 text-sm sm:text-base">
							<li><strong>Validar una propuesta:</strong> necesitas saber si una oferta genera reuniones o interes real.</li>
							<li><strong>Presentar mejor el producto:</strong> la web actual no ayuda a vender, explicar o dar contexto suficiente.</li>
							<li><strong>Preparar demos y ventas:</strong> hace falta una base creible para conversaciones comerciales o con partners.</li>
							<li><strong>Lanzar una primera version:</strong> necesitas un MVP util, no una plataforma gigante desde el dia uno.</li>
						</ul>

						<h2 class="text-2xl sm:text-3xl font-bold mt-8 sm:mt-12 mb-4 sm:mb-6">
							Integraciones y piezas que suelen aparecer
						</h2>

						<div class="grid sm:grid-cols-3 gap-4 mb-6 sm:mb-8 text-sm">
							<div class="bg-secondary p-3 rounded-lg text-center">
								<strong>Marketing</strong><br/>
								Mailchimp, HubSpot, ActiveCampaign, Intercom
							</div>
							<div class="bg-secondary p-3 rounded-lg text-center">
								<strong>Analytics</strong><br/>
								GA4, Mixpanel, Amplitude, Hotjar
							</div>
							<div class="bg-secondary p-3 rounded-lg text-center">
								<strong>Pagos</strong><br/>
								Stripe, PayPal, Bizum
							</div>
							<div class="bg-secondary p-3 rounded-lg text-center">
								<strong>Auth</strong><br/>
								Auth0, Firebase, OAuth
							</div>
							<div class="bg-secondary p-3 rounded-lg text-center">
								<strong>CRM</strong><br/>
								Salesforce, Pipedrive, Notion
							</div>
							<div class="bg-secondary p-3 rounded-lg text-center">
								<strong>Comunicación</strong><br/>
								Slack, Discord, email y webhooks
							</div>
						</div>

						<h2 class="text-2xl sm:text-3xl font-bold mt-8 sm:mt-12 mb-4 sm:mb-6">
							Preguntas frecuentes
						</h2>
						
						<div class="space-y-4 mb-6 sm:mb-8">
							<div class="bg-secondary p-4 rounded-lg">
								<h3 class="font-bold text-base sm:text-lg mb-2">¿Cuanto cuesta una landing page o una web para startup?</h3>
								<p class="text-sm sm:text-base text-text-muted">
									Una landing enfocada suele partir de 800 EUR. Una web mas completa suele moverse desde
									1.800 EUR. Si hay MVP o logica de producto, conviene presupuestarlo por fases.
								</p>
							</div>
							<div class="bg-secondary p-4 rounded-lg">
								<h3 class="font-bold text-base sm:text-lg mb-2">¿Puedes ayudarme a definir un MVP sin sobreconstruir?</h3>
								<p class="text-sm sm:text-base text-text-muted">
									Si. La idea es definir primero la version minima util, construir solo lo importante y
									dejar preparada la base para la siguiente iteracion.
								</p>
							</div>
							<div class="bg-secondary p-4 rounded-lg">
								<h3 class="font-bold text-base sm:text-lg mb-2">¿Que tipo de startups suelen encajar mejor?</h3>
								<p class="text-sm sm:text-base text-text-muted">
									Equipos pequeños que necesitan validar una propuesta, presentar mejor el producto,
									captar leads o preparar una primera base util para vender y aprender.
								</p>
							</div>
							<div class="bg-secondary p-4 rounded-lg">
								<h3 class="font-bold text-base sm:text-lg mb-2">¿Trabajas tambien con startups fuera de Barcelona?</h3>
								<p class="text-sm sm:text-base text-text-muted">
									Si. Trabajo en remoto con startups de Barcelona y con equipos de otras ciudades o paises.
								</p>
							</div>
						</div>

						<div class="bg-gradient-to-r from-accent/10 to-purple-500/10 p-4 sm:p-6 rounded-lg mt-6 sm:mt-8 mb-6 sm:mb-8">
							<h3 class="text-xl sm:text-2xl font-bold mb-3 sm:mb-4">
								Si necesitas una web para validar, vender o lanzar mejor, el siguiente paso deberia ser simple
							</h3>
							<p class="mb-3 sm:mb-4 text-sm sm:text-base">
								Cuentame que quieres conseguir, en que fase estas y si ya existe algo construido. Con eso
								te puedo orientar sobre si conviene una landing, una web de producto o una primera fase de MVP.
							</p>
							<p class="font-semibold text-sm sm:text-base">
								✅ Primera respuesta util en 24h laborables<br/>
								✅ Alcance inicial sin compromiso<br/>
								✅ Trabajo por fases cuando hace falta<br/>
								✅ Base clara para seguir iterando
							</p>
						</div>

						<h3 class="text-xl sm:text-2xl font-bold mt-6 sm:mt-8 mb-3 sm:mb-4">Otros servicios relacionados:</h3>
						<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
							<a href="/crear-pagina-web-barcelona" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
								<h4 class="font-bold mb-2">Crear Página Web Barcelona →</h4>
								<p class="text-sm text-text-muted">Servicios generales de desarrollo web para empresas en Barcelona.</p>
							</a>
							<a href="/desarrollador-web-barcelona" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
								<h4 class="font-bold mb-2">Desarrollador Web Barcelona →</h4>
								<p class="text-sm text-text-muted">Desarrollo web profesional con las últimas tecnologías.</p>
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<Contact />
	</main>
	<StickyCTA />
</Layout>

<style>
	.text-text-muted {
		color: var(--color-text-muted);
	}
	
	.bg-secondary {
		background-color: var(--color-secondary);
	}
	
	.text-accent {
		color: var(--color-accent);
	}
	
	.prose h2, .prose h3 {
		color: var(--color-text);
	}
	
	.prose p, .prose li {
		color: var(--color-text);
		line-height: 1.8;
	}
</style>
