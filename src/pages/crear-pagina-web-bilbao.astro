---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Contact from '../components/Contact.astro';
import StickyCTA from '../components/StickyGTA.astro';

const baseUrl = 'https://www.ignacioamatweb.com';
const title = "Crear Página Web Bilbao 2026 | Ignacio Amat";
const description = "Diseño y creación de páginas web en Bilbao y Vizcaya. Especialista en webs corporativas para el sector industrial y pymes. SEO y resultados. Presupuesto en 24h.";
const canonicalUrl = "/crear-pagina-web-bilbao";
const keywords = ["crear página web Bilbao", "diseño web Bilbao", "desarrollo web Bilbao", "empresa diseño web Bilbao", "presupuesto web Bilbao", "web sector industrial Bilbao", "freelance web Vizcaya"];

// Structured Data
const serviceSchema = {
	"@context": "https://schema.org",
	"@type": "Service",
	"serviceType": "Crear Página Web para Empresas en Bilbao",
	"provider": {
		"@type": "LocalBusiness",
		"name": "Ignacio Amat",
		"url": baseUrl,
		"address": {
			"@type": "PostalAddress",
			"addressLocality": "Bilbao",
			"addressRegion": "Vizcaya",
			"addressCountry": "ES"
		}
	},
	"areaServed": {
		"@type": "City",
		"name": "Bilbao"
	},
	"description": "Desarrollo de páginas web profesionales para el tejido empresarial e industrial de Bilbao. Webs robustas, rápidas y seguras.",
	"offers": {
		"@type": "Offer",
		"priceRange": "€800 - €6,000+",
		"description": "Soluciones de alta ingeniería web para Bilbao"
	},
	"aggregateRating": {
		"@type": "AggregateRating",
		"ratingValue": "5",
		"reviewCount": "5",
		"bestRating": "5"
	}
};

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{
			"@type": "ListItem",
			"position": 1,
			"name": "Inicio",
			"item": baseUrl
		},
		{
			"@type": "ListItem",
			"position": 2,
			"name": "Crear Página Web Bilbao",
			"item": `${baseUrl}${canonicalUrl}`
		}
	]
};

const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": [
		{
			"@type": "Question",
			"name": "¿Cuál es el coste de crear una web para una empresa en Bilbao?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Para empresas de Bilbao, los proyectos suelen oscilar entre los 1.500€ para webs corporativas estándar y los 6.000€+ para sistemas industriales complejos o e-commerce. Landing pages disponibles desde 800€."
			}
		},
		{
			"@type": "Question",
			"name": "¿Ofreces servicios a empresas de toda Vizcaya?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Sí, trabajo de forma remota con empresas de Bilbao, Barakaldo, Getxo, Zamudio (Parque Tecnológico) y todo el País Vasco, asegurando una comunicación fluida y resultados de alta calidad."
			}
		}
	]
};

const localBusinessSchema = {
	"@context": "https://schema.org",
	"@type": "ProfessionalService",
	"name": "Ignacio Amat — Crear Página Web Bilbao",
	"url": `https://www.ignacioamatweb.com${canonicalUrl}`,
	"image": "https://www.ignacioamatweb.com/og-image.png",
	"priceRange": "€€",
	"currenciesAccepted": "EUR",
	"serviceArea": { "@type": "City", "name": "Bilbao" },
	"areaServed": { "@type": "City", "name": "Bilbao" },
	"address": { "@type": "PostalAddress", "addressLocality": "Bilbao", "addressRegion": "Vizcaya", "addressCountry": "ES" },
	"availableLanguage": ["Spanish", "English"],
	"sameAs": ["https://www.linkedin.com/in/ignacio-amat-urbina-789244223/", "https://github.com/ignaaaam"]
};

const allSchemas = [serviceSchema, breadcrumbSchema, faqSchema, localBusinessSchema];

const alternateUrls = {
	es: canonicalUrl,
	en: "/en/create-website-bilbao"
};
---
<Layout 
	title={title} 
	description={description} 
	lang="es"
	canonicalUrl={canonicalUrl}
	keywords={keywords}
	additionalSchemas={allSchemas}
	alternateUrls={alternateUrls}
>
	<Header />
	<main>
		<section class="py-12 sm:py-16 md:py-20 content-page">
			<div class="container px-4 sm:px-6 content-page__container">
				<div class="max-w-4xl mx-auto content-page__inner">
					<h1 class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 sm:mb-6">Crear Página Web para tu Empresa en Bilbao</h1>
					
					<p class="text-lg sm:text-xl text-text-muted mb-6 sm:mb-8">
						Bilbao cuenta con un tejido empresarial e industrial de primer nivel. Tu presencia online debe reflejar esa misma solidez. 
						Diseño y desarrollo páginas web profesionales para empresas de Vizcaya que necesitan resultados medibles.
					</p>

					<div class="prose prose-lg max-w-none content-page__prose mb-8 sm:mb-12">
						<h2 class="text-2xl sm:text-3xl font-bold mt-8 sm:mt-12 mb-4 sm:mb-6">Soluciones web robustas para el sector industrial y corporativo</h2>
						
						<p class="text-base sm:text-lg mb-4">
							En Bilbao, la seriedad y la fiabilidad son claves. Mi enfoque para crear páginas web se basa en la ingeniería técnica: 
							webs rápidas, seguras y preparadas para el crecimiento. No utilizo plantillas genéricas; cada proyecto se construye 
							a medida de los objetivos de tu negocio.
						</p>

						<h3 class="text-xl sm:text-2xl font-bold mt-6 sm:mt-8 mb-3 sm:mb-4">Especialidades en el mercado de Vizcaya:</h3>
						<ul class="list-disc pl-5 sm:pl-6 space-y-2 sm:space-y-3 mb-4 sm:mb-6 text-sm sm:text-base">
							<li><strong>Webs Corporativas B2B:</strong> Para empresas industriales y de servicios especializados.</li>
							<li><strong>Catálogos Digitales:</strong> Presenta tus productos de forma profesional y clara.</li>
							<li><strong>SEO para el País Vasco:</strong> Posicionamiento estratégico para captar demanda local y nacional.</li>
							<li><strong>Intranets y Paneles:</strong> Herramientas a medida para optimizar procesos internos.</li>
						</ul>

						<h3 class="text-xl sm:text-2xl font-bold mt-6 sm:mt-8 mb-3 sm:mb-4">¿Por qué confiar en un desarrollador freelance?</h3>
						<p class="mb-4 text-sm sm:text-base">
							Ofrezco el compromiso y la atención al detalle que requiere el mercado de Bilbao. Trabajarás directamente conmigo, 
							sin intermediarios, lo que garantiza una ejecución técnica impecable y un cumplimiento estricto de los plazos acordados.
						</p>

						<div class="bg-secondary p-4 sm:p-6 rounded-lg mt-6 sm:mt-8 mb-6 sm:mb-8">
							<h3 class="text-xl sm:text-2xl font-bold mb-3 sm:mb-4">Construyamos tu identidad digital en Bilbao</h3>
							<p class="mb-3 sm:mb-4 text-sm sm:text-base">
								Si buscas un colaborador de confianza para crear la página web de tu empresa en Bilbao o Vizcaya, 
								pídeme una propuesta hoy mismo.
							</p>
							<p class="font-semibold text-sm sm:text-base">
								✅ Presupuesto detallado en 24h<br/>
								✅ Tecnologías modernas y seguras<br/>
								✅ Enfoque en captación de negocio<br/>
								✅ Factura oficial y contrato
							</p>
						</div>

						<h3 class="text-xl sm:text-2xl font-bold mt-6 sm:mt-8 mb-3 sm:mb-4">Más información:</h3>
						<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
							<a href="/desarrollador-web-bilbao" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
								<h4 class="font-bold mb-2">Desarrollador Web Bilbao →</h4>
								<p class="text-sm text-text-muted">Servicios de programación y consultoría técnica en Bilbao.</p>
							</a>
							<a href="/diseno-web-empresas" class="block p-4 bg-secondary rounded-lg hover:shadow-lg transition-all">
								<h4 class="font-bold mb-2">Diseño Web Empresas →</h4>
								<p class="text-sm text-text-muted">Diseño centrado en la marca y la experiencia de usuario.</p>
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<Contact />
		<StickyCTA />
	</main>
</Layout>

<style>
	.text-text-muted { color: var(--color-text-muted); }
	.bg-secondary { background-color: var(--color-secondary); }
	.prose h2, .prose h3 { color: var(--color-text); }
	.prose p, .prose li { color: var(--color-text); line-height: 1.8; }
</style>
