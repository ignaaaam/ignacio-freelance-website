---
import { getLocaleFromPath } from '../i18n/utils';
import { siteContent } from '../data/siteContent';
import { siteConfig } from '../data/siteConfig';

const locale = getLocaleFromPath(Astro.url.pathname);
const content = siteContent[locale].contact;

const projectTypes =
  locale === 'en'
    ? [
        ['landing', 'Landing page'],
        ['web', 'Business website'],
        ['redesign', 'Redesign / improvement'],
        ['laravel', 'Laravel project'],
        ['webapp', 'Web app / SaaS / MVP'],
        ['maintenance', 'Maintenance'],
        ['bugfix', 'Technical fix / issue'],
        ['other', 'Other'],
      ]
    : [
        ['landing', 'Landing page'],
        ['web', 'Web de empresa'],
        ['redesign', 'Rediseño / mejora'],
        ['laravel', 'Proyecto Laravel'],
        ['webapp', 'App web / SaaS / MVP'],
        ['maintenance', 'Mantenimiento'],
        ['bugfix', 'Corrección / incidencia técnica'],
        ['other', 'Otro'],
      ];

const budgetOptions =
  locale === 'en'
    ? [
        ['', 'Prefer not to say'],
        ['under-1500', 'Under EUR 1,500'],
        ['1500-3000', 'EUR 1,500 to 3,000'],
        ['3000-6000', 'EUR 3,000 to 6,000'],
        ['6000-10000', 'EUR 6,000 to 10,000'],
        ['over-10000', 'Over EUR 10,000'],
      ]
    : [
        ['', 'Prefiero no indicarlo'],
        ['under-1500', 'Menos de 1.500 EUR'],
        ['1500-3000', '1.500 a 3.000 EUR'],
        ['3000-6000', '3.000 a 6.000 EUR'],
        ['6000-10000', '6.000 a 10.000 EUR'],
        ['over-10000', 'Más de 10.000 EUR'],
      ];
---

<section class="section section-alt" id="contacto" data-contact-root>
  <div class="container">
    <div class="section-heading">
      <p class="section-eyebrow">{content.eyebrow}</p>
      <h2>{content.title}</h2>
      <p class="section-copy">{content.description}</p>
    </div>

    <div class="contact-grid">
      <aside class="contact-panel surface-card" data-sr>
        <div class="contact-panel__stack">
          <article class="contact-channel">
            <span>{locale === 'en' ? 'Recommended path' : 'Paso recomendado'}</span>
            <a href="#contact-form" data-cta="contact-recommended">{locale === 'en' ? 'Use the contact form' : 'Usar el formulario'}</a>
            <p>{locale === 'en' ? 'It is the clearest way to explain the project, timing and budget context in one place.' : 'Es la forma más clara de explicar el proyecto, el plazo y el contexto de presupuesto en un solo paso.'}</p>
          </article>

          <article class="contact-channel">
            <span>{content.emailLabel}</span>
            <a href={`mailto:${siteConfig.email}`} data-cta="contact-email">{siteConfig.email}</a>
            <p>{locale === 'en' ? 'Useful if you prefer to write directly, forward the enquiry internally or continue by email.' : 'Útil si prefieres escribir directamente, reenviar la consulta internamente o seguir por email.'}</p>
          </article>

          <article class="contact-channel">
            <span>{locale === 'en' ? 'What happens next' : 'Qué pasa después'}</span>
            <strong class="contact-channel__next">{locale === 'en' ? 'You will hear back within 24 business hours' : 'Recibirás respuesta en 24 horas laborables'}</strong>
            <p>{locale === 'en' ? 'A first reply with a useful recommendation, any clarifying questions and the best next step for the project.' : 'Una primera respuesta con una recomendación útil, las preguntas necesarias y el mejor siguiente paso para el proyecto.'}</p>
          </article>
        </div>

        <div class="contact-panel__note">
          <span>{content.responseLabel}</span>
          <p>{content.responseText}</p>
        </div>
      </aside>

      <div class="contact-form-wrap surface-card" data-sr>
        <h3>{content.formTitle}</h3>

        <form id="contact-form" class="contact-form" method="POST" novalidate>
          <div class="hp-field" aria-hidden="true">
            <label for="website">Website</label>
            <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
          </div>

          <div class="contact-form__row">
            <label for="name">{locale === 'en' ? 'Name' : 'Nombre'}</label>
            <input id="name" name="name" type="text" required autocomplete="name" />
          </div>

          <div class="contact-form__row">
            <label for="email">Email</label>
            <input id="email" name="email" type="email" required autocomplete="email" inputmode="email" spellcheck="false" />
          </div>

          <div class="contact-form__row">
            <label for="type">{locale === 'en' ? 'Project type' : 'Tipo de proyecto'}</label>
            <select id="type" name="type" required>
              <option value="">{locale === 'en' ? 'Select an option' : 'Selecciona una opción'}</option>
              {projectTypes.map(([value, label]) => (
                <option value={value}>{label}</option>
              ))}
            </select>
          </div>

          <div class="contact-form__row">
            <label for="budget">
              {locale === 'en' ? 'Approximate budget' : 'Presupuesto aproximado'}
              <span class="contact-form__hint">{locale === 'en' ? '(optional - helps me tailor the proposal)' : '(opcional - ayuda a ajustar la propuesta)'}</span>
            </label>
            <select id="budget" name="budget">
              {budgetOptions.map(([value, label]) => (
                <option value={value}>{label}</option>
              ))}
            </select>
          </div>

          <div class="contact-form__row">
            <label for="message">{locale === 'en' ? 'Project context' : 'Contexto del proyecto'}</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              placeholder={locale === 'en' ? 'What do you need, who is it for and what timeline are you working with…' : 'Qué necesitas, para quién es y con qué plazo estás trabajando…'}
            ></textarea>
          </div>

          <details class="contact-form__optional">
            <summary>{content.optionalFields}</summary>

            <div class="contact-form__row">
              <label for="company">{locale === 'en' ? 'Company' : 'Empresa'}</label>
              <input id="company" name="company" type="text" autocomplete="organization" />
            </div>
          </details>

          <button type="submit" class="btn-primary" data-cta="contact-submit">{locale === 'en' ? 'Send project brief' : 'Enviar briefing'}</button>
          <p class="contact-form__assurance">{locale === 'en' ? 'No commitment required. If it looks like a fit, you will get a useful first reply within 24 business hours.' : 'Sin compromiso. Si encaja, recibirás una primera respuesta útil en 24 horas laborables.'}</p>
          <p id="contact-feedback" class="contact-feedback" role="status" aria-live="polite" tabindex="-1" hidden></p>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: minmax(320px, 0.82fr) minmax(0, 1.18fr);
    gap: 1.15rem;
  }

  .contact-panel,
  .contact-form-wrap {
    padding: 1.7rem;
  }

  .contact-panel__stack {
    display: grid;
    gap: 0.95rem;
  }

  .contact-channel,
  .contact-panel__note {
    padding: 1rem 1.05rem;
    border-radius: 1.15rem;
  }

  .contact-channel span,
  .contact-panel__note span {
    display: block;
    margin-bottom: 0.45rem;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--theme-accent-strong);
  }

  .contact-channel a {
    display: inline-flex;
    margin-bottom: 0.4rem;
    font-weight: 700;
    max-width: 100%;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .contact-channel p,
  .contact-panel__note p {
    color: var(--color-text-muted);
    line-height: 1.75;
  }

  .contact-panel__note {
    margin-top: 1rem;
  }

  .contact-panel {
    background:
      radial-gradient(circle at top left, rgba(31, 107, 255, 0.18), transparent 28%),
      linear-gradient(180deg, rgba(13, 16, 24, 0.98), rgba(9, 11, 16, 0.98));
    color: var(--theme-dark-text);
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: 0 26px 64px rgba(7, 10, 16, 0.24);
  }

  .contact-panel .contact-channel,
  .contact-panel .contact-panel__note {
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.05);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .contact-panel .contact-channel p,
  .contact-panel .contact-panel__note p,
  .contact-panel .contact-channel a {
    color: var(--theme-dark-muted);
  }

  .contact-panel .contact-channel__next {
    color: var(--theme-dark-text);
  }

  .contact-form-wrap h3 {
    margin-bottom: 1rem;
    font-size: clamp(1.5rem, 2.5vw, 2rem);
  }

  .contact-form {
    display: grid;
    gap: 1rem;
  }

  .contact-form__row {
    display: grid;
    gap: 0.45rem;
  }

  .contact-form__row label,
  .contact-form__optional summary {
    font-weight: 700;
  }

  .contact-form__hint {
    display: block;
    margin-top: 0.18rem;
    font-size: 0.82rem;
    font-weight: 400;
    color: var(--color-text-muted);
  }

  .contact-form__assurance {
    margin-top: -0.25rem;
    font-size: 0.88rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .contact-channel__next {
    display: block;
    margin-bottom: 0.4rem;
    font-size: 1rem;
    color: var(--theme-highlight);
  }

  .contact-form__row input,
  .contact-form__row textarea,
  .contact-form__row select {
    width: 100%;
    padding: 1rem 1.02rem;
    border: 1px solid var(--theme-field-border);
    border-radius: 1.1rem;
    background: var(--theme-field-bg);
    color: var(--color-text);
    transition: border-color 0.18s ease, background-color 0.18s ease, box-shadow 0.18s ease;
  }

  .contact-form__row input:hover,
  .contact-form__row textarea:hover,
  .contact-form__row select:hover {
    border-color: rgba(74, 54, 41, 0.24);
  }

  .contact-form__row input:focus,
  .contact-form__row textarea:focus,
  .contact-form__row select:focus {
    background: var(--theme-field-bg-focus);
    border-color: rgba(31, 107, 255, 0.34);
    box-shadow: 0 0 0 4px rgba(31, 107, 255, 0.08);
  }

  .contact-form__optional {
    display: grid;
    gap: 0.95rem;
    padding: 1rem;
    border: 1px solid rgba(17, 19, 26, 0.08);
    border-radius: 1.1rem;
    background: rgba(247, 249, 253, 0.72);
  }

  .contact-form__optional summary {
    cursor: pointer;
    color: var(--color-text);
  }

  .hp-field,
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  .contact-feedback {
    display: none;
    align-items: flex-start;
    gap: 0.7rem;
    padding: 1rem 1.05rem;
    border-radius: 1.1rem;
    border: 1px solid rgba(17, 19, 26, 0.12);
    background: rgba(255, 255, 255, 0.94);
    color: var(--color-text);
    line-height: 1.65;
  }

  .contact-feedback::before {
    content: '';
    flex: 0 0 0.8rem;
    width: 0.8rem;
    height: 0.8rem;
    margin-top: 0.35rem;
    border-radius: 999px;
    background: rgba(74, 54, 41, 0.22);
  }

  .contact-feedback[data-state='success'] {
    border-color: rgba(31, 107, 255, 0.18);
    background: rgba(243, 247, 255, 0.95);
    color: var(--theme-accent-strong);
  }

  .contact-feedback[data-state='success']::before {
    background: var(--theme-accent-strong);
  }

  .contact-feedback[data-state='error'] {
    border-color: rgba(160, 76, 56, 0.18);
    background: rgba(252, 244, 241, 0.95);
    color: #7d3d2f;
  }

  .contact-feedback[data-state='error']::before {
    background: #a04c38;
  }

  .contact-feedback[data-state='loading'] {
    border-color: rgba(31, 107, 255, 0.16);
    background: rgba(245, 248, 255, 0.96);
    color: var(--color-text);
  }

  .contact-feedback[data-state='loading']::before {
    background: var(--theme-accent);
    animation: pulse-dot 1.2s ease-in-out infinite;
  }

  .contact-feedback.is-visible {
    display: flex;
  }

  @keyframes pulse-dot {
    0%,
    100% {
      opacity: 0.38;
      transform: scale(0.92);
    }
    50% {
      opacity: 1;
      transform: scale(1);
    }
  }

  @media (max-width: 1040px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .contact-panel,
    .contact-form-wrap {
      padding: 1.3rem;
    }

    .contact-form__optional {
      padding: 1rem;
    }

    .contact-grid {
      gap: 1.15rem;
    }
  }
</style>

<script is:inline define:vars={{ locale }}>
  const messages = {
    es: {
      send: 'Enviar briefing',
      sending: 'Enviando…',
      sendingDetail: 'Enviando tu mensaje…',
      required: 'Completa nombre, email, tipo de proyecto y mensaje.',
      success: 'Mensaje enviado. Revisaré el contexto y te responderé por email.',
      error: 'No se pudo enviar el mensaje. Inténtalo de nuevo más tarde.',
    },
    en: {
      send: 'Send project brief',
      sending: 'Sending…',
      sendingDetail: 'Sending your message…',
      required: 'Please complete name, email, project type and message.',
      success: 'Message sent. I will review the details and reply by email.',
      error: 'The message could not be sent. Please try again later.',
    },
  };

  function bindContactForm() {
    const form = document.getElementById('contact-form');
    if (!form || form.dataset.bound === 'true') return;

    form.dataset.bound = 'true';
    const feedback = document.getElementById('contact-feedback');
    const button = form.querySelector('button[type="submit"]');
    const t = messages[locale];

    function setFeedback(state, message) {
      if (!feedback) return;
      feedback.hidden = false;
      feedback.textContent = message;
      feedback.dataset.state = state;
      feedback.classList.add('is-visible');

      if (state !== 'loading') {
        feedback.focus({ preventScroll: true });
      }
    }

    function clearFeedback() {
      if (!feedback) return;
      feedback.hidden = true;
      feedback.textContent = '';
      feedback.dataset.state = '';
      feedback.classList.remove('is-visible');
    }

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!button) return;

      const formData = new FormData(form);
      const payload = Object.fromEntries(formData.entries());
      payload.locale = locale;

      if (!payload.name || !payload.email || !payload.type || !payload.message) {
        setFeedback('error', t.required);
        return;
      }

      clearFeedback();
      button.disabled = true;
      button.setAttribute('aria-busy', 'true');
      button.textContent = t.sending;
      setFeedback('loading', t.sendingDetail);

      try {
        const response = await fetch('/api/contact', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Accept: 'application/json',
          },
          body: JSON.stringify(payload),
        });

        const result = await response.json();

        if (!response.ok) {
          throw new Error(result.error || t.error);
        }

        form.reset();
        window.dispatchEvent(new CustomEvent('site:lead-submitted', { detail: { locale } }));
        const thanksPath = locale === 'en' ? '/en/thanks' : '/thanks';
        window.setTimeout(() => {
          window.location.href = thanksPath;
        }, 200);
      } catch (error) {
        setFeedback('error', error instanceof Error ? error.message : t.error);
      } finally {
        button.disabled = false;
        button.removeAttribute('aria-busy');
        button.textContent = t.send;
      }
    });
  }

  bindContactForm();
  document.addEventListener('astro:after-swap', bindContactForm);
</script>
