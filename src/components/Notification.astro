---
interface Props {
  type: 'success' | 'error';
  message: string;
}

const { type, message } = Astro.props;
---

<div class="notification" data-type={type}>
  <div class="notification-content">
    {type === 'success' && (
      <svg xmlns="http://www.w3.org/2000/svg" class="notification-icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
      </svg>
    )}
    {type === 'error' && (
      <svg xmlns="http://www.w3.org/2000/svg" class="notification-icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
      </svg>
    )}
    <div class="notification-copy">
      <span>{message}</span>
    </div>
  </div>
</div>

<style>
  .notification {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    max-width: min(26rem, calc(100vw - 2rem));
    padding: 1rem 1.05rem;
    border-radius: 1.1rem;
    border: 1px solid rgba(74, 54, 41, 0.12);
    background: rgba(255, 250, 244, 0.96);
    box-shadow: 0 18px 36px rgba(28, 18, 12, 0.14);
    backdrop-filter: blur(16px);
    animation: slideIn 0.28s ease-out forwards;
    z-index: 1000;
  }

  .notification[data-type="success"] {
    border-color: rgba(33, 68, 63, 0.16);
    background: rgba(244, 250, 248, 0.96);
    color: #21443f;
  }

  .notification[data-type="error"] {
    border-color: rgba(160, 76, 56, 0.16);
    background: rgba(252, 244, 241, 0.96);
    color: #8e4634;
  }

  .notification-content {
    display: flex;
    align-items: flex-start;
    gap: 0.8rem;
  }

  .notification-icon {
    flex: 0 0 1.1rem;
    width: 1.1rem;
    height: 1.1rem;
    margin-top: 0.16rem;
  }

  .notification-copy span {
    font-size: 0.93rem;
    line-height: 1.6;
  }

  @keyframes slideIn {
    from {
      transform: translateY(12px);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  @keyframes slideOut {
    from {
      transform: translateY(0);
      opacity: 1;
    }
    to {
      transform: translateY(12px);
      opacity: 0;
    }
  }

  @media (max-width: 640px) {
    .notification {
      right: 0.75rem;
      bottom: 0.75rem;
      max-width: calc(100vw - 1.5rem);
    }
  }
</style> 
