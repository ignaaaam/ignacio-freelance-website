---
import { getLocaleFromPath } from '../i18n/utils';
import { siteContent } from '../data/siteContent';

const locale = getLocaleFromPath(Astro.url.pathname);
const content = siteContent[locale].process;
const primaryCta = siteContent[locale].nav.primaryCta;
---

<section class="section section-alt" id="proceso">
  <div class="container">
    <div class="section-heading">
      <p class="section-eyebrow">{content.eyebrow}</p>
      <h2>{content.title}</h2>
      <p class="section-copy">{content.description}</p>
    </div>

    <div class="process-grid">
      {content.steps.map((step, index) => (
        <article class="process-card surface-card" data-sr>
          <div class="process-card__number">{index + 1}</div>
          <h3>{step.title}</h3>
          <p>{step.description}</p>
        </article>
      ))}
    </div>

    <div class="process-cta" data-sr>
      <div class="process-cta__inner surface-card">
        <div class="process-cta__text">
          <p class="process-cta__heading">{locale === 'en' ? 'Ready to talk through the project?' : '¿Listo para hablar del proyecto?'}</p>
          <p class="process-cta__sub">{locale === 'en'
            ? 'Share the essentials and get a useful first recommendation, usually within 24 business hours.'
            : 'Cuéntame lo esencial y recibe una primera recomendación útil, normalmente en 24 horas laborables.'
          }</p>
        </div>
        <a href="#contacto" class="btn-primary process-cta__btn">
          {primaryCta}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .process-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.1rem;
  }

  .process-card {
    position: relative;
    padding: 1.7rem;
  }

  .process-card__number {
    display: inline-grid;
    place-items: center;
    width: 2.55rem;
    aspect-ratio: 1;
    margin-bottom: 1rem;
    border-radius: 999px;
    background: var(--theme-highlight);
    color: var(--theme-dark-text);
    font-family: var(--font-heading);
    font-weight: 800;
    box-shadow: 0 14px 28px rgba(15, 23, 42, 0.14);
  }

  .process-card p {
    margin-top: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.74;
  }

  .process-cta {
    margin-top: 1.45rem;
  }

  .process-cta__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.7rem 1.9rem;
    border-color: rgba(31, 107, 255, 0.16);
    background:
      linear-gradient(135deg, rgba(31, 107, 255, 0.08), transparent 60%),
      var(--color-card-bg);
  }

  .process-cta__text {
    display: grid;
    gap: 0.4rem;
  }

  .process-cta__heading {
    font-family: var(--font-heading);
    font-size: 1.24rem;
    font-weight: 800;
    color: var(--color-text);
  }

  .process-cta__sub {
    color: var(--color-text-muted);
    line-height: 1.65;
    max-width: 52ch;
  }

  .process-cta__btn {
    min-width: max-content;
  }

  @media (max-width: 1100px) {
    .process-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .process-grid {
      grid-template-columns: 1fr;
    }

    .process-card {
      padding: 1.28rem;
    }

    .process-cta__inner {
      flex-direction: column;
      align-items: stretch;
      padding: 1.28rem;
      gap: 1rem;
    }

    .process-cta__btn {
      text-align: center;
    }
  }
</style>
