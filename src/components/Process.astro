---
import { getLocaleFromPath } from '../i18n/utils';
import { siteContent } from '../data/siteContent';

const locale = getLocaleFromPath(Astro.url.pathname);
const content = siteContent[locale].process;
---

<section class="section section-alt" id="proceso">
  <div class="container">
    <div class="section-heading">
      <p class="section-eyebrow">{content.eyebrow}</p>
      <h2>{content.title}</h2>
      <p class="section-copy">{content.description}</p>
    </div>

    <div class="process-grid">
      {content.steps.map((step, index) => (
        <article class="process-card surface-card" data-sr>
          <div class="process-card__number">{index + 1}</div>
          <h3>{step.title}</h3>
          <p>{step.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .process-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .process-card {
    padding: 1.5rem;
  }

  .process-card__number {
    display: inline-grid;
    place-items: center;
    width: 2.4rem;
    aspect-ratio: 1;
    margin-bottom: 1rem;
    border-radius: 999px;
    background: var(--color-text);
    color: var(--color-primary);
    font-family: var(--font-heading);
    font-weight: 800;
  }

  .process-card p {
    margin-top: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.75;
  }

  @media (max-width: 1100px) {
    .process-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .process-grid {
      grid-template-columns: 1fr;
    }

    .process-card {
      padding: 1.15rem;
    }
  }
</style>
