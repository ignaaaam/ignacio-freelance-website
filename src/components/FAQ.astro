---
import { getLocaleFromPath } from '../i18n/utils';
import { siteContent } from '../data/siteContent';

const locale = getLocaleFromPath(Astro.url.pathname);
const content = siteContent[locale].faq;
---

<section class="section" id="faq">
  <div class="container">
    <div class="section-heading">
      <p class="section-eyebrow">{content.eyebrow}</p>
      <h2>{content.title}</h2>
      <p class="section-copy">{content.description}</p>
    </div>

    <div class="faq-list">
      {content.items.map((item) => (
        <details class="faq-item surface-card" data-sr>
          <summary>
            <span>{item.question}</span>
            <span aria-hidden="true">+</span>
          </summary>
          <p>{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-list {
    display: grid;
    gap: 0.8rem;
  }

  .faq-item {
    padding: 1.2rem 1.35rem;
  }

  .faq-item summary {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    cursor: pointer;
    font-weight: 800;
    list-style: none;
  }

  .faq-item summary span:first-child {
    flex: 1;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item p {
    margin-top: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.75;
  }

  .faq-item[open] summary span:last-child {
    transform: rotate(45deg);
  }

  @media (max-width: 720px) {
    .faq-item {
      padding: 1rem 1.05rem;
    }
  }
</style>
