---
import { getLanguageSwitchUrls, getLocaleFromPath } from '../i18n/utils';
import { siteContent } from '../data/siteContent';
import { siteConfig } from '../data/siteConfig';

interface Props {
  languageSwitchUrls?: { es: string; en: string };
}

const currentPath = Astro.url.pathname;
const locale = getLocaleFromPath(currentPath);
const isEnglish = locale === 'en';
const content = siteContent[locale];
const { languageSwitchUrls: customLanguageSwitchUrls } = Astro.props as Props;
const languageSwitchUrls = customLanguageSwitchUrls || getLanguageSwitchUrls(Astro.url);
const homeUrl = isEnglish ? '/en' : '/';
const isHomePage = currentPath === '/' || currentPath === '/en' || currentPath === '/en/';

const toHomeAnchor = (anchor: string) => (isHomePage ? anchor : `${homeUrl}${anchor}`);

const navItems = [
  { label: content.nav.work, href: toHomeAnchor(content.nav.workHref) },
  { label: content.nav.investment, href: toHomeAnchor(content.nav.investmentHref) },
  { label: content.nav.faq, href: toHomeAnchor(content.nav.faqHref) },
  { label: content.nav.blog, href: content.nav.blogHref },
];

const servicePages = isEnglish
  ? [
      { label: 'All services', href: '/en/services', note: 'Overview' },
      { label: 'Landing pages', href: '/en/professional-landing-page-development', note: 'Campaigns and lead gen' },
      { label: 'Business websites', href: '/en/web-design-businesses', note: 'Company websites' },
      { label: 'Laravel development', href: '/en/freelance-laravel-developer', note: 'Custom logic and backends' },
      { label: 'Redesigns', href: '/en/website-redesign-improvements', note: 'UX, trust and performance' },
      { label: 'Maintenance', href: '/en/website-maintenance', note: 'Support and fixes' },
      { label: 'SaaS / MVP', href: '/en/web-application-saas-development', note: 'Products and internal tools' },
      { label: 'Pricing guide', href: '/en/how-much-does-website-cost', note: 'Budget framing' },
      { label: 'FAQ page', href: '/en/frequently-asked-questions', note: 'Process and hiring' },
    ]
  : [
      { label: 'Todos los servicios', href: '/servicios', note: 'Vision general' },
      { label: 'Landing pages', href: '/crear-landing-page-profesional', note: 'Campanas y captacion' },
      { label: 'Webs de empresa', href: '/diseno-web-empresas', note: 'Presencia comercial' },
      { label: 'Desarrollo Laravel', href: '/desarrollador-laravel-freelance', note: 'Backends y logica a medida' },
      { label: 'Redisenos', href: '/rediseno-web-mejoras', note: 'UX, confianza y rendimiento' },
      { label: 'Mantenimiento', href: '/mantenimiento-web', note: 'Soporte y mejoras' },
      { label: 'SaaS / MVP', href: '/desarrollo-aplicacion-web-saas', note: 'Producto y herramientas internas' },
      { label: 'Guia de precios', href: '/cuanto-cuesta-pagina-web', note: 'Rangos e inversion' },
      { label: 'FAQ', href: '/preguntas-frecuentes', note: 'Proceso y contratacion' },
    ];
---

<header class="site-header">
  <div class="container site-header__shell">
    <a href={homeUrl} class="site-header__brand">
      <span class="site-header__brand-row">
        <img src="/brand-mark.svg" alt="" width="30" height="30" />
        <span>{siteConfig.name}</span>
      </span>
      <small>{isEnglish ? 'Freelance web developer' : 'Desarrollador web freelance'}</small>
    </a>

    <nav class="site-header__nav" aria-label={isEnglish ? 'Primary navigation' : 'Navegacion principal'}>
      <div class="site-header__dropdown" data-services-dropdown>
        <button
          type="button"
          class="site-header__link site-header__dropdown-trigger"
          aria-expanded="false"
          aria-controls="services-menu"
          data-services-trigger
        >
          {content.nav.servicesLabel}
          <span aria-hidden="true">+</span>
        </button>
        <div id="services-menu" class="site-header__dropdown-panel">
          {servicePages.map((item, index) => (
            <a href={item.href} class={index === 0 ? 'is-featured' : undefined}>
              <strong>{item.label}</strong>
              <span>{item.note}</span>
            </a>
          ))}
        </div>
      </div>

      {navItems.map((item) => (
        <a href={item.href} class="site-header__link">{item.label}</a>
      ))}
    </nav>

    <div class="site-header__actions">
      <div class="site-header__lang" aria-label={isEnglish ? 'Language selector' : 'Selector de idioma'}>
        <a href={languageSwitchUrls.es} class={!isEnglish ? 'is-active' : undefined}>ES</a>
        <a href={languageSwitchUrls.en} class={isEnglish ? 'is-active' : undefined}>EN</a>
      </div>
      <a href={toHomeAnchor(content.nav.contactHref)} class="btn-primary site-header__cta" data-cta="header-primary">{content.nav.primaryCta}</a>
      <button id="mobile-menu-button" class="site-header__menu" aria-expanded="false" aria-label={isEnglish ? 'Open menu' : 'Abrir menu'}>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="site-header__mobile surface-card" hidden>
    <nav>
      <a href={content.nav.servicesHubHref}>{content.nav.servicesHub}</a>
      {navItems.map((item) => (
        <a
          href={item.href}
          class={item.href.includes('inversion') ? 'site-header__mobile-pricing' : undefined}
        >{item.label}</a>
      ))}
      {servicePages.slice(1).map((item) => (
        <a href={item.href} class="site-header__mobile-sub">{item.label}</a>
      ))}
      <div class="site-header__mobile-row">
        <div class="site-header__lang site-header__lang--mobile">
          <a href={languageSwitchUrls.es} class={!isEnglish ? 'is-active' : undefined}>ES</a>
          <a href={languageSwitchUrls.en} class={isEnglish ? 'is-active' : undefined}>EN</a>
        </div>
        <a href={toHomeAnchor(content.nav.contactHref)} class="btn-primary" data-cta="header-mobile-primary">{content.nav.primaryCta}</a>
      </div>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 60;
    padding: 0.82rem 0 0.52rem;
  }

  .site-header__shell {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: 0.82rem 0.88rem;
    border: 1px solid rgba(74, 54, 41, 0.1);
    border-radius: 1.45rem;
    background: var(--theme-header-bg);
    box-shadow: 0 14px 40px rgba(28, 18, 12, 0.06);
  }

  .site-header__brand {
    display: inline-flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
    font-family: var(--font-heading);
    font-weight: 800;
  }

  .site-header__brand-row {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    min-width: 0;
  }

  .site-header__brand-row span:last-child {
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .site-header__brand small {
    font-family: var(--font-body);
    font-size: 0.78rem;
    color: var(--color-text-muted);
    overflow-wrap: anywhere;
  }

  .site-header__nav,
  .site-header__actions,
  .site-header__lang {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .site-header__nav {
    justify-content: center;
  }

  .site-header__link,
  .site-header__lang a {
    font-weight: 700;
    color: var(--color-text);
  }

  .site-header__link {
    padding: 0.55rem 0.2rem;
    color: var(--color-text-muted);
  }

  .site-header__link:hover {
    color: var(--color-text);
  }

  .site-header__lang {
    padding: 0.28rem;
    border: 1px solid rgba(74, 54, 41, 0.1);
    border-radius: 999px;
    background: #fff9f3;
  }

  .site-header__lang a {
    padding: 0.38rem 0.68rem;
    border-radius: 999px;
    font-size: 0.9rem;
  }

  .site-header__lang .is-active {
    background: var(--theme-highlight);
    color: #fffaf4;
  }

  .site-header__dropdown {
    position: relative;
  }

  .site-header__dropdown-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 0.15rem;
    background: none;
    border: 0;
    cursor: pointer;
  }

  .site-header__dropdown-trigger span:last-child {
    transition: transform 0.18s ease;
  }

  .site-header__dropdown[data-open='true'] .site-header__dropdown-trigger span:last-child {
    transform: rotate(45deg);
  }

  .site-header__dropdown-panel {
    position: absolute;
    top: calc(100% + 0.7rem);
    left: 0;
    display: grid;
    min-width: 320px;
    gap: 0.4rem;
    padding: 0.9rem;
    border: 1px solid rgba(74, 54, 41, 0.12);
    border-radius: 1.2rem;
    background: var(--theme-dropdown-bg);
    box-shadow: 0 24px 60px rgba(28, 18, 12, 0.12);
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: opacity 0.18s ease, transform 0.18s ease;
  }

  .site-header__dropdown[data-open='true'] .site-header__dropdown-panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .site-header__dropdown-panel a {
    display: grid;
    gap: 0.2rem;
    padding: 0.72rem 0.78rem;
    border-radius: 0.95rem;
    color: var(--color-text);
  }

  .site-header__dropdown-panel a span {
    color: var(--color-text-muted);
    font-size: 0.88rem;
  }

  .site-header__dropdown-panel a:hover,
  .site-header__dropdown-panel a:focus-visible,
  .site-header__dropdown-panel a.is-featured {
    background: rgba(33, 68, 63, 0.06);
  }

  .site-header__menu {
    display: none;
    flex-direction: column;
    gap: 0.3rem;
    align-items: center;
    justify-content: center;
    width: 2.8rem;
    height: 2.8rem;
    border: 1px solid rgba(74, 54, 41, 0.1);
    border-radius: 999px;
    background: #fff9f3;
    cursor: pointer;
  }

  .site-header__menu span {
    width: 1rem;
    height: 2px;
    background: currentColor;
    border-radius: 999px;
  }

  .site-header__mobile {
    display: none;
    margin: 0.85rem auto 0;
    width: min(var(--container-max), calc(100% - 2rem));
    max-height: calc(100svh - 5.8rem);
    overflow: auto;
    padding: 0.9rem;
  }

  .site-header__mobile nav {
    display: grid;
    gap: 0.28rem;
  }

  .site-header__mobile a {
    padding: 0.68rem 0.8rem;
    border-radius: 0.95rem;
    color: var(--color-text);
    background: rgba(255, 250, 244, 0.95);
  }

  .site-header__mobile-sub {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .site-header__mobile-pricing {
    background: rgba(184, 104, 54, 0.08) !important;
    color: var(--theme-highlight) !important;
    font-weight: 700;
  }

  .site-header__mobile-row {
    display: grid;
    gap: 0.75rem;
    margin-top: 0.7rem;
    padding-top: 0.85rem;
    border-top: 1px solid rgba(74, 54, 41, 0.08);
    position: sticky;
    bottom: -0.1rem;
    background: linear-gradient(180deg, rgba(255, 250, 244, 0), rgba(255, 250, 244, 0.94));
  }

  .site-header__lang--mobile {
    justify-content: center;
  }

  @media (max-width: 980px) {
    .site-header__shell {
      grid-template-columns: auto auto;
      justify-content: space-between;
    }

    .site-header__nav,
    .site-header__cta,
    .site-header__actions > .site-header__lang {
      display: none;
    }

    .site-header__menu {
      display: inline-flex;
    }

    .site-header__mobile[data-open='true'] {
      display: block;
    }
  }

  @media (max-width: 640px) {
    .site-header {
      padding-top: max(0.72rem, env(safe-area-inset-top));
    }

    .site-header__shell {
      padding: 0.78rem;
      gap: 0.65rem;
      border-radius: 1.2rem;
    }

    .site-header__brand small {
      display: none;
    }

    .site-header__mobile {
      width: min(var(--container-max), calc(100% - 2rem));
      padding: 0.78rem;
      border-radius: 1.25rem;
    }

    .site-header__mobile a {
      padding: 0.64rem 0.76rem;
    }
  }
</style>

<script is:inline data-astro-rerun>
  function bindHeaderInteractions() {
    const button = document.getElementById('mobile-menu-button');
    const menu = document.getElementById('mobile-menu');
    const dropdown = document.querySelector('[data-services-dropdown]');
    const trigger = dropdown?.querySelector('[data-services-trigger]');

    if (button && menu && button.dataset.bound !== 'true') {
      const closeMenu = () => {
        button.setAttribute('aria-expanded', 'false');
        menu.hidden = true;
        menu.removeAttribute('data-open');
      };

      button.dataset.bound = 'true';
      closeMenu();

      button.addEventListener('click', () => {
        const isOpen = button.getAttribute('aria-expanded') === 'true';
        if (isOpen) {
          closeMenu();
        } else {
          button.setAttribute('aria-expanded', 'true');
          menu.hidden = false;
          menu.setAttribute('data-open', 'true');
        }
      });

      menu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', closeMenu);
      });
    }

    if (dropdown && trigger && trigger.dataset.bound !== 'true') {
      const closeDropdown = () => {
        dropdown.removeAttribute('data-open');
        trigger.setAttribute('aria-expanded', 'false');
      };

      trigger.dataset.bound = 'true';
      closeDropdown();

      trigger.addEventListener('click', () => {
        const isOpen = dropdown.getAttribute('data-open') === 'true';
        if (isOpen) {
          closeDropdown();
        } else {
          dropdown.setAttribute('data-open', 'true');
          trigger.setAttribute('aria-expanded', 'true');
        }
      });

      document.addEventListener('click', (event) => {
        if (!dropdown.contains(event.target)) {
          closeDropdown();
        }
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          closeDropdown();
        }
      });

      dropdown.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', closeDropdown);
      });
    }
  }

  bindHeaderInteractions();
  document.addEventListener('astro:after-swap', bindHeaderInteractions);
</script>
