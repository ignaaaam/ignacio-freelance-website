---
import { render } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Header from './Header.astro';
import Contact from './Contact.astro';
import StickyCTA from './StickyGTA.astro';
import type { BlogEntry } from '../data/blog';
import {
  formatBlogDate,
  getBlogEntryPathSlug,
  getBlogIndexUrl,
  getBlogPostUrl,
  getLocalizedServiceLinks,
} from '../data/blog';
import commercialNav from '../data/blog-commercial-nav.json';

interface Props {
  entry: BlogEntry;
  alternateUrls: { es?: string; en?: string };
  relatedPosts: BlogEntry[];
}

const { entry, alternateUrls, relatedPosts } = Astro.props;
const { Content, headings } = await render(entry);
const locale = entry.data.locale;
const isEnglish = locale === 'en';
const pathSlug = getBlogEntryPathSlug(entry);
const canonicalUrl = getBlogPostUrl(locale, pathSlug);
const baseUrl = 'https://www.ignacioamatweb.com';
const serviceLinks = getLocalizedServiceLinks(entry.data.relatedServices, locale);
const publishedDate = entry.data.publishedDate.toISOString().split('T')[0];
const modifiedDate = (entry.data.updatedDate ?? entry.data.publishedDate).toISOString().split('T')[0];
const pageTitle = entry.data.title;
const pageDescription = entry.data.description;
const image = entry.data.heroImage.startsWith('http')
  ? entry.data.heroImage
  : `${baseUrl}${entry.data.heroImage}`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: isEnglish ? 'Home' : 'Inicio',
      item: isEnglish ? `${baseUrl}/en/` : baseUrl,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Blog',
      item: `${baseUrl}${getBlogIndexUrl(locale)}`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: entry.data.title,
      item: `${baseUrl}${canonicalUrl}`,
    },
  ],
};

const schemaKeywords = [...entry.data.keywords, ...entry.data.tags].filter(Boolean);
const keywordString = [...new Set(schemaKeywords)].join(', ');

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: entry.data.title,
  description: entry.data.description,
  image,
  author: {
    '@type': 'Person',
    name: entry.data.author,
    url: baseUrl,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Ignacio Amat - Web Development',
    logo: {
      '@type': 'ImageObject',
      url: `${baseUrl}/brand-mark.svg`,
    },
  },
  datePublished: publishedDate,
  dateModified: modifiedDate,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${baseUrl}${canonicalUrl}`,
  },
  inLanguage: isEnglish ? 'en-US' : 'es-ES',
  ...(keywordString ? { keywords: keywordString } : {}),
};

const faqSchema = entry.data.faq?.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: entry.data.faq.map((item) => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.answer,
        },
      })),
    }
  : null;

const additionalSchemas = faqSchema ? [breadcrumbSchema, articleSchema, faqSchema] : [breadcrumbSchema, articleSchema];
const tocHeadings = headings.filter((heading) => heading.depth <= 2);
const stripLocale = commercialNav[locale];
const commercialStrip = stripLocale.commercialStrip;
---

<Layout
  title={pageTitle}
  description={pageDescription}
  lang={locale}
  canonicalUrl={canonicalUrl}
  image={image}
  imageAlt={entry.data.heroImageAlt}
  type="article"
  publishedDate={publishedDate}
  modifiedDate={modifiedDate}
  articleSection={entry.data.category}
  alternateUrls={alternateUrls}
  additionalSchemas={additionalSchemas}
  keywords={[...new Set([...entry.data.keywords, ...entry.data.tags])]}
>
  <Header languageSwitchUrls={alternateUrls} />
  <main>
    <article class="section">
      <div class="container article-layout">
        <header class="article-hero surface-card" data-sr>
          <nav class="article-breadcrumbs" aria-label="Breadcrumb">
            <a href={isEnglish ? '/en/' : '/'}>{isEnglish ? 'Home' : 'Inicio'}</a>
            <span>/</span>
            <a href={getBlogIndexUrl(locale)}>Blog</a>
            <span>/</span>
            <span>{entry.data.title}</span>
          </nav>

          <p class="section-eyebrow">{entry.data.category}</p>
          <h1>{entry.data.title}</h1>
          <div class="article-meta">
            <span>{entry.data.author}</span>
            <span>{formatBlogDate(entry.data.publishedDate, locale)}</span>
            <span>{entry.data.readTime}</span>
          </div>
          <p class="article-intro">{entry.data.description}</p>
          <img
            src={entry.data.heroImage}
            alt={entry.data.heroImageAlt}
            class="article-hero__image"
            width="1200"
            height="900"
            loading="eager"
            decoding="async"
          />
          {entry.data.heroImageCredit && (
            <p class="image-credit">{entry.data.heroImageCredit}</p>
          )}
        </header>

        <div class="article-shell surface-card" data-sr>
          <div class="article-layout__content">
            {tocHeadings.length > 0 && (
              <aside class="toc-card">
                <h2>{isEnglish ? 'Contents' : 'Contenido'}</h2>
                <ol>
                  {tocHeadings.map((heading) => (
                    <li><a href={`#${heading.slug}`}>{heading.text}</a></li>
                  ))}
                </ol>
              </aside>
            )}

            <div class="article-content">
              <Content />
            </div>
          </div>
        </div>

        <section class="commercial-strip surface-card" data-sr aria-label={isEnglish ? 'High-intent guides' : 'Guías de alta intención'}>
          <p class="section-eyebrow">{stripLocale.commercialStripEyebrow}</p>
          <h2 class="commercial-strip__title">{stripLocale.commercialStripTitle}</h2>
          <p class="commercial-strip__intro">{stripLocale.commercialStripIntro}</p>
          <div class="commercial-strip__grid">
            {commercialStrip.map((item) => (
              <a href={item.href} class="commercial-strip__card" data-cta="blog-commercial-strip">
                <span class="commercial-strip__card-label">{item.label}</span>
                <span class="commercial-strip__card-hint">{item.hint}</span>
              </a>
            ))}
          </div>
        </section>

        <div class="article-footer-grid">
          {serviceLinks.length > 0 && (
            <section class="article-panel surface-card" data-sr>
              <p class="section-eyebrow">{isEnglish ? 'Relevant services' : 'Servicios relacionados'}</p>
              <h2>{isEnglish ? 'Where this topic connects with the work I do' : 'Dónde encaja este tema con mi trabajo'}</h2>
              <div class="article-links">
                {serviceLinks.map((link) => (
                  <a href={link.href} class="article-links__card">
                    <h3>{link.label}</h3>
                    <p>{isEnglish ? 'See service details and fit' : 'Ver detalles del servicio y encaje'}</p>
                  </a>
                ))}
              </div>
            </section>
          )}

          {relatedPosts.length > 0 && (
            <section class="article-panel surface-card" data-sr>
              <p class="section-eyebrow">{isEnglish ? 'More articles' : 'Más artículos'}</p>
              <h2>{isEnglish ? 'Keep reading' : 'Seguir leyendo'}</h2>
              <div class="article-links">
                {relatedPosts.map((post) => (
                  <a href={getBlogPostUrl(locale, getBlogEntryPathSlug(post))} class="article-links__card">
                    <h3>{post.data.title}</h3>
                    <p>{post.data.description}</p>
                  </a>
                ))}
              </div>
            </section>
          )}
        </div>
      </div>
    </article>

    <Contact />
    <StickyCTA />
  </main>
</Layout>

<style>
  .article-layout {
    display: grid;
    gap: 1.15rem;
    max-width: 1080px;
  }

  .article-hero,
  .article-shell,
  .article-panel {
    padding: 1.75rem;
  }

  .article-breadcrumbs,
  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    color: var(--color-text-muted);
    font-size: 0.94rem;
  }

  .article-breadcrumbs {
    margin-bottom: 1rem;
  }

  .article-hero {
    background:
      radial-gradient(circle at top left, rgba(31, 107, 255, 0.2), transparent 28%),
      linear-gradient(180deg, rgba(10, 12, 18, 0.98), rgba(13, 16, 24, 0.98));
    color: var(--theme-dark-text);
    border-color: rgba(255, 255, 255, 0.08);
  }

  .article-breadcrumbs,
  .article-meta,
  .article-intro,
  .image-credit {
    color: var(--theme-dark-muted);
  }

  .article-hero .section-eyebrow {
    border-color: rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.06);
    color: rgba(246, 248, 252, 0.82);
  }

  .article-hero h1 {
    max-width: min(22ch, 100%);
    margin-bottom: 1rem;
    color: var(--theme-dark-text);
    font-size: clamp(2.8rem, 6vw, 5rem);
  }

  .article-intro {
    max-width: 64ch;
    margin-top: 1rem;
    font-size: 1.08rem;
    line-height: 1.78;
  }

  .article-hero__image {
    width: 100%;
    margin-top: 1.4rem;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 1.4rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.12);
  }

  .image-credit {
    font-size: 0.72rem;
    text-align: right;
    margin-top: 0.35rem;
    opacity: 0.75;
  }

  .article-layout__content {
    display: grid;
    gap: 1.25rem;
  }

  .toc-card {
    padding: 1rem 1.05rem;
    border: 1px solid rgba(17, 19, 26, 0.08);
    border-radius: 1.15rem;
    background: rgba(247, 249, 253, 0.9);
  }

  .toc-card h2 {
    font-size: 1rem;
  }

  .toc-card ol {
    margin: 0.9rem 0 0;
    padding-left: 1rem;
    color: var(--color-text-muted);
    display: grid;
    gap: 0.55rem;
  }

  .toc-card a {
    color: var(--color-text-muted);
  }

  .toc-card a:hover {
    color: var(--theme-accent-strong);
  }

  .article-footer-grid {
    display: grid;
    gap: 1.15rem;
  }

  .article-links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
    margin-top: 1rem;
  }

  .article-links__card {
    padding: 1rem 1.05rem;
    border: 1px solid rgba(17, 19, 26, 0.08);
    border-radius: 1.15rem;
    background: rgba(247, 249, 253, 0.9);
  }

  .article-links__card p {
    margin-top: 0.45rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  /* Injected by rehype-blog-mid-cta (Markdown body) */
  .article-content :global(.blog-mid-cta) {
    margin: 1.55rem 0;
    padding: 1.25rem 1.35rem;
    border-radius: 1.15rem;
    border: 1px solid rgba(31, 107, 255, 0.22);
    background: linear-gradient(135deg, rgba(31, 107, 255, 0.06), rgba(247, 249, 253, 0.96));
    display: grid;
    gap: 0.65rem;
  }

  .article-content :global(.blog-mid-cta__title) {
    margin: 0;
    font-size: 1.08rem;
    line-height: 1.28;
    letter-spacing: -0.02em;
  }

  .article-content :global(.blog-mid-cta__body) {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.65;
    font-size: 0.96rem;
    max-width: 62ch;
  }

  .article-content :global(.blog-mid-cta__primary) {
    justify-self: start;
    margin-top: 0.15rem;
  }

  .article-content :global(.blog-mid-cta__secondary-heading) {
    margin: 0.5rem 0 0;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .article-content :global(.blog-mid-cta__links) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem 1rem;
    align-items: center;
  }

  .article-content :global(.blog-mid-cta__secondary-link) {
    font-size: 0.9rem;
    font-weight: 650;
    color: var(--theme-accent-strong);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .article-content :global(.blog-mid-cta__secondary-link:hover) {
    color: var(--theme-accent);
  }

  @media (min-width: 960px) {
    .article-layout__content {
      grid-template-columns: minmax(220px, 260px) minmax(0, 1fr);
      align-items: start;
    }

    .toc-card {
      position: sticky;
      top: 6.4rem;
    }
  }

  @media (max-width: 720px) {
    .article-hero,
    .article-shell,
    .article-panel {
      padding: 1.3rem;
    }

    .article-hero h1 {
      max-width: none;
    }

    .article-links {
      grid-template-columns: 1fr;
    }
  }
</style>
