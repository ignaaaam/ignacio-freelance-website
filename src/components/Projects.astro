---
import { getLocaleFromPath } from '../i18n/utils';
import { siteContent } from '../data/siteContent';

const locale = getLocaleFromPath(Astro.url.pathname);
const content = siteContent[locale].portfolio;
---

<section class="section" id="proyectos">
  <div class="container">
    <div class="section-heading">
      <p class="section-eyebrow">{content.eyebrow}</p>
      <h2>{content.title}</h2>
      <p class="section-copy">{content.description}</p>
    </div>

    <div class="project-grid">
      {content.items.map((item) => (
        <article class="project-card surface-card" data-sr>
          <div class="project-card__visual">
            <div class="project-card__browser">
              <span></span><span></span><span></span>
            </div>
            <img
              src={item.visual.imageSrc}
              alt={item.visual.imageAlt}
              class="project-card__image"
              loading="lazy"
              decoding="async"
              width="1600"
              height="1000"
            />
            <p class="project-card__eyebrow">{item.visual.eyebrow}</p>
            <h3>{item.visual.headline}</h3>
            <p>{item.visual.caption}</p>
            <div class="project-card__metrics">
              {item.visual.metrics.map((metric) => (
                <span>{metric}</span>
              ))}
            </div>
          </div>

          <div class="project-card__body">
            <div class="project-card__heading">
              <p class="project-card__type">{item.category}</p>
              <h3>{item.name}</h3>
            </div>
            <p class="project-card__summary">{item.summary}</p>

            <div class="project-card__stack">
              {item.stack.map((entry) => (
                <span>{entry}</span>
              ))}
            </div>

            <div class="project-card__result">
              <strong>{locale === 'en' ? 'Primary goal' : 'Objetivo principal'}</strong>
              <p>{item.outcome}</p>
            </div>

            <p class="project-card__detail">{item.detail}</p>

            <div class="project-card__actions">
              <a href={item.primaryLink.href} class="btn-primary">{item.primaryLink.label}</a>
              {item.secondaryLink && <a href={item.secondaryLink.href} class="btn-secondary">{item.secondaryLink.label}</a>}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .project-grid {
    display: grid;
    gap: 1.25rem;
  }

  .project-card {
    display: grid;
    grid-template-columns: minmax(320px, 0.96fr) minmax(0, 1.04fr);
    overflow: hidden;
  }

  .project-card__visual,
  .project-card__body {
    padding: 1.95rem;
    min-width: 0;
  }

  .project-card__visual {
    border-right: 1px solid rgba(17, 19, 26, 0.08);
    background:
      radial-gradient(circle at top right, rgba(31, 107, 255, 0.16), transparent 35%),
      linear-gradient(160deg, rgba(255, 255, 255, 0.86), rgba(246, 248, 252, 0.6));
  }

  .project-card__browser {
    display: flex;
    gap: 0.35rem;
    margin-bottom: 1.2rem;
  }

  .project-card__browser span {
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 999px;
    background: rgba(17, 19, 26, 0.12);
  }

  .project-card__eyebrow,
  .project-card__type {
    margin-bottom: 0.6rem;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--theme-accent-strong);
  }

  .project-card__visual h3,
  .project-card__heading h3 {
    font-size: clamp(1.5rem, 2vw, 1.9rem);
  }

  .project-card__image {
    display: block;
    width: 100%;
    margin-bottom: 1.15rem;
    border: 1px solid rgba(17, 19, 26, 0.08);
    border-radius: 1.3rem;
    overflow: hidden;
    box-shadow: 0 20px 36px rgba(16, 23, 36, 0.08);
  }

  .project-card__visual p,
  .project-card__summary,
  .project-card__detail,
  .project-card__result p {
    color: var(--color-text-muted);
    line-height: 1.75;
  }

  .project-card__metrics,
  .project-card__stack,
  .project-card__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.74rem;
  }

  .project-card__metrics {
    margin-top: 1.25rem;
  }

  .project-card__metrics span,
  .project-card__stack span {
    padding: 0.48rem 0.72rem;
    border-radius: 999px;
    border: 1px solid rgba(17, 19, 26, 0.08);
    font-size: 0.86rem;
    background: rgba(255, 255, 255, 0.82);
  }

  .project-card__stack {
    margin-top: 1rem;
  }

  .project-card__result {
    margin-top: 1.2rem;
    padding-top: 1.2rem;
    border-top: 1px solid rgba(17, 19, 26, 0.08);
  }

  .project-card__detail {
    margin-top: 1rem;
  }

  .project-card__actions {
    margin-top: 1.3rem;
  }

  @media (max-width: 1024px) {
    .project-card {
      grid-template-columns: 1fr;
    }

    .project-card__visual {
      border-right: 0;
      border-bottom: 1px solid rgba(17, 19, 26, 0.08);
    }
  }

  @media (max-width: 720px) {
    .project-card__visual,
    .project-card__body {
      padding: 1.35rem;
    }

    .project-card__visual h3,
    .project-card__heading h3 {
      font-size: 1.35rem;
    }

    .project-card__actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
