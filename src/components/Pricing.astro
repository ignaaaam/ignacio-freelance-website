---
import { getLocaleFromPath } from '../i18n/utils';
import { siteContent } from '../data/siteContent';

const locale = getLocaleFromPath(Astro.url.pathname);
const content = siteContent[locale].investment;
---

<section class="section" id="inversion">
  <div class="container">
    <div class="section-heading">
      <p class="section-eyebrow">{content.eyebrow}</p>
      <h2>{content.title}</h2>
      <p class="section-copy">{content.description}</p>
    </div>

    <div class="investment-grid">
      {content.cards.map((card) => (
        <article class={`investment-card surface-card ${card.tone === 'featured' ? 'investment-card--featured' : ''}`} data-sr>
          <p class="investment-card__name">{card.name}</p>
          <h3>{card.price}</h3>
          <p class="investment-card__summary">{card.summary}</p>
          <ul>
            {card.bullets.map((bullet) => (
              <li>{bullet}</li>
            ))}
          </ul>
          <a href="#contacto" class={card.tone === 'featured' ? 'btn-primary' : 'btn-secondary'}>
            {locale === 'en' ? 'Request a proposal' : 'Solicitar propuesta'}
          </a>
        </article>
      ))}
    </div>

    <p class="investment-note">{content.note}</p>
  </div>
</section>

<style>
  .investment-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .investment-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.6rem;
  }

  .investment-card--featured {
    border-color: rgba(192, 106, 42, 0.45);
    box-shadow: 0 24px 58px rgba(192, 106, 42, 0.16);
  }

  .investment-card__name {
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--theme-highlight);
  }

  .investment-card h3 {
    font-size: 2rem;
  }

  .investment-card__summary,
  .investment-card li,
  .investment-note {
    color: var(--color-text-muted);
    line-height: 1.75;
  }

  .investment-card ul {
    display: grid;
    gap: 0.75rem;
    margin: 0;
    padding-left: 1rem;
    flex: 1;
  }

  .investment-note {
    max-width: 68ch;
    margin-top: 1.4rem;
  }

  @media (max-width: 1100px) {
    .investment-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .investment-grid {
      grid-template-columns: 1fr;
    }

    .investment-card {
      padding: 1.3rem;
    }
  }
</style>
