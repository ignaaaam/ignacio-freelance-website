---
import { getLocaleFromPath } from '../i18n/utils';
import { siteContent } from '../data/siteContent';

const locale = getLocaleFromPath(Astro.url.pathname);
const nav = siteContent[locale].nav;
---

<div id="sticky-cta" class="sticky-cta">
  <div class="sticky-cta__content">
    <div>
      <strong>{locale === 'en' ? 'Want a clearer proposal?' : 'Quieres una propuesta mas clara?'}</strong>
      <p>{locale === 'en' ? 'Share the project and I will send you a useful first recommendation.' : 'Cuentame el proyecto y te dare una primera recomendacion util.'}</p>
    </div>
    <a href={nav.contactHref} class="btn-primary">{nav.primaryCta}</a>
  </div>
</div>

<style>
  .sticky-cta {
    position: fixed;
    left: 0;
    right: 0;
    bottom: max(0.85rem, env(safe-area-inset-bottom));
    z-index: 40;
    display: none;
    justify-content: center;
    pointer-events: none;
  }

  .sticky-cta[data-visible='true'] {
    display: flex;
  }

  .sticky-cta__content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: min(920px, calc(100% - 1.2rem));
    padding: 1rem 1.05rem;
    border: 1px solid rgba(74, 54, 41, 0.08);
    border-radius: 1.35rem;
    background: rgba(31, 23, 18, 0.95);
    box-shadow: 0 20px 48px rgba(15, 11, 8, 0.28);
    pointer-events: auto;
  }

  .sticky-cta__content strong,
  .sticky-cta__content p {
    color: #fff8f2;
  }

  .sticky-cta__content p {
    margin-top: 0.25rem;
    font-size: 0.94rem;
    opacity: 0.86;
  }

  .sticky-cta .btn-primary {
    min-width: max-content;
  }

  @media (max-width: 720px) {
    .sticky-cta__content {
      flex-direction: column;
      align-items: stretch;
      padding: 0.95rem;
      border-radius: 1.15rem;
    }
  }
</style>

<script is:inline data-astro-rerun>
  function bindStickyCta() {
    const sticky = document.getElementById('sticky-cta');
    const contactRoot = document.querySelector('[data-contact-root]');
    const footerRoot = document.querySelector('[data-footer-root]');
    if (!sticky || sticky.dataset.bound === 'true') return;

    sticky.dataset.bound = 'true';

    const toggleByScroll = () => {
      if (window.scrollY > 520) {
        sticky.setAttribute('data-visible', 'true');
      } else {
        sticky.removeAttribute('data-visible');
      }
    };

    const hideSticky = () => sticky.removeAttribute('data-visible');
    toggleByScroll();
    window.addEventListener('scroll', toggleByScroll, { passive: true });

    if (contactRoot) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            hideSticky();
          } else {
            toggleByScroll();
          }
        });
      }, { threshold: 0.15 });

      observer.observe(contactRoot);
    }

    if (footerRoot) {
      const footerObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            hideSticky();
          } else {
            toggleByScroll();
          }
        });
      }, { threshold: 0.08 });

      footerObserver.observe(footerRoot);
    }
  }

  bindStickyCta();
  document.addEventListener('astro:after-swap', bindStickyCta);
</script>
