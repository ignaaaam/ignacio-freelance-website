---
import { getLocaleFromPath } from '../i18n/utils';
import { siteContent } from '../data/siteContent';

const locale = getLocaleFromPath(Astro.url.pathname);
const nav = siteContent[locale].nav;
---

<div id="sticky-cta" class="sticky-cta">
  <div class="sticky-cta__content">
    <div>
      <strong>{locale === 'en' ? 'Need a website that makes your offer easier to understand?' : '¿Necesitas una web que explique mejor tu oferta?'}</strong>
      <p>{locale === 'en' ? 'Tell me the goal, timing and context. I will tell you if it looks like a fit and what I would suggest next.' : 'Cuéntame objetivo, plazo y contexto. Te diré si encaja y cuál te recomiendo como siguiente paso.'}</p>
    </div>
    <a href={nav.contactHref} class="btn-primary" data-cta="sticky-primary">{nav.primaryCta}</a>
  </div>
</div>

<style>
  .sticky-cta {
    position: fixed;
    left: 0;
    right: 0;
    bottom: max(1rem, env(safe-area-inset-bottom));
    z-index: 40;
    display: none;
    justify-content: center;
    pointer-events: none;
  }

  .sticky-cta[data-visible='true'] {
    display: flex;
  }

  .sticky-cta__content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.2rem;
    width: min(1040px, calc(100% - 2rem));
    padding: 1rem 1.15rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.6rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.02)),
      rgba(10, 12, 18, 0.92);
    box-shadow: 0 24px 60px rgba(6, 9, 15, 0.28);
    backdrop-filter: blur(26px);
    pointer-events: auto;
  }

  .sticky-cta__content strong,
  .sticky-cta__content p {
    color: var(--theme-dark-text);
  }

  .sticky-cta__content p {
    margin-top: 0.32rem;
    max-width: 54ch;
    font-size: 0.95rem;
    color: var(--theme-dark-muted);
  }

  .sticky-cta .btn-primary {
    min-width: max-content;
  }

  @media (max-width: 720px) {
    .sticky-cta__content {
      flex-direction: column;
      align-items: stretch;
      padding: 1rem;
      border-radius: 1.28rem;
    }

    .sticky-cta__content p {
      font-size: 0.92rem;
    }
  }
</style>

<script is:inline data-astro-rerun>
  function bindStickyCta() {
    const sticky = document.getElementById('sticky-cta');
    const contactRoot = document.querySelector('[data-contact-root]');
    const footerRoot = document.querySelector('[data-footer-root]');
    const consentBanner = document.getElementById('cookie-consent');
    if (!sticky || sticky.dataset.bound === 'true') return;

    sticky.dataset.bound = 'true';

    const toggleByScroll = () => {
      const consentVisible = consentBanner && !consentBanner.hidden && consentBanner.getAttribute('data-visible') === 'true';
      if (consentVisible) {
        hideSticky();
        return;
      }

      if (window.scrollY > 520) {
        sticky.setAttribute('data-visible', 'true');
      } else {
        sticky.removeAttribute('data-visible');
      }
    };

    const hideSticky = () => sticky.removeAttribute('data-visible');
    toggleByScroll();
    window.addEventListener('scroll', toggleByScroll, { passive: true });

    if (contactRoot) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            hideSticky();
          } else {
            toggleByScroll();
          }
        });
      }, { threshold: 0.15 });

      observer.observe(contactRoot);
    }

    if (footerRoot) {
      const footerObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            hideSticky();
          } else {
            toggleByScroll();
          }
        });
      }, { threshold: 0.08 });

      footerObserver.observe(footerRoot);
    }
  }

  bindStickyCta();
  document.addEventListener('astro:after-swap', bindStickyCta);
</script>
