---
import { getLocaleFromPath } from '../i18n/utils';
import { siteContent } from '../data/siteContent';
import { siteConfig } from '../data/siteConfig';

const locale = getLocaleFromPath(Astro.url.pathname);
const content = siteContent[locale].hero;
const isEnglish = locale === 'en';
---

<section class="hero section">
  <div class="container hero__grid">
    <div class="hero__content" data-sr>
      <p class="section-eyebrow">{content.eyebrow}</p>
      <h1>{content.title}</h1>
      <p class="hero__copy">{content.subtitle}</p>

      <div class="hero__actions">
        <a href={content.primaryHref} class="btn-primary">{content.primaryCta}</a>
        <a href={content.secondaryHref} class="btn-secondary">{content.secondaryCta}</a>
      </div>

      <div class="hero__proof">
        {content.proof.map((item) => (
          <span class="pill">{item}</span>
        ))}
      </div>
    </div>

    <aside class="hero__panel surface-card" data-sr>
      <div class="hero__panel-header">
        <div class="hero__portrait-visual">
          <span>IA</span>
        </div>
        <div>
          <p class="hero__panel-name">{content.portraitLabel}</p>
          <p class="hero__panel-role">{content.availability}</p>
        </div>
      </div>

      <div class="hero__meta-grid">
        {content.portraitMeta.map((item) => (
          <article class="hero__meta-card">
            <span>{isEnglish ? 'Built for' : 'Pensado para'}</span>
            <p>{item}</p>
          </article>
        ))}
      </div>

      <div class="hero__panel-footer">
        <div class="hero__channel">
          <span>{isEnglish ? 'Direct email' : 'Email directo'}</span>
          <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
        </div>

        <div class="hero__links">
          <a href={siteConfig.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
          <a href={siteConfig.github} target="_blank" rel="noreferrer">GitHub</a>
        </div>
      </div>
    </aside>
  </div>
</section>

<style>
  .hero {
    padding-top: 2rem;
  }

  .hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.28fr) minmax(300px, 0.92fr);
    gap: 1.25rem;
    align-items: start;
  }

  .hero h1 {
    max-width: 10.5ch;
    font-size: clamp(3rem, 7vw, 5.6rem);
  }

  .hero__copy {
    max-width: 60ch;
    margin-top: 1.25rem;
    color: var(--color-text-muted);
    font-size: clamp(1rem, 2vw, 1.18rem);
    line-height: 1.8;
  }

  .hero__actions,
  .hero__proof,
  .hero__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  .hero__actions {
    margin-top: 1.6rem;
  }

  .hero__proof {
    margin-top: 1.55rem;
  }

  .hero__panel {
    display: grid;
    gap: 1.15rem;
    padding: 1.35rem;
    overflow: hidden;
    align-self: stretch;
  }

  .hero__panel-header {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.95rem;
    align-items: center;
  }

  .hero__portrait-visual {
    display: grid;
    place-items: center;
    width: 5rem;
    aspect-ratio: 4 / 5;
    border-radius: 1.3rem;
    background:
      radial-gradient(circle at 32% 22%, rgba(255, 255, 255, 0.38), transparent 25%),
      linear-gradient(160deg, rgba(184, 104, 54, 0.94), rgba(33, 68, 63, 0.94));
    color: #fff8f2;
    font-family: var(--font-heading);
    font-size: 1.7rem;
    font-weight: 800;
  }

  .hero__panel-name {
    font-family: var(--font-heading);
    font-size: 1.28rem;
    font-weight: 800;
  }

  .hero__panel-role {
    margin-top: 0.35rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .hero__meta-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .hero__meta-card {
    display: grid;
    gap: 0.35rem;
    padding: 0.95rem;
    border: 1px solid rgba(74, 54, 41, 0.1);
    border-radius: 1rem;
    background: rgba(255, 250, 244, 0.82);
  }

  .hero__meta-card:last-child {
    grid-column: 1 / -1;
  }

  .hero__meta-card span {
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    color: var(--theme-highlight);
  }

  .hero__meta-card p {
    color: var(--color-text);
    line-height: 1.7;
  }

  .hero__panel-footer {
    display: grid;
    gap: 0.85rem;
    padding-top: 0.1rem;
  }

  .hero__channel {
    display: grid;
    gap: 0.3rem;
    padding: 0.95rem 1rem;
    border: 1px solid rgba(74, 54, 41, 0.1);
    border-radius: 1rem;
    background: rgba(255, 250, 244, 0.82);
  }

  .hero__channel span {
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    color: var(--theme-highlight);
  }

  .hero__channel a {
    font-weight: 700;
    overflow-wrap: anywhere;
  }

  .hero__links a {
    color: var(--color-text-muted);
    font-weight: 700;
  }

  .hero__links a:hover {
    color: var(--color-text);
  }

  @media (max-width: 1040px) {
    .hero__grid {
      grid-template-columns: 1fr;
    }

    .hero h1 {
      max-width: 12ch;
    }
  }

  @media (max-width: 720px) {
    .hero h1 {
      max-width: none;
      font-size: clamp(2.55rem, 12vw, 3.8rem);
      line-height: 0.98;
    }

    .hero__copy {
      margin-top: 1rem;
      font-size: 0.99rem;
    }

    .hero__actions {
      flex-direction: column;
      align-items: stretch;
    }

    .hero__panel {
      padding: 1.15rem;
    }
  }

  @media (max-width: 640px) {
    .hero__meta-grid {
      grid-template-columns: 1fr;
    }

    .hero__meta-card:last-child {
      grid-column: auto;
    }

    .hero__panel-header {
      gap: 0.8rem;
    }

    .hero__portrait-visual {
      width: 4.2rem;
    }
  }
</style>
