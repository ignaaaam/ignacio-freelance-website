---
import { getLocaleFromPath } from '../i18n/utils';
import { siteContent } from '../data/siteContent';
import { siteConfig } from '../data/siteConfig';

const locale = getLocaleFromPath(Astro.url.pathname);
const content = siteContent[locale].hero;
const isEnglish = locale === 'en';
const panelStatus = isEnglish ? 'Open for selected projects' : 'Disponible para proyectos seleccionados';
const panelFocusLabel = isEnglish ? 'Typical fit' : 'Encaje habitual';
const panelCapabilitiesLabel = isEnglish ? 'In brief' : 'En breve';
const panelContactLabel = isEnglish ? 'Direct contact' : 'Contacto directo';
const panelProfilesLabel = isEnglish ? 'Profiles' : 'Perfiles';
const panelResponse = isEnglish ? siteConfig.responseTimeEn : siteConfig.responseTimeEs;
---

<section class="hero section">
  <div class="container hero__grid">
    <div class="hero__content" data-sr>
      <p class="section-eyebrow">{content.eyebrow}</p>
      <h1>{content.title}</h1>
      <p class="hero__copy">{content.subtitle}</p>

      <div class="hero__actions">
        <a href={content.primaryHref} class="btn-primary">{content.primaryCta}</a>
        <a href={content.secondaryHref} class="btn-secondary">{content.secondaryCta}</a>
      </div>

      <div class="hero__proof">
        {content.proof.map((item) => (
          <span class="pill">{item}</span>
        ))}
      </div>
    </div>

    <aside class="hero__panel surface-card" data-sr>
      <div class="hero__panel-status">
        <span class="hero__status-dot"></span>
        <span>{panelStatus}</span>
      </div>

      <div class="hero__panel-header">
        <div class="hero__portrait-visual">
          <span>IA</span>
        </div>
        <div>
          <p class="hero__panel-name">{content.portraitLabel}</p>
          <p class="hero__panel-role">{isEnglish ? 'Freelance web developer' : 'Desarrollador web freelance'}</p>
        </div>
      </div>

      <div class="hero__panel-highlight">
        <span class="hero__panel-label">{panelFocusLabel}</span>
        <p>{content.availability}</p>
      </div>

      <div class="hero__panel-body">
        <section class="hero__panel-section">
          <span class="hero__panel-label">{panelCapabilitiesLabel}</span>
          <ul class="hero__panel-list">
            {content.portraitMeta.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>

        <section class="hero__panel-section hero__panel-section--contact">
          <span class="hero__panel-label">{panelContactLabel}</span>
          <div class="hero__channel">
            <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
            <p>{panelResponse}</p>
          </div>
        </section>
      </div>

      <div class="hero__panel-footer">
        <span class="hero__panel-label">{panelProfilesLabel}</span>
        <div class="hero__links">
          <a href={siteConfig.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
          <a href={siteConfig.github} target="_blank" rel="noreferrer">GitHub</a>
        </div>
      </div>
    </aside>
  </div>
</section>

<style>
  .hero {
    padding-top: 2rem;
  }

  .hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.18fr) minmax(320px, 0.88fr);
    gap: 1.25rem;
    align-items: start;
  }

  .hero h1 {
    max-width: 11.75ch;
    font-size: clamp(2.8rem, 6vw, 5rem);
  }

  .hero__copy {
    max-width: 58ch;
    margin-top: 1.15rem;
    color: var(--color-text-muted);
    font-size: clamp(0.99rem, 1.55vw, 1.08rem);
    line-height: 1.75;
  }

  .hero__actions,
  .hero__proof,
  .hero__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  .hero__actions {
    margin-top: 1.6rem;
  }

  .hero__proof {
    margin-top: 1.55rem;
  }

  .hero__panel {
    display: grid;
    gap: 1rem;
    padding: 1.35rem;
    overflow: hidden;
    align-self: stretch;
    position: relative;
    background:
      radial-gradient(circle at top right, rgba(184, 104, 54, 0.18), transparent 34%),
      radial-gradient(circle at bottom left, rgba(33, 68, 63, 0.12), transparent 28%),
      var(--color-card-bg);
  }

  .hero__panel::before {
    content: '';
    position: absolute;
    inset: 0 0 auto;
    height: 1px;
    background: linear-gradient(90deg, rgba(184, 104, 54, 0.3), rgba(33, 68, 63, 0.45));
  }

  .hero__panel-status {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    width: fit-content;
    padding: 0.28rem 0.68rem;
    border: 1px solid rgba(33, 68, 63, 0.14);
    border-radius: 999px;
    background: rgba(255, 252, 247, 0.78);
    font-size: 0.72rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--theme-highlight);
  }

  .hero__status-dot {
    width: 0.48rem;
    height: 0.48rem;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--theme-accent), var(--theme-highlight));
    box-shadow: 0 0 0 0.18rem rgba(184, 104, 54, 0.13);
  }

  .hero__panel-header {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.95rem;
    align-items: center;
    padding-bottom: 0.2rem;
  }

  .hero__portrait-visual {
    display: grid;
    place-items: center;
    width: 4.9rem;
    aspect-ratio: 1;
    border-radius: 1.5rem;
    background:
      radial-gradient(circle at 32% 22%, rgba(255, 255, 255, 0.38), transparent 25%),
      linear-gradient(160deg, rgba(184, 104, 54, 0.94), rgba(33, 68, 63, 0.94));
    color: #fff8f2;
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 800;
    box-shadow: 0 18px 36px rgba(33, 68, 63, 0.16);
  }

  .hero__panel-name {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 800;
  }

  .hero__panel-role {
    margin-top: 0.22rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .hero__panel-highlight,
  .hero__panel-section,
  .hero__panel-footer {
    padding: 1rem 1.05rem;
    border: 1px solid rgba(74, 54, 41, 0.1);
    border-radius: 1.15rem;
    background: rgba(255, 250, 244, 0.78);
  }

  .hero__panel-highlight {
    display: grid;
    gap: 0.5rem;
    background:
      linear-gradient(135deg, rgba(184, 104, 54, 0.1), rgba(255, 250, 244, 0.82)),
      rgba(255, 250, 244, 0.82);
  }

  .hero__panel-highlight p {
    font-family: var(--font-heading);
    font-size: clamp(1.2rem, 2vw, 1.55rem);
    line-height: 1.15;
  }

  .hero__panel-body {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
    gap: 0.8rem;
  }

  .hero__panel-section {
    display: grid;
    gap: 0.8rem;
  }

  .hero__panel-section--contact {
    align-content: start;
    grid-column: 1 / -1;
  }

  .hero__panel-label {
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    color: var(--theme-highlight);
  }

  .hero__panel-list {
    display: grid;
    gap: 0.7rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .hero__panel-list li {
    position: relative;
    padding-left: 1.15rem;
    color: var(--color-text);
    line-height: 1.7;
  }

  .hero__panel-list li::before {
    content: '';
    position: absolute;
    top: 0.72rem;
    left: 0;
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--theme-accent), var(--theme-highlight));
  }

  .hero__channel {
    display: grid;
    gap: 0.4rem;
  }

  .hero__channel a {
    font-weight: 700;
    max-width: 100%;
    font-size: clamp(0.8rem, 1vw, 0.92rem);
    white-space: nowrap;
    overflow-wrap: normal;
    word-break: normal;
  }

  .hero__channel p {
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  .hero__panel-footer {
    display: grid;
    gap: 0.75rem;
  }

  .hero__links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.65rem;
    padding: 0.55rem 0.95rem;
    border: 1px solid rgba(74, 54, 41, 0.12);
    border-radius: 999px;
    background: rgba(255, 252, 247, 0.82);
    color: var(--color-text-muted);
    font-weight: 700;
  }

  .hero__links a:hover {
    color: var(--color-text);
  }

  @media (max-width: 1040px) {
    .hero__grid {
      grid-template-columns: 1fr;
    }

    .hero h1 {
      max-width: 13ch;
    }

    .hero__panel-body {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .hero h1 {
      max-width: none;
      font-size: clamp(2.4rem, 11vw, 3.55rem);
      line-height: 1;
    }

    .hero__copy {
      margin-top: 1rem;
      font-size: 0.97rem;
    }

    .hero__actions {
      flex-direction: column;
      align-items: stretch;
    }

    .hero__panel {
      padding: 1.15rem;
    }

    .hero__panel-highlight,
    .hero__panel-section,
    .hero__panel-footer {
      padding: 0.95rem;
    }
  }

  @media (max-width: 640px) {
    .hero__panel-body {
      grid-template-columns: 1fr;
    }

    .hero__panel-header {
      gap: 0.8rem;
    }

    .hero__portrait-visual {
      width: 4.2rem;
    }
  }
</style>
