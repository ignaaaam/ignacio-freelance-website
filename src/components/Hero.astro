---
import { getLocaleFromPath } from '../i18n/utils';
import { siteContent } from '../data/siteContent';
import { siteConfig } from '../data/siteConfig';

const locale = getLocaleFromPath(Astro.url.pathname);
const content = siteContent[locale].hero;
const isEnglish = locale === 'en';
const locationLine = isEnglish ? `${siteConfig.locationEn} · ES/EN` : `${siteConfig.locationEs} · ES/EN`;
---

<section class="hero section">
  <div class="container hero__grid">
    <div class="hero__content" data-sr>
      <p class="section-eyebrow">{content.eyebrow}</p>
      <h1>{content.title}</h1>
      <p class="hero__copy">{content.subtitle}</p>

      <div class="hero__actions">
        <a href={content.primaryHref} class="btn-primary" data-cta="hero-primary">{content.primaryCta}</a>
        <a href={content.secondaryHref} class="btn-secondary" data-cta="hero-secondary">{content.secondaryCta}</a>
      </div>

      <div class="hero__meta">
        <div class="hero__meta-top">
          <div class="hero__fit">
            <span class="hero__meta-label">{content.fitLabel}</span>
            <p>{content.fitText}</p>
            <span class="hero__fit-note">{locationLine}</span>
          </div>

          <div class="hero__contact">
            <span class="hero__meta-label">{content.contactLinksLabel}</span>
            <div class="hero__links">
              <a
                href={siteConfig.linkedin}
                target="_blank"
                rel="noreferrer"
                translate="no"
                aria-label={isEnglish ? 'LinkedIn profile, opens in a new tab' : 'Perfil de LinkedIn, se abre en una pestaña nueva'}
              >
                LinkedIn
              </a>
              <a
                href={siteConfig.github}
                target="_blank"
                rel="noreferrer"
                translate="no"
                aria-label={isEnglish ? 'GitHub profile, opens in a new tab' : 'Perfil de GitHub, se abre en una pestaña nueva'}
              >
                GitHub
              </a>
              <a href={`mailto:${siteConfig.email}`} class="hero__cta-link" aria-label={isEnglish ? 'Send an email' : 'Enviar un email'}>
                Email
              </a>
            </div>
          </div>
        </div>

        <ul class="hero__proof" aria-label={isEnglish ? 'Key project signals' : 'Señales clave del proyecto'}>
          {content.proof.map((item) => (
            <li class="pill">{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: calc(100svh - 5.85rem);
    padding-block: clamp(1.35rem, 2vw, 2rem) clamp(2.2rem, 4vw, 3rem);
    color: var(--theme-dark-text);
    background:
      radial-gradient(circle at top left, rgba(31, 107, 255, 0.24), transparent 30%),
      radial-gradient(circle at bottom right, rgba(255, 255, 255, 0.09), transparent 24%),
      linear-gradient(180deg, rgba(9, 11, 16, 0.98), rgba(12, 15, 22, 0.98));
    overflow: hidden;
  }

  .hero__grid {
    display: grid;
    width: 100%;
    grid-template-columns: minmax(0, 1fr);
    align-items: center;
  }

  .hero__content {
    display: grid;
    align-content: center;
    max-width: min(100%, 70rem);
  }

  .hero h1 {
    max-width: 12ch;
    color: var(--theme-dark-text);
    font-size: clamp(2.95rem, 5.9vw, 5.35rem);
    line-height: 0.92;
    letter-spacing: -0.055em;
    text-wrap: balance;
  }

  .hero__copy {
    max-width: 62ch;
    margin-top: 0.9rem;
    color: var(--theme-dark-muted);
    font-size: clamp(0.98rem, 1.05vw, 1.08rem);
    line-height: 1.62;
  }

  .hero__actions,
  .hero__proof,
  .hero__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  .hero__actions {
    margin-top: 1.15rem;
  }

  .hero__actions .btn-secondary {
    border-color: rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.08);
    color: var(--theme-dark-text);
    box-shadow: none;
  }

  .hero__actions .btn-secondary:hover {
    border-color: rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.12);
    color: var(--theme-dark-text);
    box-shadow: none;
  }

  .hero__proof {
    margin: 0;
    padding: 0;
    list-style: none;
    gap: 0.7rem;
  }

  .hero__actions .btn-primary,
  .hero__actions .btn-secondary {
    min-height: 3.2rem;
    padding: 0.82rem 1.2rem;
  }

  .hero__proof .pill {
    min-height: 2.2rem;
    padding: 0.42rem 0.84rem;
    border-color: rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.06);
    color: var(--theme-dark-text);
    font-size: 0.88rem;
  }

  .hero__meta {
    display: grid;
    gap: 0.9rem;
    max-width: min(100%, 60rem);
    margin-top: 1.3rem;
  }

  .hero__meta-top {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) auto;
    gap: 0.85rem;
    align-items: stretch;
  }

  .hero__fit,
  .hero__contact {
    display: grid;
    gap: 0.45rem;
    align-content: start;
    height: 100%;
    padding: 1rem 1.1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.3rem;
    background: rgba(255, 255, 255, 0.04);
    -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
  }

  .hero__fit p {
    font-family: var(--font-heading);
    font-size: clamp(1rem, 1.25vw, 1.12rem);
    line-height: 1.25;
    color: var(--theme-dark-text);
  }

  .hero__fit-note {
    color: rgba(246, 248, 252, 0.68);
    font-size: 0.84rem;
    line-height: 1.4;
  }

  .hero__meta-label {
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: rgba(246, 248, 252, 0.68);
  }

  .hero__links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.5rem;
    padding: 0.46rem 0.82rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.05);
    color: var(--theme-dark-text);
    font-size: 0.88rem;
    font-weight: 700;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease,
      transform 0.2s ease;
  }

  .hero__links a:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.18);
    color: var(--theme-dark-text);
    transform: translateY(-1px);
  }

  .hero__links a:focus-visible {
    outline: 2px solid var(--theme-accent);
    outline-offset: 2px;
  }

  .hero__links .hero__cta-link {
    background: rgba(31, 107, 255, 0.18);
    color: var(--theme-dark-text);
    border-color: rgba(31, 107, 255, 0.38);
    font-weight: 700;
  }

  .hero__links .hero__cta-link:hover {
    background: rgba(31, 107, 255, 0.28);
    color: var(--theme-dark-text);
  }

  .hero .section-eyebrow {
    border-color: rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.06);
    color: rgba(246, 248, 252, 0.82);
    box-shadow: none;
  }

  @media (max-width: 1040px) {
    .hero {
      display: block;
      min-height: auto;
      padding-block: 1.25rem 3rem;
    }

    .hero__grid {
      align-items: start;
    }

    .hero h1 {
      max-width: 12.4ch;
    }

    .hero__meta-top {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .hero {
      padding-block: 1.2rem 2.8rem;
    }

    .hero h1 {
      max-width: none;
      font-size: clamp(2.55rem, 10.2vw, 3.95rem);
      line-height: 0.95;
    }

    .hero__copy {
      margin-top: 0.9rem;
      font-size: 0.97rem;
      line-height: 1.62;
    }

    .hero__content {
      padding-inline: 0.2rem;
    }

    .hero__actions {
      flex-direction: column;
      align-items: stretch;
      gap: 0.72rem;
    }

    .hero__meta {
      margin-top: 1.15rem;
    }

    .hero__fit,
    .hero__contact {
      padding: 0.95rem 1rem;
    }
  }
</style>
