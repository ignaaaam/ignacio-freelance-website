---
import { getLocaleFromPath } from '../i18n/utils';

const locale = getLocaleFromPath(Astro.url.pathname);
const isEnglish = locale === 'en';

const trust = isEnglish
  ? ['Projects from EUR 800', 'Reply within 24 business hours', 'Remote from Spain', 'No commitment required']
  : ['Proyectos desde 800 EUR', 'Respuesta habitual en 24h laborables', 'Remoto desde España', 'Sin compromiso'];
---

<section class="contact-intro">
  <div class="container contact-intro__shell">
    <div class="contact-intro__main">
      <h1 class="contact-intro__heading">
        {isEnglish ? 'Start with a clear brief' : 'Empieza con un briefing claro'}
      </h1>
      <p class="contact-intro__sub">
        {isEnglish
          ? 'Tell me what you need, what result you want and what timeline you are working with. That is usually enough for a useful first reply.'
          : 'Cuéntame qué necesitas, qué resultado buscas y qué plazo manejas. Con eso suele bastar para una primera respuesta útil.'}
      </p>
    </div>

    <div class="contact-intro__meta">
      <div class="contact-intro__pills">
        {trust.map((item) => (
          <span class="contact-intro__pill">{item}</span>
        ))}
      </div>
      <a href={isEnglish ? '/en/services' : '/servicios'} class="contact-intro__back">
        {isEnglish ? '← See all services' : '← Ver todos los servicios'}
      </a>
    </div>
  </div>
</section>

<style>
  .contact-intro {
    padding-block: clamp(3rem, 5vw, 4rem) clamp(2rem, 3vw, 2.8rem);
    color: var(--theme-dark-text);
    background:
      radial-gradient(circle at top left, rgba(31, 107, 255, 0.18), transparent 28%),
      linear-gradient(180deg, rgba(9, 11, 16, 0.98), rgba(13, 16, 24, 0.98));
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .contact-intro__shell {
    display: grid;
    gap: 1.4rem;
  }

  .contact-intro__main {
    display: grid;
    gap: 0.65rem;
    max-width: 56ch;
  }

  .contact-intro__heading {
    font-size: clamp(1.9rem, 3.5vw, 3rem);
    line-height: 1.05;
  }

  .contact-intro__sub {
    color: var(--theme-dark-muted);
    font-size: clamp(0.96rem, 1.1vw, 1.05rem);
    line-height: 1.72;
  }

  .contact-intro__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    justify-content: space-between;
  }

  .contact-intro__pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .contact-intro__pill {
    display: inline-flex;
    align-items: center;
    padding: 0.42rem 0.86rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    color: var(--theme-dark-text);
    font-size: 0.88rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .contact-intro__back {
    font-size: 0.92rem;
    font-weight: 700;
    color: rgba(246, 248, 252, 0.76);
    white-space: nowrap;
  }

  .contact-intro__back:hover {
    color: var(--theme-dark-text);
  }

  @media (max-width: 720px) {
    .contact-intro__meta {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.85rem;
    }

    .contact-intro__back {
      order: -1;
    }
  }
</style>
