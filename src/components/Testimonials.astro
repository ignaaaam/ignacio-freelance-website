---
import { getLocaleFromPath } from '../i18n/utils';
import { siteContent } from '../data/siteContent';

const locale = getLocaleFromPath(Astro.url.pathname);
const content = siteContent[locale].testimonials;
---

<section class="section section-alt" id="testimonios">
  <div class="container">
    <div class="section-heading">
      <p class="section-eyebrow">{content.eyebrow}</p>
      <h2>{content.title}</h2>
      <p class="section-copy">{content.description}</p>
    </div>

    <div class="testimonial-grid">
      {content.items.map((item) => (
        <article class="testimonial-card surface-card" data-sr>
          <p class="testimonial-card__quote">"{item.quote}"</p>
          <div class="testimonial-card__meta">
            <div class="testimonial-card__avatar">{item.name[0]}</div>
            <div>
              <strong>{item.name}</strong>
              <p>{item.role} · {item.company}</p>
              <span>{item.context}</span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonial-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .testimonial-card {
    display: grid;
    gap: 1.5rem;
    padding: 1.5rem;
  }

  .testimonial-card__quote {
    font-size: 1.08rem;
    line-height: 1.75;
  }

  .testimonial-card__meta {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.85rem;
    align-items: center;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .testimonial-card__avatar {
    display: grid;
    place-items: center;
    width: 3rem;
    aspect-ratio: 1;
    border-radius: 999px;
    background: var(--color-text);
    color: var(--color-primary);
    font-family: var(--font-heading);
    font-weight: 800;
  }

  .testimonial-card__meta p,
  .testimonial-card__meta span {
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .testimonial-card__meta span {
    display: inline-block;
    margin-top: 0.35rem;
    font-size: 0.92rem;
  }

  @media (max-width: 1100px) {
    .testimonial-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .testimonial-grid {
      grid-template-columns: 1fr;
    }

    .testimonial-card {
      padding: 1.15rem;
      gap: 1.15rem;
    }

    .testimonial-card__meta {
      align-items: start;
    }
  }
</style>
