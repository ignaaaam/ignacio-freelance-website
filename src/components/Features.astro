---
import { getLocaleFromPath } from '../i18n/utils';
import { siteContent } from '../data/siteContent';

const locale = getLocaleFromPath(Astro.url.pathname);
const content = siteContent[locale].services;
---

<section class="section" id="servicios">
  <div class="container">
    <div class="section-heading">
      <p class="section-eyebrow">{content.eyebrow}</p>
      <h2>{content.title}</h2>
      <p class="section-copy">{content.description}</p>
    </div>

    <div class="service-grid">
      {content.items.map((item, index) => (
        <article class="service-card surface-card" data-sr>
          <div class="service-card__top">
            <span class="service-card__index">{String(index + 1).padStart(2, '0')}</span>
            <span class="service-card__eyebrow">{locale === 'en' ? 'Core offer' : 'Servicio principal'}</span>
          </div>

          <div class="service-card__heading">
            <h3>{item.name}</h3>
            <p>{item.summary}</p>
          </div>

          <div class="service-card__benefits">
            <article>
              <span>{locale === 'en' ? 'Built for' : 'Pensado para'}</span>
              <p>{item.bulletA}</p>
            </article>
            <article>
              <span>{locale === 'en' ? 'Delivers' : 'Aporta'}</span>
              <p>{item.bulletB}</p>
            </article>
          </div>

          <a href={item.href} class="service-card__link">
            <span>{locale === 'en' ? 'See service details' : 'Ver detalles del servicio'}</span>
            <strong>{locale === 'en' ? 'Open page' : 'Abrir pagina'}</strong>
          </a>
        </article>
      ))}
    </div>

    <div class="service-hub-cta">
      <a href={siteContent[locale].nav.servicesHubHref} class="btn-secondary">{content.hubCta}</a>
    </div>
  </div>
</section>

<style>
  .service-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.15rem;
  }

  .service-card {
    display: grid;
    gap: 1.2rem;
    padding: 1.8rem;
  }

  .service-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .service-card__index {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.45rem;
    height: 2.45rem;
    padding: 0 0.55rem;
    border-radius: 999px;
    background: rgba(31, 107, 255, 0.08);
    color: var(--theme-accent-strong);
    font-size: 0.9rem;
    font-weight: 800;
  }

  .service-card__eyebrow {
    color: var(--theme-accent-strong);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .service-card__heading {
    display: grid;
    gap: 0.75rem;
  }

  .service-card__heading h3 {
    font-size: clamp(1.45rem, 2vw, 1.7rem);
  }

  .service-card__heading p,
  .service-card__benefits p {
    color: var(--color-text-muted);
    line-height: 1.74;
  }

  .service-card__benefits {
    display: grid;
    gap: 0.85rem;
  }

  .service-card__benefits article {
    display: grid;
    gap: 0.35rem;
    padding: 1rem;
    border: 1px solid rgba(17, 19, 26, 0.08);
    border-radius: 1.15rem;
    background: rgba(247, 249, 253, 0.88);
  }

  .service-card__benefits span {
    color: var(--theme-accent-strong);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .service-card__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.85rem;
    margin-top: auto;
    padding: 1rem 1.05rem;
    border-radius: 1.15rem;
    background: rgba(15, 23, 42, 0.04);
    color: var(--color-text);
  }

  .service-card__link span {
    color: var(--color-text-muted);
  }

  .service-card__link strong {
    color: var(--theme-accent-strong);
  }

  .service-hub-cta {
    margin-top: 1.5rem;
  }

  @media (max-width: 1100px) {
    .service-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .service-grid {
      grid-template-columns: 1fr;
    }

    .service-card {
      padding: 1.35rem;
    }

    .service-card__link {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
