---
import { getLocaleFromPath } from '../i18n/utils';

const locale = getLocaleFromPath(Astro.url.pathname);
const isEnglish = locale === 'en';
---

<div id="cookie-consent" class="cookie-consent surface-card" hidden>
  <div class="cookie-consent__body">
    <strong>{isEnglish ? 'Optional site measurement' : 'Medicion opcional del sitio'}</strong>
    <p>
      {isEnglish
        ? 'If you allow it, I use analytics to understand visits and improve the site. If you decline, everything essential still works as expected.'
        : 'Si la permites, uso analitica para entender las visitas y mejorar la web. Si la rechazas, todo lo esencial sigue funcionando igual.'}
    </p>
  </div>

  <div class="cookie-consent__actions">
    <a href={isEnglish ? '/en/privacy' : '/privacidad'} class="btn-secondary cookie-consent__link">
      {isEnglish ? 'Privacy details' : 'Detalles de privacidad'}
    </a>
    <button type="button" class="btn-secondary" data-consent-action="reject">
      {isEnglish ? 'Reject' : 'Rechazar'}
    </button>
    <button type="button" class="btn-primary" data-consent-action="accept">
      {isEnglish ? 'Allow measurement' : 'Permitir medicion'}
    </button>
  </div>
</div>

<style>
  .cookie-consent {
    position: fixed;
    left: 50%;
    bottom: max(0.85rem, env(safe-area-inset-bottom));
    z-index: 80;
    display: grid;
    gap: 1rem;
    width: min(760px, calc(100% - 1.25rem));
    padding: 1rem 1.1rem;
    transform: translate(-50%, calc(100% + 2rem));
    transition: transform 0.22s ease;
  }

  .cookie-consent[data-visible='true'] {
    transform: translate(-50%, 0);
  }

  .cookie-consent__body {
    display: grid;
    gap: 0.45rem;
  }

  .cookie-consent__body p {
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .cookie-consent__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .cookie-consent__link {
    margin-right: auto;
  }

  @media (max-width: 720px) {
    .cookie-consent {
      gap: 0.85rem;
      padding: 0.95rem;
      width: min(760px, calc(100% - 1rem));
      border-radius: 1.15rem;
    }

    .cookie-consent__actions {
      display: grid;
      grid-template-columns: 1fr;
    }

    .cookie-consent__link {
      margin-right: 0;
    }
  }
</style>

<script is:inline data-astro-rerun>
  function bindCookieConsent() {
    const banner = document.getElementById('cookie-consent');
    if (!banner || banner.dataset.bound === 'true') return;

    banner.dataset.bound = 'true';

    const stored = localStorage.getItem('cookie-consent');
    if (!stored) {
      banner.hidden = false;
      requestAnimationFrame(() => banner.setAttribute('data-visible', 'true'));
    }

    banner.querySelectorAll('[data-consent-action]').forEach((button) => {
      button.addEventListener('click', () => {
        const action = button.getAttribute('data-consent-action');
        if (!action) return;

        localStorage.setItem('cookie-consent', action);
        banner.removeAttribute('data-visible');
        setTimeout(() => {
          banner.hidden = true;
        }, 220);

        window.dispatchEvent(new CustomEvent('site:consent-changed', { detail: action }));
      });
    });
  }

  bindCookieConsent();
  document.addEventListener('astro:after-swap', bindCookieConsent);
</script>
