---
import { getLocaleFromPath } from '../i18n/utils';

const locale = getLocaleFromPath(Astro.url.pathname);
const isEnglish = locale === 'en';
---

<div id="cookie-consent" class="cookie-consent surface-card" hidden>
  <div class="cookie-consent__body">
    <strong>{isEnglish ? 'Cookies & Analytics' : 'Cookies y Analítica'}</strong>
    <p class="cookie-consent__desc">
      {isEnglish
        ? "I use minimal analytics to see how the site performs. You can accept this or continue without tracking. No pressure!"
        : "Utilizo analítica básica para ver qué tal funciona la web. Puedes aceptarlo o continuar sin ellas. ¡Sin problema!"}
    </p>
  </div>

  <div class="cookie-consent__actions">
    <a href={isEnglish ? '/en/privacy' : '/privacidad'} class="btn-secondary cookie-consent__link">
      {isEnglish ? 'Privacy Policy' : 'Política de privacidad'}
    </a>
    <button type="button" class="btn-secondary cookie-consent__btn" data-consent-action="reject">
      {isEnglish ? 'No, thanks' : 'No, gracias'}
    </button>
    <button type="button" class="btn-primary cookie-consent__btn" data-consent-action="accept">
      {isEnglish ? 'Sounds good' : 'Me parece bien'}
    </button>
  </div>
</div>

<style>
  .cookie-consent {
    position: fixed;
    left: 50%;
    bottom: max(1rem, env(safe-area-inset-bottom));
    z-index: 80;
    display: grid;
    gap: 1rem;
    width: min(760px, calc(100% - 2rem));
    padding: 1rem 1.05rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.55rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02)),
      rgba(10, 12, 18, 0.92);
    box-shadow: 0 24px 60px rgba(7, 10, 16, 0.28);
    backdrop-filter: blur(24px);
    transform: translate(-50%, calc(100% + 2rem));
    transition: transform 0.22s ease;
  }

  .cookie-consent[data-visible='true'] {
    transform: translate(-50%, 0);
  }

  .cookie-consent__body {
    display: grid;
    gap: 0.35rem;
  }

  .cookie-consent__body strong {
    color: var(--theme-dark-text);
  }

  .cookie-consent__body p {
    color: var(--theme-dark-muted);
    line-height: 1.62;
  }

  .cookie-consent__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .cookie-consent__link {
    margin-right: auto;
  }

  @media (max-width: 720px) {
    .cookie-consent {
      gap: 0.6rem;
      padding: 0.85rem;
      width: calc(100% - 1.5rem);
      border-radius: 1.1rem;
    }

    .cookie-consent__actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .cookie-consent__link {
      width: 100%;
      text-align: center;
      margin-right: 0;
      margin-bottom: 0.25rem;
      font-size: 0.85rem;
      padding: 0.5rem;
    }

    .cookie-consent__btn {
      flex: 1;
      font-size: 0.85rem;
      padding: 0.6rem;
    }

    .cookie-consent__body strong {
      font-size: 0.95rem;
    }

    .cookie-consent__desc {
      font-size: 0.85rem;
      line-height: 1.4;
      margin-top: 0.2rem;
    }
  }
</style>

<script is:inline data-astro-rerun>
  function bindCookieConsent() {
    const banner = document.getElementById('cookie-consent');
    if (!banner || banner.dataset.bound === 'true') return;

    banner.dataset.bound = 'true';

    const stored = localStorage.getItem('cookie-consent');
    if (!stored) {
      banner.hidden = false;
      requestAnimationFrame(() => banner.setAttribute('data-visible', 'true'));
    }

    banner.querySelectorAll('[data-consent-action]').forEach((button) => {
      button.addEventListener('click', () => {
        const action = button.getAttribute('data-consent-action');
        if (!action) return;

        localStorage.setItem('cookie-consent', action);
        banner.removeAttribute('data-visible');
        setTimeout(() => {
          banner.hidden = true;
        }, 220);

        window.dispatchEvent(new CustomEvent('site:consent-changed', { detail: action }));
      });
    });
  }

  bindCookieConsent();
  document.addEventListener('astro:after-swap', bindCookieConsent);
</script>
