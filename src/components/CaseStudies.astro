---
import { getLocaleFromPath } from '../i18n/utils';
import { siteContent } from '../data/siteContent';

const locale = getLocaleFromPath(Astro.url.pathname);
const content = siteContent[locale].cases;
const labels =
  locale === 'en'
    ? { challenge: 'Challenge', solution: 'Solution', result: 'Result', metric: 'Signal' }
    : { challenge: 'Problema', solution: 'Enfoque', result: 'Resultado', metric: 'Indicador' };
---

<section class="section section-alt" id="casos">
  <div class="container">
    <div class="section-heading">
      <p class="section-eyebrow">{content.eyebrow}</p>
      <h2>{content.title}</h2>
      <p class="section-copy">{content.description}</p>
    </div>

    <div class="case-grid">
      {content.items.map((item) => (
        <article class="case-card surface-card">
          <p class="case-card__client">{item.client}</p>
          <div class="case-card__row">
            <span>{labels.challenge}</span>
            <p>{item.challenge}</p>
          </div>
          <div class="case-card__row">
            <span>{labels.solution}</span>
            <p>{item.solution}</p>
          </div>
          <div class="case-card__result">
            <span>{labels.result}</span>
            <p>{item.result}</p>
          </div>
          {item.metricValue && (
            <div class="case-card__metric">
              <span>{labels.metric}</span>
              <p>
                <strong>{item.metricValue}</strong>
                {item.metricLabel ? ` — ${item.metricLabel}` : ''}
                {item.timeframe ? <span class="case-card__time"> ({item.timeframe})</span> : null}
              </p>
            </div>
          )}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .case-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.15rem;
  }

  .case-card {
    padding: 1.75rem;
  }

  .case-card__client {
    margin-bottom: 1rem;
    font-size: 1.16rem;
    font-weight: 800;
  }

  .case-card__row,
  .case-card__result {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(17, 19, 26, 0.08);
  }

  .case-card__row span,
  .case-card__result span,
  .case-card__metric span:first-child {
    display: block;
    margin-bottom: 0.45rem;
    color: var(--theme-accent-strong);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .case-card__row p,
  .case-card__result p {
    color: var(--color-text-muted);
    line-height: 1.74;
  }

  .case-card__metric {
    margin-top: 1.15rem;
    padding: 1rem 1.05rem;
    border: 1px dashed rgba(31, 107, 255, 0.22);
    border-radius: 1.15rem;
    background: rgba(31, 107, 255, 0.06);
  }

  .case-card__metric p {
    color: var(--color-text);
    line-height: 1.6;
  }

  .case-card__time {
    color: var(--color-text-muted);
    font-weight: 500;
  }

  @media (max-width: 960px) {
    .case-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .case-grid {
      grid-template-columns: 1fr;
    }

    .case-card {
      padding: 1.35rem;
    }
  }
</style>
