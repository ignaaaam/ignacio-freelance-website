---
import { getLocaleFromPath } from '../i18n/utils';
import { siteContent } from '../data/siteContent';

const locale = getLocaleFromPath(Astro.url.pathname);
const content = siteContent[locale].cases;
const labels =
  locale === 'en'
    ? { challenge: 'Challenge', solution: 'Solution', result: 'Result', metric: 'Signal' }
    : { challenge: 'Problema', solution: 'Enfoque', result: 'Resultado', metric: 'Indicador' };
---

<section class="section section-alt" id="casos">
  <div class="container">
    <div class="section-heading">
      <p class="section-eyebrow">{content.eyebrow}</p>
      <h2>{content.title}</h2>
      <p class="section-copy">{content.description}</p>
    </div>

    <div class="case-grid">
      {content.items.map((item) => (
        <article class="case-card surface-card">
          <p class="case-card__client">{item.client}</p>
          <div class="case-card__row">
            <span>{labels.challenge}</span>
            <p>{item.challenge}</p>
          </div>
          <div class="case-card__row">
            <span>{labels.solution}</span>
            <p>{item.solution}</p>
          </div>
          <div class="case-card__result">
            <span>{labels.result}</span>
            <p>{item.result}</p>
          </div>
          {item.metricValue && (
            <div class="case-card__metric">
              <span>{labels.metric}</span>
              <p>
                <strong>{item.metricValue}</strong>
                {item.metricLabel ? ` — ${item.metricLabel}` : ''}
                {item.timeframe ? <span class="case-card__time"> ({item.timeframe})</span> : null}
              </p>
            </div>
          )}
        </article>
      ))}
    </div>
  </div>
</section>
