---
import Layout from '../layouts/Layout.astro';
import Header from './Header.astro';
import type { BlogEntry, BlogLocale } from '../data/blog';
import { formatBlogDate, getBlogEntryPathSlug, getBlogPostUrl } from '../data/blog';

interface Props {
  locale: BlogLocale;
  posts: BlogEntry[];
}

const { locale, posts } = Astro.props;
const isEnglish = locale === 'en';

function blogCardImageUrl(url: string): string {
  if (!url || !url.includes('images.unsplash.com')) return url;
  // Rebuild Unsplash URL with thumbnail params (w=600, WebP) for blog cards
  const [base] = url.split('?');
  // Preserve ixid/ixlib from original for attribution compliance
  const orig = new URL(url);
  const params = new URLSearchParams();
  if (orig.searchParams.get('ixid')) params.set('ixid', orig.searchParams.get('ixid')!);
  if (orig.searchParams.get('ixlib')) params.set('ixlib', orig.searchParams.get('ixlib')!);
  params.set('auto', 'format');
  params.set('fit', 'crop');
  params.set('w', '600');
  params.set('q', '75');
  params.set('fm', 'webp');
  return `${base}?${params.toString()}`;
}
const title = isEnglish
  ? 'Web development, product strategy and business website insights | Ignacio Amat'
  : 'Blog de desarrollo web, tecnología y decisiones de proyecto | Ignacio Amat';
const description = isEnglish
  ? 'Practical articles on websites, product decisions, technical tradeoffs, SEO, conversion and the systems behind better digital projects.'
  : 'Guías prácticas sobre tecnología, producto, SEO, conversión y decisiones web que ayudan a vender mejor y evitar errores caros.';
const canonicalUrl = isEnglish ? '/en/blog' : '/blog';
const alternateUrls = { es: '/blog', en: '/en/blog' };
const keywords = isEnglish
  ? ['web development blog', 'business website blog', 'web strategy', 'astro vs wordpress', 'custom web app', 'lead generation website']
  : ['blog desarrollo web', 'blog tecnologia para empresas', 'decisiones web', 'astro vs wordpress', 'aplicacion web a medida', 'captacion de leads'];

const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: isEnglish ? 'Ignacio Amat Blog' : 'Blog de Ignacio Amat',
  description,
  url: `https://www.ignacioamatweb.com${canonicalUrl}`,
  inLanguage: isEnglish ? 'en-US' : 'es-ES',
};
---

<Layout
  title={title}
  description={description}
  lang={locale}
  canonicalUrl={canonicalUrl}
  alternateUrls={alternateUrls}
  additionalSchemas={[blogSchema]}
  keywords={keywords}
>
  <Header languageSwitchUrls={alternateUrls} />
  <main>
    <section class="section">
      <div class="container">
        <div class="blog-hero surface-card" data-sr>
          <p class="section-eyebrow">{isEnglish ? 'Blog' : 'Blog'}</p>
          <h1>
            {isEnglish
              ? 'Articles for companies comparing platforms, redesigns, websites and product decisions.'
              : 'Artículos para empresas que comparan plataformas, rediseños, webs y decisiones de producto.'}
          </h1>
          <p class="section-copy">
            {isEnglish
              ? 'Technology and web development topics explained from a business angle: what to build, what to avoid, where the budget goes and what actually helps a site convert.'
              : 'Temas de tecnología y desarrollo web explicados desde negocio: qué construir, qué evitar, dónde se va el presupuesto y qué ayuda de verdad a convertir.'}
          </p>
        </div>

        <div class="blog-grid">
          {posts.map((post) => (
            <article class="blog-card surface-card" data-sr>
              <a href={getBlogPostUrl(locale, getBlogEntryPathSlug(post))} class="blog-card__link">
                <div class="blog-card__media">
                  <img
                    src={blogCardImageUrl(post.data.heroImage)}
                    alt={post.data.heroImageAlt}
                    class="blog-card__image"
                    loading="lazy"
                    decoding="async"
                    width="600"
                    height="375"
                  />
                </div>
                <div class="blog-card__content">
                  <div class="blog-card__meta">
                    <span class="blog-card__badge">{post.data.category}</span>
                    <time datetime={post.data.publishedDate.toISOString()}>{formatBlogDate(post.data.publishedDate, locale)}</time>
                    <span>{post.data.readTime}</span>
                  </div>
                  <h2>{post.data.title}</h2>
                  <p>{post.data.description}</p>
                  <span class="btn-tertiary">{isEnglish ? 'Read article' : 'Leer artículo'}</span>
                </div>
              </a>
            </article>
          ))}
        </div>

        <div class="blog-cta surface-card" data-sr>
          <div>
            <p class="section-eyebrow">{isEnglish ? 'Need a clearer website?' : '¿Necesitas una web más clara?'}</p>
            <h2>
              {isEnglish
                ? 'If these topics feel familiar, the site is probably creating friction already.'
                : 'Si alguno de estos temas te suena, probablemente la web ya esté creando fricción.'}
            </h2>
            <p class="section-copy">
              {isEnglish
                ? 'Tell me what is not working and I will tell you whether you need a landing page, a redesign, a stronger business website or a custom build.'
                : 'Cuéntame qué no está funcionando y te diré si necesitas una landing, un rediseño, una web de empresa mejor planteada o un desarrollo a medida.'}
            </p>
          </div>
          <a href={isEnglish ? '/en/#contacto' : '/#contacto'} class="btn-primary">
            {isEnglish ? 'Tell me about your project' : 'Cuéntame tu proyecto'}
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .blog-hero,
  .blog-card,
  .blog-cta {
    padding: 1.45rem;
  }

  .blog-hero {
    display: grid;
    width: 100%;
    max-width: none;
    gap: 0.7rem;
    padding: 1.6rem 1.7rem;
    background:
      radial-gradient(circle at top left, rgba(31, 107, 255, 0.18), transparent 28%),
      linear-gradient(180deg, rgba(10, 12, 18, 0.98), rgba(13, 16, 24, 0.98));
    color: var(--theme-dark-text);
    border-color: rgba(255, 255, 255, 0.08);
  }

  .blog-hero h1 {
    max-width: 14ch;
    margin-bottom: 0;
    color: var(--theme-dark-text);
    font-size: clamp(2.3rem, 4vw, 4rem);
    line-height: 0.92;
  }

  .blog-hero .section-copy {
    max-width: 74ch;
    color: var(--theme-dark-muted);
    font-size: 1rem;
    line-height: 1.72;
  }

  .blog-hero .section-eyebrow {
    border-color: rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.06);
    color: rgba(246, 248, 252, 0.82);
  }

  .blog-grid {
    display: grid;
    gap: 1.1rem;
    margin-top: 1.3rem;
  }

  .blog-card__link {
    display: grid;
    grid-template-columns: minmax(280px, 360px) minmax(0, 1fr);
    gap: 1.15rem;
    align-items: start;
  }

  .blog-card__media {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 230px;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: 1.2rem;
    border: 1px solid rgba(17, 19, 26, 0.08);
    background: rgba(255, 255, 255, 0.78);
  }

  .blog-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .blog-card__content {
    display: grid;
    align-content: start;
    gap: 0.8rem;
    min-width: 0;
    padding-block: 0.1rem;
  }

  .blog-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem 0.75rem;
    align-items: center;
    color: var(--color-text-muted);
    font-size: 0.88rem;
  }

  .blog-card__badge {
    display: inline-flex;
    align-items: center;
    min-height: 1.8rem;
    padding: 0.24rem 0.62rem;
    border-radius: 999px;
    background: rgba(31, 107, 255, 0.08);
    color: var(--theme-accent-strong);
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-size: 0.75rem;
  }

  .blog-card h2 {
    max-width: 24ch;
    font-size: clamp(1.35rem, 2vw, 2rem);
    line-height: 0.96;
  }

  .blog-card p {
    max-width: 58ch;
    color: var(--color-text-muted);
    line-height: 1.72;
  }

  .blog-cta {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1.2rem;
    margin-top: 1.5rem;
    background:
      radial-gradient(circle at top left, rgba(31, 107, 255, 0.18), transparent 28%),
      linear-gradient(180deg, rgba(10, 12, 18, 0.98), rgba(13, 16, 24, 0.98));
    color: var(--theme-dark-text);
    border-color: rgba(255, 255, 255, 0.08);
  }

  .blog-cta h2,
  .blog-cta .section-copy {
    color: var(--theme-dark-text);
  }

  .blog-cta .section-copy {
    color: var(--theme-dark-muted);
  }

  .blog-cta .section-eyebrow {
    border-color: rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.06);
    color: rgba(246, 248, 252, 0.82);
  }

  @media (max-width: 720px) {
    .blog-hero,
    .blog-card,
    .blog-cta {
      padding: 1.2rem;
    }

    .blog-hero h1 {
      max-width: none;
    }

    .blog-card__link {
      grid-template-columns: 1fr;
      gap: 0.8rem;
    }

    .blog-card__media {
      min-height: 0;
    }

    .blog-cta {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
